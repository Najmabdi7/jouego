om/L81O9/thumbnail/small.png","url":"https://play.gamepix.com/poly-art/embed?sid=1","plays":43804,"rating":4.8,"featured":true,"source":"gamepix"}}],["$","$L5","40071",{"game":{"id":"40071","slug":"cut-the-rope","title":"Cut The Rope","description":"Vous avez reçu un mystérieux paquet, et le petit monstre à l’intérieur n’a envie que d’une chose… de BONBONS ! Collectez les étoiles dorées, découvrez les prix cachés et débloquez de nouveaux niveaux dans ce jeu addictif acclamé par la critique et au moteur physique réaliste!","category":"Puzzle","tags":["classics","puzzles"],"thumbnail":"https://games.assets.gamepix.com/40071/thumbnail/small.png","url":"https://play.gamepix.com/cut-the-rope/embed?sid=1","plays":43711,"rating":4.8,"featured":true,"source":"gamepix"}}],["$","$L5","40337",{"game":{"id":"40337","slug":"cut-the-rope-experiments","title":"Cut the Rope Experiments","description":"Le petit monstre vert Om Nom est de retour et il est plus affamé que jamais! Faites équipe avec le Professeur, un savant un peu fou (mais pas voyou!) résolu à étudier le goût prononcé de Om Nom pour les bonbons à l'aide d'expérimentations en tout genre. Dévoiler les prix cachés et déverrouiller de nouveaux niveaux! ","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/40337/thumbnail/small.png","url":"https://play.gamepix.com/cut-the-rope-experiments/embed?sid=1","plays":43703,"rating":4.8,"featured":true,"source":"gamepix"}}]]}]]}]]}]]}]}]]],null],null]},["$","$L6",null,{"parallelRouterKey":"children","segmentPath":["children","game","children","$7","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L8",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined","styles":[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/b9e0354fe0ba80bd.css","precedence":"next","crossOrigin":"$undefined"}]]}],null]},["$","$L6",null,{"para