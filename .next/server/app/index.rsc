0:["HGwViRD4yYULRUXFPKjk2",[[["",{"children":["__PAGE__",{}]},"$undefined","$undefined",true],["",{"children":["__PAGE__",{},[["$L1",[["$","$L2",null,{}],["$","$3",null,{"fallback":["$","div",null,{"className":"page_loading__4WMny","children":"Chargement..."}],"children":["$","$L4",null,{"games":[{"id":"36DO1","slug":"body-drop-3d","title":"Body Drop 3D","description":"The game will delight you with a realistic simulation of the body falling! Its advantage is not only physics, but also the realistic behavior of the character, his animations, nice graphics and many levels!","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/36DO1/thumbnail/small.png","url":"https://play.gamepix.com/body-drop-3d/embed?sid=1","plays":46072,"rating":4.9,"featured":true,"source":"gamepix"},{"id":"GS7CA","slug":"slope-racing-3d","title":"Slope Racing 3D","description":"Welcome to Slope Racing 3D!  It is a 3D running game with perfect controls, breath-taking speeds, and an addictive gameplay. \nHow far can you go without reaching the floor? Try Slope Racing 3D, the more you play the game, the easier it is and the more enjoyable it is. Our goal in the game is to make the ball roll without falling on the surface of the inclined buildings.. Get ready for serious speed boost as you fall downhill the never-ending surface. Play Slope Racing 3D!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/GS7CA/thumbnail/small.png","url":"https://play.gamepix.com/slope-racing-3d/embed?sid=1","plays":45437,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"7MS9M","slug":"moto-x3m-spooky-land","title":"Moto X3M: Spooky Land","description":"Drive your motorbike through Halloween-themed tracks filled with obstacles and stunt opportunities. Get your bike through the trials quickly to earn more points!","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/7MS9M/thumbnail/small.png","url":"https://play.gamepix.com/moto-x3m-spooky-land/embed?sid=1","plays":45358,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"P11VR","slug":"lol-surprise-insta-party-divas","title":"LOL Surprise Insta Party Divas","description":"Welcome to the LOL Surprise Insta Party Divas. LOL girls heard about the surprise Insta party. They planned to try some new trends. But they need some hands to be perfect. Browse the girl’s wardrobe for perfect outfits and costumes. Before that pick some cute makeover for the girls. Play and have fun!","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/P11VR/thumbnail/small.png","url":"https://play.gamepix.com/lol-surprise-insta-party-divas/embed?sid=1","plays":45247,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"35LBE","slug":"basketball-stars","title":"Basketball Stars","description":"Basketball Stars is a 2-player basketball game. In this game, you can play with your favorite team and play with basketball legends. In this game, you can either play with friends in 2-player mode or solo in single-player mode.\nShow off your basketball skills and see if you can score a three-pointer or slam home an impressive dunk! You can play as many different legendary teams and try out both your defensive and offensive skills.","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/35LBE/thumbnail/small.png","url":"https://play.gamepix.com/basketball-stars/embed?sid=1","plays":44852,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"20XI2","slug":"drunken-boxing-2","title":"Drunken Boxing 2","description":"New game is live for boxing lovers! Drunken Boxing 2 offers a new gaming experience with renewed animations, effects and 3D graphics. Try to control the Drunken Boxers and throw quick punches at your opponent but watch out for your Energy Bar! If you run out of energy, it will take a while for you to recover. Make forward and backward moves, throw quick punches and win the match!\n\nDrunken Boxing game has 1P and 2P modes. The first to reach a score of 5 in the game wins the match!\n\nGame Controls:\nPLAYER 1: \"ARROW KEYS\"\nPLAYER 2: \"W,A,S,D\"","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/20XI2/thumbnail/small.png","url":"https://play.gamepix.com/drunken-boxing-2/embed?sid=1","plays":44844,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"NG7TT","slug":"among-at-easter","title":"Among at Easter","description":"Play online or over local WiFi with 4-10 players as you attempt to prep your spaceship for departure, but beware as one will be an impostor bent on killing everyone!\n\nCrewmates can win by completing all tasks or discovering and voting the impostor off the ship.\n\nThe Impostor can use sabotage to cause chaos, making for easier kills and better alibis.\n","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/NG7TT/thumbnail/small.png","url":"https://play.gamepix.com/among-at-easter/embed?sid=1","plays":44740,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"40434","slug":"magikmon","title":"Magikmon","description":"Magikmon is an awesome RPG game in which you must capture different types of monsters. The magical world you live in is packed full with weird and wonderful monsters. You can use them to battle! Enjoy it!","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/40434/thumbnail/small.png","url":"https://play.gamepix.com/magikmon/embed?sid=1","plays":44728,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"O2NNU","slug":"battle-simluator-counter-stickman","title":"Battle Simluator - Counter Stickman","description":"The stickmen must strike at the terror enemy stickmen in this Battle Simulator\n\nThe stickmen terror forces must be stopped with a tactical strike! You are the battle commander of the counter terrorist stickman (CTS) forces.\n\n▶TABS simulator - style gameplay\n▶3D stickmen, levels and gun models\n▶Help win the stickman war.. on terror!\n▶Accurate stickman tactics\n\nSounds: Freesound.org\nMusic_cornandbeans_generic_techno","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/O2NNU/thumbnail/small.png","url":"https://play.gamepix.com/counter-stickman/embed?sid=1","plays":44705,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"L6TL9","slug":"fractal-combat-x","title":"Fractal Combat X","description":"FCX is an HTML5 action-packed flight combat game, sporting top notch 3D graphics, WebGL and a progressively intense gameplay!\n\nMAIN FEATURES\n- Exciting, fast-paced arcade flight combat action\n- Top notch 3D graphics\n- Unique gorgeous fractal landscapes\n- Dozens of missions in Story mode\n- New missions every day!\n- Epic sound tracks\n- Arcade and Simulator modes\n- Cross-device","category":"Arcade","tags":["arcade","classics"],"thumbnail":"https://games.assets.gamepix.com/L6TL9/thumbnail/small.png","url":"https://play.gamepix.com/fractal-combat-x/embed?sid=1","plays":44699,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"EYN60","slug":"funny-throat-surgery","title":"Funny Throat Surgery","description":"Having a throat sore? Let the doctor see you! Cure the diseases on you gums, destroy all bacteries, and remove the infected amandels. Get some cute and funny dress up at the end of your journey to the doctor. It's important to be healthy and stylish!","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/EYN60/thumbnail/small.png","url":"https://play.gamepix.com/funny-throat-surgery/embed?sid=1","plays":44452,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"1N6AV","slug":"vangers-hd","title":"Vangers HD","description":"Mind-altering sandbox game that can be described as a racing role-playing adventure game with a complicated storyline. You’ll find a unique atmosphere, complete freedom and lots of gameplay hours to figure out what’s the game is all about.","category":"Aventure","tags":["arcade","classics","strategy"],"thumbnail":"https://games.assets.gamepix.com/1N6AV/thumbnail/small.png","url":"https://play.gamepix.com/vangers/embed?sid=1","plays":44151,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"40450","slug":"alpha-guns","title":"Alpha Guns","description":"Alpha Guns a 2D side scroller shooter with classic gameplay and unique mechanics. Play as a soldier from the Elite Force!","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/40450/thumbnail/small.png","url":"https://play.gamepix.com/alpha-guns/embed?sid=1","plays":44074,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"20048","slug":"foot-chinko","title":"Foot Chinko","description":"Défiez vos adversaires dans le tournoi de football le plus célèbre au monde. Serez-vous assez doué pour rafler toutes les récompenses des 90 niveaux du jeu ? Assez brave pour vous confronter au gardien de but surnommé le \"gardien du diable\" ? Nous verrons!","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/20048/thumbnail/small.png","url":"https://play.gamepix.com/foot-chinko/embed?sid=1","plays":44071,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"2TM7A","slug":"football-masters","title":"Football Masters","description":"Football Masters Euro 2020 is a fun soccer game.  In this game, you can play as your favorite team and compete against other teams in challenging football matches; solo or together with your friends. Show your best ball kicking moves! \n","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/2TM7A/thumbnail/small.png","url":"https://play.gamepix.com/football-masters/embed?sid=1","plays":43950,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"DDY8C","slug":"red-and-blue-stickman-huggy","title":"Red and Blue Stickman Huggy","description":"Are you ready for the adventure of two very cute brothers, namely blue and red stickman? Brothers red and blue need to get the key and reach the door. Be two people and get them to the door with your friend. reach the door and pass it to the new level. You will face multiple challenges but reach the door. \n\nHow to Play?\n*Move to WASD + Arrow Keys                  \n*Double Jump available                  \n*Mobile Touch Control","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/DDY8C/thumbnail/small.png","url":"https://play.gamepix.com/red-and-blue-stickman-huggy/embed?sid=1","plays":43901,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"54418","slug":"pixel-on-titan","title":"Pixel on Titan","description":"The titans is coming and attacking the city, you need to save the civilians in the city by killing all the titans in this beautiful pixel art game based on manga or anime attack on titan (AoT).\n\n*This game will be updated periodically\n\nMove Left = A   Move Right = D  Attack = F  Jump to Certain Direction = Left Mouse Click","category":"Aventure","tags":["adventure","arcade"],"thumbnail":"https://games.assets.gamepix.com/54418/thumbnail/small.png","url":"https://play.gamepix.com/pixel-on-titan/embed?sid=1","plays":43891,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"PVPRV","slug":"red-impostor-vs-crew","title":"Red Impostor vs. Crew","description":"Red Imposter vs. Crew is a fun and engaging Action game. Your mission is simple: Execute all living crewmates in the spaceship. Let no one survive.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/PVPRV/thumbnail/small.png","url":"https://play.gamepix.com/red-impostor-vs-crew/embed?sid=1","plays":43859,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"40214","slug":"cut-the-rope-2","title":"Cut the Rope 2","description":"Cut the Rope 2 reprend les éléments qui ont fait le succès du premier volet, tout en ajoutant de nouveaux défis et des obstacles inattendus pour le plus grand bonheur des millions de fans aux quatre coins du globe ! Vous avez aimé Cut the Rope ? Vous allez adorer Cut the Rope 2!","category":"Aventure","tags":["adventure","puzzles","junior"],"thumbnail":"https://games.assets.gamepix.com/40214/thumbnail/small.png","url":"https://play.gamepix.com/cut-the-rope-2/embed?sid=1","plays":43854,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"40344","slug":"bomber-friends","title":"Bomber Friends","description":"Fais exploser tes amis et remporte le match en étant le dernier survivant! Ramasse les bonus pour obtenir des bombes toujours plus puissantes! Utilise les bombes explosives pour souffler tes amis à travers toute la carte!","category":"Arcade","tags":["arcade","classics"],"thumbnail":"https://games.assets.gamepix.com/40344/thumbnail/small.png","url":"https://play.gamepix.com/bomber-friends/embed?sid=1","plays":43821,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"L81O9","slug":"poly-art","title":"Poly Art","description":"Des dizaines d'animaux, de plantes, de véhicules, de fleurs et plus encore. Voilà ce qui vous attend dans cette œuvre d'art absolument fantastique et relaxante. Assemblez de belles images à partir de fragments et complétez tous les segments du jeu.\n","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/L81O9/thumbnail/small.png","url":"https://play.gamepix.com/poly-art/embed?sid=1","plays":43804,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"40263","slug":"1941-frozen-front","title":"1941 Frozen Front","description":"Menez les forces allemandes lors de la poussée vers l'Est ou défendez la mère patrie du côté soviétique. Choisissez la bonne tactique de guerre et gagnez vos galons en commandant de manière ingénieuse dans FROZEN FRONT ! Découvrez des batailles de la seconde guerre mondiale époustouflantes dans la toute nouvelle simulation militaire et STRATÉGIQUE de HandyGames™!","category":"Stratégie","tags":["strategy"],"thumbnail":"https://games.assets.gamepix.com/40263/thumbnail/small.png","url":"https://play.gamepix.com/1941-frozen-front/embed?sid=1","plays":43751,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"40071","slug":"cut-the-rope","title":"Cut The Rope","description":"Vous avez reçu un mystérieux paquet, et le petit monstre à l’intérieur n’a envie que d’une chose… de BONBONS ! Collectez les étoiles dorées, découvrez les prix cachés et débloquez de nouveaux niveaux dans ce jeu addictif acclamé par la critique et au moteur physique réaliste!","category":"Arcade","tags":["classics","puzzles"],"thumbnail":"https://games.assets.gamepix.com/40071/thumbnail/small.png","url":"https://play.gamepix.com/cut-the-rope/embed?sid=1","plays":43711,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"GC2MR","slug":"my-sugar-factory","title":"My Sugar Factory","description":"My Sugar Factory is a turn-based game about managing a sugar factory. Start with one sugar cane bush and earn millions! Buy a factory and open a laboratory to improve the sugar cane variety.","category":"Stratégie","tags":["strategy"],"thumbnail":"https://games.assets.gamepix.com/GC2MR/thumbnail/small.png","url":"https://play.gamepix.com/my-sugar-factory/embed?sid=1","plays":43707,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"40337","slug":"cut-the-rope-experiments","title":"Cut the Rope Experiments","description":"Le petit monstre vert Om Nom est de retour et il est plus affamé que jamais! Faites équipe avec le Professeur, un savant un peu fou (mais pas voyou!) résolu à étudier le goût prononcé de Om Nom pour les bonbons à l'aide d'expérimentations en tout genre. Dévoiler les prix cachés et déverrouiller de nouveaux niveaux! ","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/40337/thumbnail/small.png","url":"https://play.gamepix.com/cut-the-rope-experiments/embed?sid=1","plays":43703,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"35L6I","slug":"flip-goal","title":"Flip Goal","description":"Aim the ball to hit the goal! Time your kick perfectly without touching any other soccer players. Pick up your favourite team!\n\nAs you progress, you’ll collect coins to upgrade your soccer stadium and get new soccer balls!\n\nWin the soccer tournament, collect keys and open chests for more coins!\n\nBecome the world champion! With easy controls, Flip Goal gives you a whole new level of soccer experience.","category":"Sport","tags":["arcade","sports"],"thumbnail":"https://games.assets.gamepix.com/35L6I/thumbnail/small.png","url":"https://play.gamepix.com/flip-goal/embed?sid=1","plays":43677,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"ADHH2","slug":"dash-masters","title":"Dash Masters","description":"Les règles sont simples. Touchez l'écran pour sauter tous azimuts et faites glisser votre doigt vers le haut pour exécuter un Rush.\n\nIl y a 20 ans, les extraterrestres ont attaqué. Des milliards d'innocents ont péri.\n\nQuelques-uns d'entre nous sont parvenus à échapper in extremis à ce massacre systématique ! Nous nous sommes alors cachés et avons tout mis en œuvre pour créer la seule et unique arme qui nous permettrait de libérer la Terre et d'anéantir cette race d'aliens artificiels que nous avons surnommée les Robots.\n\nÉquipé de l'exo-armure C-31, vous tenterez l'impossible : infiltrer les tours offensives des extraterrestres et les démolir. Utilisez vos propulseurs pour détruire les Robots gardiens et frayez-vous un chemin à travers les défenses ennemies.","category":"Arcade","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/ADHH2/thumbnail/small.png","url":"https://play.gamepix.com/dash-masters/embed?sid=1","plays":43653,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"T02T0","slug":"tower-crush","title":"Tower Crush","description":"Tower Crush is an epic indie game where you build 1 tower, up to 6 floors, load them with weapons, upgrade, evolve and defeat your opponents in fantastic battles. A combination of action and strategy!\n\nDon't fear, you’ll collect Machine Guns, Cannons, Flame Guns, Bomb Launchers, Shockwaves, Rocket Launchers, Lasers, Teslas, Ice Cannons and Mighty Plasma Cannons to help defend your tower. Unleash the most devastating special powers upon your enemies in this Combat Game.","category":"Stratégie","tags":["classics"],"thumbnail":"https://games.assets.gamepix.com/T02T0/thumbnail/small.png","url":"https://play.gamepix.com/tower-crush/embed?sid=1","plays":43583,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"LNI17","slug":"lol-surprise-fresh-spring-look","title":"LOL Surprise Fresh Spring Look","description":"Welcome to the LOL Surprise Fresh Spring Look.  LOL Suprise Girls have some plans for welcoming their favorite season spring. They already filled their cupboard with new spring fashion. But they have a dilemma is to choose the best outfits. Browse the wardrobe and pick the suitable outfits for each one.","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/LNI17/thumbnail/small.png","url":"https://play.gamepix.com/lol-surprise-fresh-spring-look/embed?sid=1","plays":43559,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"871A2","slug":"swipy-basketball","title":"Swipy Basketball","description":"Swipy Basketball is the new basketball game you can play on any device! Swipe the balls towards the hoop and reach an higher score.\nCollect stars to unlock new skins. Improve your skills and become the master of Swipy Basketball!","category":"Arcade","tags":["arcade","sports"],"thumbnail":"https://games.assets.gamepix.com/871A2/thumbnail/small.png","url":"https://play.gamepix.com/swipy-basketball/embed?sid=1","plays":43556,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"0730R","slug":"superbike-hero","title":"Superbike Hero","description":"Compete across Europe and the Middle East as you race in the Superbike Series. Boost between opponents, hang-on around tight corners, collect coins and upgrade your superbike for the next race. Are you the Superbike Hero?","category":"Sport","tags":["sports","arcade"],"thumbnail":"https://games.assets.gamepix.com/0730R/thumbnail/small.png","url":"https://play.gamepix.com/superbike-hero/embed?sid=1","plays":43556,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"G7625","slug":"god-of-light","title":"God of Light","description":"nstallez-vous confortablement et immergez-vous corps et âme au cœur du monde de God of Light, un jeu lumineux qui va en faire voir de toutes les couleurs à votre matière grise ! \nAvec son extraordinaire gameplay qui met l’accent sur l’exploration, ses visuels splendides et sa bande-son génialissime signée UNKLE (le géant de la musique électronique), ce titre fait exploser les fondations du puzzle-game et repousse les lois de la physique vidéoludique pour offrir une expérience purement et simplement hors-norme !","category":"Puzzle","tags":["adventure","puzzles"],"thumbnail":"https://games.assets.gamepix.com/G7625/thumbnail/small.png","url":"https://play.gamepix.com/god-of-light/embed?sid=1","plays":43526,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"037S6","slug":"rabbit-samurai-2","title":"Rabbit Samurai 2","description":"Throw the rope and swing around to find all little bees and bring them back home.   ","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/037S6/thumbnail/small.png","url":"https://play.gamepix.com/rabbit-samurai-2/embed?sid=1","plays":43483,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"9I093","slug":"helix-blitz","title":"Helix Blitz","description":"Helix Blitz, the ultimate arcade game where you need to move the ball of paint down the helixes! Try to avoid the helixes and enter the cool Blitz mode!","category":"Arcade","tags":["classics"],"thumbnail":"https://games.assets.gamepix.com/9I093/thumbnail/small.png","url":"https://play.gamepix.com/helix-blitz/embed?sid=1","plays":43460,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"B34R1","slug":"drag-racing-club","title":"Drag Racing Club","description":"Entrez dans le monde passionnant des courses de dragsters dans ce jeu unique. Commencez comme outsider inconnu et frayez-vous un chemin jusqu'au sommet. Prouvez à tout le monde que vous êtes le meilleur pilote de la ville. Pour y parvenir, vous devrez acheter ou gagner les superbes voitures de vos adversaires. Ensuite tunez-les pour en faire des bolides puissants. En piste !\n\n","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/B34R1/thumbnail/small.png","url":"https://play.gamepix.com/drag-racing-club/embed?sid=1","plays":43416,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"45TBR","slug":"babel-tower","title":"Babel Tower","description":"You are building the Tower of Babel, that will reach to the sky!\nYou have a team of professionals: miners, masons, crafters, lumberjacks, builders, who will help you achieve success in this incremental idle game.\n\nNew fun machines are unlocked with every tower floor.\n\nThe game was made by Airapport and expands our idle games universe. \n\nControls\nPress-and-hold on the screen to mine stone, transfer stone to processing, speed up bricks creation, chop trees, and perform other activities.\n\nSell part of your resources at the Market to gain money for upgrades. At certain upgrade level the building works by itself, you will be spectating and having fun.\n\nRestarting your tower building gives you Golden Bricks, which boost your tap power, production and increase market prices.\n\nIf you are away you are earning time bonus, which can be used to speed up game processes.\n\nBuy special artifacts to boost your progress even further.","category":"Stratégie","tags":["arcade","strategy"],"thumbnail":"https://games.assets.gamepix.com/45TBR/thumbnail/small.png","url":"https://play.gamepix.com/babel-tower/embed?sid=1","plays":43366,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"ERSEI","slug":"supermarket-expert-idle","title":"Supermarket Expert Idle","description":"A new Supermarket idle adventure is now beginning with the experts of this job. You have just opened a new supermarket in your town and you should manage there. There are lots of customers visiting your supermarket daily. You can earn good money and you can open new departments inside your supermarket. More departments mean more income. Don't forget to do your upgrades within the upgrade menu. You can buy helpers and do your work faster. Let the Supermarket Expert Idle adventure begin!\n\nHow to play?\nMove: \"ARROW KEYS\" or \"W,A,S,D\" or \"MOUSE\" and \"LEFT-CLICK\"\n\nPick products from the places where they grow up or are produced and place them inside their departments and check out customers on the counter and earn money.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/ERSEI/thumbnail/small.png","url":"https://play.gamepix.com/supermarket-expert-idle/embed?sid=1","plays":43328,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"40307","slug":"basket-champs","title":"Basket Champs","description":"Basket Champs is the brand new game from the developer of Foot Chinko. Select your basketball team and play in World Championship.","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/40307/thumbnail/small.png","url":"https://play.gamepix.com/basket-champs/embed?sid=1","plays":43327,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"IIAOR","slug":"funny-shooter-destroy-all-enemies","title":"Funny Shooter - Destroy all enemies","description":"Choose your weapon from the 18 available. Protect yourself from the invasion of enemies. Enemies differ in size and ability. Avoid enemy grenades and pitchforks. Dodge blows from clubs, axes, and chainsaws. Destroy enemies with a grenade launcher and a bazooka. Shoot them with machine guns and pistols. Destroy them all !!!       \n       \nFeatures:       \n- beautiful graphics       \n- a variety of weapons       \n- addictive gameplay       \n- driving music and great sound effects","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/IIAOR/thumbnail/small.png","url":"https://play.gamepix.com/funny-shooter-destroy-all-enemies/embed?sid=1","plays":43321,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"4B1SB","slug":"skyblock","title":"Skyblock","description":"Minecraft - SkyBlock Description Skyblock is a popular challenge, where the player starts the game in a small island in the void, including a tree and often a chest, which contains items you couldn't get without it. WASD or arrows Mouse or Touch","category":"Arcade","tags":["classics","arcade"],"thumbnail":"https://games.assets.gamepix.com/4B1SB/thumbnail/small.png","url":"https://play.gamepix.com/skyblock/embed?sid=1","plays":43290,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"40415","slug":"stock-car-hero","title":"Stock Car Hero","description":"Compete across North America as you race in the Stock Car Series. Dodge traffic, boost around banked corners, collect coins and upgrade your car for the next race. Are you the Stock Car Hero the world needs?","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/40415/thumbnail/small.png","url":"https://play.gamepix.com/stock-car-hero/embed?sid=1","plays":43256,"rating":4.8,"featured":true,"source":"gamepix"},{"id":"6A631","slug":"mr-santa-run-2","title":"Mr Santa Run 2","description":"mr santa run 2 is a html5 arcade game, run and avoid enemy, collect star to earn score","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/6A631/thumbnail/small.png","url":"https://play.gamepix.com/mr-santa-run-2/embed?sid=1","plays":43249,"rating":4.8,"featured":false,"source":"gamepix"},{"id":"40422","slug":"street-ball-jam","title":"Street Ball Jam","description":"A one-touch basketball arcade game with an endless gameplay. Unlock all balls, earn crystals to open extra courts and enjoy Street Ball Jam!","category":"Puzzle","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/40422/thumbnail/small.png","url":"https://play.gamepix.com/street-ball-jam/embed?sid=1","plays":43245,"rating":4.8,"featured":false,"source":"gamepix"},{"id":"TC86D","slug":"castel-war-3d","title":"Castel War 3D","description":"Defeat the opponent by collecting the balls and make troops. \n\nLet’s join the epic fight 3d simulator, fight like the strongest army clash in the town to defend your castle fight from the extreme fighting and crazy enemies. It is your duty to claim your legacy as a big hero warrior, assemble your epic clash army troops, get them ready for 3d battle view and destroy the enemy stick army of and become the master of the 3d battle view. Defend your gang clash castle fight as a big battle hero of your town.","category":"Stratégie","tags":["strategy"],"thumbnail":"https://games.assets.gamepix.com/TC86D/thumbnail/small.png","url":"https://play.gamepix.com/castel-war-3d/embed?sid=1","plays":43215,"rating":4.8,"featured":false,"source":"gamepix"},{"id":"C4LMG","slug":"ultimate-flying-car","title":"Ultimate Flying Car","description":"Do you want to take fast rides and flights on the long streets of the city? Ultimate Flying Car game invites you to realistic flying car simulator experience. Explore the sky with stylish flying cars, or unlock new cars by participating in races. You can play all of these game modes either 1 player or 2 player.\n\nPlayer 1:\nMove: \"W,A,S,D\"\nNOS: \"SHIFT  \"\nLook back: \"T\"\nFix car's position: \"R\"\nHandbrake: \"SPACE\"\n\nPlayer 2:\nMove: \"ARROW KEYS\"\nNOS: \"M\"\nLook back: \"L\"\nFix car's position: \"U\"\nHandbrake: \"K\"","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/C4LMG/thumbnail/small.png","url":"https://play.gamepix.com/ultimate-flying-car/embed?sid=1","plays":43173,"rating":4.8,"featured":false,"source":"gamepix"},{"id":"40407","slug":"bouncy-dunk","title":"Bouncy Dunk","description":"Get ready, shoot, score and WIN: Bouncy Dunk will make your excitement grow! Test your skills by winning all the challenges and unlock special basketballs to grow your power and style! Become a Bouncy Champion NOW!","category":"Sport","tags":["arcade","sports"],"thumbnail":"https://games.assets.gamepix.com/40407/thumbnail/small.png","url":"https://play.gamepix.com/bouncy-dunk/embed?sid=1","plays":43064,"rating":4.8,"featured":false,"source":"gamepix"},{"id":"20049","slug":"metal-animals","title":"Metal Animals","description":"Appelez les Metal Animals à la rescousse! Prenez le contrôle d'une escouade de petits animaux à fourrure aussi mignons que déterminés et défendez votre Tank face à l'ennemi!","category":"Aventure","tags":["adventure","strategy"],"thumbnail":"https://games.assets.gamepix.com/20049/thumbnail/small.png","url":"https://play.gamepix.com/metal-animals/embed?sid=1","plays":43020,"rating":4.8,"featured":false,"source":"gamepix"},{"id":"40272","slug":"dark-lands","title":"Dark Lands","description":"Frayez-vous un chemin au travers de hordes de squelettes, de trolls et affrontez les terribles scorpions et minotaures. Améliorez votre héros pour venir à bout du monde aventure et survivre au mode infini. Courez pour votre survie!","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/40272/thumbnail/small.png","url":"https://play.gamepix.com/dark-lands/embed?sid=1","plays":43014,"rating":4.8,"featured":false,"source":"gamepix"},{"id":"40405","slug":"foot-chinko-world-cup","title":"Foot Chinko World Cup","description":"Foot Chinko World Cup features a different take on soccer games with a unique blend of pachinko and pinball. As fun as soccer can get!","category":"Sport","tags":["arcade","sports"],"thumbnail":"https://games.assets.gamepix.com/40405/thumbnail/small.png","url":"https://play.gamepix.com/foot-chinko-world-cup/embed?sid=1","plays":43006,"rating":4.8,"featured":false,"source":"gamepix"},{"id":"23ES5","slug":"deadswitch-3","title":"Deadswitch 3","description":"Deadswitch 3 is a fast-paced 2D multiplayer shooter with plenty of game modes, maps, and weapons!","category":"Stratégie","tags":["strategy"],"thumbnail":"https://games.assets.gamepix.com/23ES5/thumbnail/small.png","url":"https://play.gamepix.com/deadswitch-3/embed?sid=1","plays":42926,"rating":4.8,"featured":false,"source":"gamepix"},{"id":"6O6G5","slug":"monster-go","title":"Monster Go","description":"Les Pokémonstres ne sont heureux qu'à deux ! Reliez-les à de l'énergie pour les activer. Amusez-vous avec ce jeu de casse-têtes simple mais addictif. N'oubliez pas de remplir le plateau de jeu de courant pour rendre les Pokémonstres heureux et gagner 3 étoiles. Les flux d'énergie ne peuvent ni se croiser ni se chevaucher.\n","category":"Puzzle","tags":["junior","puzzles"],"thumbnail":"https://games.assets.gamepix.com/6O6G5/thumbnail/small.png","url":"https://play.gamepix.com/monster-go/embed?sid=1","plays":42925,"rating":4.8,"featured":false,"source":"gamepix"},{"id":"20067","slug":"penalty-shooters","title":"Penalty Shooters","description":"2 joueurs, un ballon et un but - la guerre des penalty peut commencer ! Résisterez-vous à la pression des milliers de supporters pour gagner la coupe de ce jeu de foot hyper excitant ? Choisissez parmi 32 équipes et devenez le plus grand champion de tous les temps!","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/20067/thumbnail/small.png","url":"https://play.gamepix.com/penalty-shooters/embed?sid=1","plays":42906,"rating":4.8,"featured":false,"source":"gamepix"},{"id":"8MSVS","slug":"masquerades-vs-impostors","title":"Masquerades vs Impostors","description":"The man in the red and blue mask needs to escape from the spaceship? you must help them. watch out, only red colored impostors with red masks can kill. Likewise with the blue mask. Anyone can kill their own color. watch out for zombies, kill them too.\n\nHow to Play?\n*Played with WASD + Arrow Keys.  \n*Mobile touch control is available.  \n*double jump available  \n*jump on it to kill!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/8MSVS/thumbnail/small.png","url":"https://play.gamepix.com/masquerades-vs-impostors/embed?sid=1","plays":42884,"rating":4.8,"featured":false,"source":"gamepix"},{"id":"UR833","slug":"drunken-duel","title":"Drunken Duel","description":"\nDrunken Duel is an entertaining western game with physics-based one-button control that can be played as two people and one person. In the game, two drunk rag dolls duel. You can hit the chance serial target by firing randomly, but you can lose by playing this way. It is possible to take more professional shots by mastering the physics of the game after a few games. The sounds and visual effects in the game make the game more fun.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/UR833/thumbnail/small.png","url":"https://play.gamepix.com/drunken-duel/embed?sid=1","plays":42875,"rating":4.8,"featured":false,"source":"gamepix"},{"id":"S4271","slug":"push-noob","title":"Push Noob","description":"Push Noob - is an amazing simulator game about a dancing Noob and his fall. Join the earning of diamonds for pumping Noob and opening new locations.\nThrow snowballs at Noob and get diamonds for his collisions! Unlock new levels and skins! Compete in the amount of diamonds earned!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/S4271/thumbnail/small.png","url":"https://play.gamepix.com/push-noob/embed?sid=1","plays":42874,"rating":4.8,"featured":false,"source":"gamepix"},{"id":"ZB7M7","slug":"special-strike-zombies","title":"Special Strike Zombies","description":"You are special forces soldier and your mission is to use big arsenal of weapons to shoot hordes of zombies and mercenaries, choose suitable weapon for each wave of enemies in order to survive and successfully complete each level.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/ZB7M7/thumbnail/small.png","url":"https://play.gamepix.com/special-strike-zombies/embed?sid=1","plays":42872,"rating":4.8,"featured":false,"source":"gamepix"},{"id":"40232","slug":"little-alchemy","title":"Little Alchemy","description":"Libérez votre pouvoir créatif! Commencez avec les quatre éléments de base et utilisez-les pour trouver des dinosaures, des licornes et des vaisseaux spatiaux!","category":"Arcade","tags":["classics","puzzles"],"thumbnail":"https://games.assets.gamepix.com/40232/thumbnail/small.png","url":"https://play.gamepix.com/little-alchemy/embed?sid=1","plays":42794,"rating":4.8,"featured":false,"source":"gamepix"},{"id":"40376","slug":"cut-the-rope-magic","title":"Cut the Rope: Magic","description":"Rejoins la dernière aventure d'Om Nom et transforme ce charmant petit monstre par magie pour l'aider à récupérer ses bonbons volés par un sorcier magique! Un incident magique a accidentellement téléporté Om Nom vers un monde mystique rempli d'énigmes complexes pour des joueurs de tous les âges. Sauras-tu utiliser les nouvelles compétences d'Om Nom pour déjouer les ruses et pièges d'un sorcier maléfique?","category":"Aventure","tags":["arcade","adventure","puzzles"],"thumbnail":"https://games.assets.gamepix.com/40376/thumbnail/small.png","url":"https://play.gamepix.com/cut-the-rope-magic/embed?sid=1","plays":42790,"rating":4.8,"featured":false,"source":"gamepix"},{"id":"R3MA1","slug":"geometrical-dash","title":"Geometrical Dash","description":"Contrôlez un carré et arrivez à la fin, c'est tout ! Mais ce n'est pas aussi facile. Les niveaux que vous traverserez sont des labyrinthes de pixels conçus pour tester vos réflexes. La seule chose que vous devez faire, c'est sauter, sauter, et sauter encore au son de la musique ! Alors plongez dans ce jeu et goûtez au rythme de ce jeu délicat !\n","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/R3MA1/thumbnail/small.png","url":"https://play.gamepix.com/geometrical-dash/embed?sid=1","plays":42754,"rating":4.8,"featured":false,"source":"gamepix"},{"id":"51E00","slug":"king-rugni-tower-defense","title":"King Rugni Tower Defense","description":"A classic Tower Defense game with lots of enemies and territories to conquer. Join King Rügni on his epic adventure against hordes of elementals.","category":"Stratégie","tags":["strategy"],"thumbnail":"https://games.assets.gamepix.com/51E00/thumbnail/small.png","url":"https://play.gamepix.com/king-rugni-tower-conquest/embed?sid=1","plays":42639,"rating":4.8,"featured":false,"source":"gamepix"},{"id":"6B1I8","slug":"baby-hazel-bed-time","title":"Baby Hazel Bed Time","description":"Stars are twinkling in the sky and night seems beautiful in moonlight. Baby Hazel is now ready to go to bed but before that she needs to brush her teeth and take a shower. Help Hazel in carrying her bedtime activities. Make a bed for her and pamper the little girl by telling her interesting stories. If bad dream scares Hazel, pamper her with kisses and playing lullabies.","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/6B1I8/thumbnail/small.png","url":"https://play.gamepix.com/baby-hazel-bed-time/embed?sid=1","plays":42607,"rating":4.8,"featured":false,"source":"gamepix"},{"id":"SM1PS","slug":"master-chess-multiplayer","title":"Master Chess Multiplayer","description":"\"Use the most effective strategies to defeat the computer or real players from all over the world in this classic game for all time.\n\nThe goal of the game is to capture your opponent's king. This is done by moving the pieces on the board.\n\nWho will be the first to say \"\"Checkmate\"\".\n\nTo make a move, click on the shape and drag it to the desired position.\"","category":"Stratégie","tags":["board"],"thumbnail":"https://games.assets.gamepix.com/SM1PS/thumbnail/small.png","url":"https://play.gamepix.com/master-chess-multiplayer/embed?sid=1","plays":42575,"rating":4.8,"featured":false,"source":"gamepix"},{"id":"9DK7H","slug":"stacky-dash-nail","title":"Stacky Dash Nail","description":"Nail Stack is an hyper casual arcade game available on the web. This game focuses on stacking fingernails. The longer the nails, the bigger the reward for each level. ","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/9DK7H/thumbnail/small.png","url":"https://play.gamepix.com/stacky-dash-nail/embed?sid=1","plays":42561,"rating":4.8,"featured":false,"source":"gamepix"},{"id":"SL86T","slug":"basketball-master","title":"Basketball Master","description":"Un défi pour les vrais joueurs de basket et de streetball ! Sautez avec le ballon et faites un panier dans le délai imparti. Obtenez le meilleur score et collectez des pièces. Débloquez tous les ballons et lieux. Essayez 2 modes de jeu. Il vous faudra un timing précis, viser juste et un peu de chance.\n","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/SL86T/thumbnail/small.png","url":"https://play.gamepix.com/basketball-masters/embed?sid=1","plays":42553,"rating":4.8,"featured":false,"source":"gamepix"},{"id":"6S1Y8","slug":"funny-rescue-pet","title":"Funny Rescue Pet","description":"Lica and Purry had an accident! Lica's house is on fire, and Purry is soak wet when she played inside the wall. How can it happen? Rescue them immediately and also give them some makeover!","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/6S1Y8/thumbnail/small.png","url":"https://play.gamepix.com/funny-rescue-pet/embed?sid=1","plays":42537,"rating":4.8,"featured":false,"source":"gamepix"},{"id":"27115","slug":"bois-d-arc-bow-shooting","title":"Bois d'Arc: Bow Shooting","description":"Défendez votre château contre des forces obscures qui tentent de violer inimaginables ses puissants murs. Choisir l'un des trois royaumes arc de tir de héros dans ce jeu de tir arc super addictif et bourré d'action. Bois D'Arc déjà a déjà été joué par des millions sur les nombreux sites de jeu différents. Par conséquent VascoGames est fier de vous présenter la version complète mobile de ce jeu de tir à l'arc, choisissez votre héros et prendre les forces de mal sur la tête!","category":"Stratégie","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/27115/thumbnail/small.png","url":"https://play.gamepix.com/bois-d-arc/embed?sid=1","plays":42530,"rating":4.8,"featured":false,"source":"gamepix"},{"id":"24A7L","slug":"kobadoo-flags","title":"Kobadoo Flags","description":"Kobadoo Flags is a browser game that trains your brain by memorizing flags of the World in the right order.\n\nWhen you play Kobadoo Flags you are actively using your working memory. Several scientific studies suggest that training of working memory has beneficial effects and can increase your cognitive functions.","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/24A7L/thumbnail/small.png","url":"https://play.gamepix.com/kobadoo-flags/embed?sid=1","plays":42512,"rating":4.8,"featured":false,"source":"gamepix"},{"id":"R628C","slug":"halloween-horror-massacre","title":"Halloween Horror Massacre","description":"Halloween approche à grands pas, tout comme les nuits d'hiver froides et effrayantes ! Les horribles monstres ont aussi froid la nuit, alors ils doivent ajouter du bois à la chaudière. En plus de couper des têtes, ils doivent couper du bois ! Mais attention, leurs branches sont aussi dirigées vers vous ! Coupez autant de bûches que possible de l'arbre tout en évitant les branches qui approchent ! Changez de position pour éviter le danger. Avez-vous ce qu'il faut pour gagner la médaille d'or ?\n","category":"Aventure","tags":["adventure","arcade"],"thumbnail":"https://games.assets.gamepix.com/R628C/thumbnail/small.png","url":"https://play.gamepix.com/halloween-horror-massacre/embed?sid=1","plays":42504,"rating":4.8,"featured":false,"source":"gamepix"},{"id":"K41PS","slug":"killer-escape-huggy","title":"Killer Escape Huggy","description":"you are a murderer! And you have to kill all your teammates kill them all. Hunt down all your teammates and unleash the killer emotion inside the blue huggy. Only you can see the karambit in your hand, don't forget they're all dead secretly, hide, come out and kill the killer Huggy!  \n\nHow to Play?\nUse Arrow keys to move.  \nMobile control available.  \nKill all your teammates.  \nKill everyone before time runs out.  \n","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/K41PS/thumbnail/small.png","url":"https://play.gamepix.com/killer-escape-huggy/embed?sid=1","plays":42487,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"G32O2","slug":"red-impostor-guys","title":"Red Impostor Guys","description":"Red impostor guys Welcome to the Game World!\nFinish dozens of courses and collect crowns. Be the winner of the day! Buy the costumes and your image has been changed. Race with 10-40 people, be the winner of the race! Join the world of Fall Days. Race with different costumes on different maps! Make the Difference.\n10 Maps\n20 Uniform Costumes\nA completely different mechanic is waiting for you!\n\nHow to Play?\nWASD + ZQSD + Arrow Keys And Mobile Touch Controls","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/G32O2/thumbnail/small.png","url":"https://play.gamepix.com/red-mpostor-guys/embed?sid=1","plays":42486,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"999D9","slug":"death-run","title":"Death Run","description":"This game is an adventure game. You have thousands of lives in your hands. The game is full of various agencies. As the controller of the agency, you can repel all people and avoid passing.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/999D9/thumbnail/small.png","url":"https://play.gamepix.com/death-run/embed?sid=1","plays":42437,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"3N322","slug":"night-city-racing","title":"Night City Racing","description":"Night City has been prepared for the night races with this great car simulator game! It is time to challenge your opponents and prove to them you are the most skillful driver of all time. The best side of this adventure is to be played in both single player and in two player game modes. You can pick between various cars and you can customize these cars in the shop and you can have great moments while flying or while racing or while driving for free. Let the super Night City adventure begin!\n\nHow to play? \n\nIf playing single:\nMove: \"W,A,S,D\" or \"ARROW KEYS\"\nNOS: \"L-SHIFT\" or \"R-SHIFT\"\nRestart car position: \"R\"\nLook back: \"T\"\nChange camera view: \"C\"\n\nIf playing two player:\nPlayer 1:\nMove: \"ARROW KEYS\"\nNOS: \"M\"\nRestart car position: \"O\"\nLook back: \"P\"\nChange camera view: \"K\"\n\nPlayer 2:\nMove: \"W,A,S,D\"\nNOS: \"L-SHIFT\"\nRestart car position: \"R\"\nLook back: \"T\"\nChange camera view: \"C\"","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/3N322/thumbnail/small.png","url":"https://play.gamepix.com/night-city-racing/embed?sid=1","plays":42397,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"7PE6N","slug":"hunters-and-props","title":"Hunters and Props","description":"Hunt or be hunted in this fun first-person shooter game! Pretend that you are one of the props or play as the hunter in Hunter and Props!\n\nHunter and Props is a first-person multiplayer shooter game where the team is divided into two: the hunter, and the props. Playing as the hunter is quite easy, your goal is to shoot other players that are pretending to be the props and should not miss. Playing as one of the props is a bit tricky as you have to be both patient and cunning with your disguise. Remember the saying that the \"best way to hide a tree is in the forest\" and keep your disguise perfect. Good luck and have fun!","category":"Arcade","tags":["classics"],"thumbnail":"https://games.assets.gamepix.com/7PE6N/thumbnail/small.png","url":"https://play.gamepix.com/hunters-and-props/embed?sid=1","plays":42377,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"9T02R","slug":"smart-looter","title":"Smart Looter","description":"Be quick and sneaky and grab tons of loots! Watch out for the patrols and become the king of thieves!\n\n","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/9T02R/thumbnail/small.png","url":"https://play.gamepix.com/smart-looter/embed?sid=1","plays":42348,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"CD7KS","slug":"red-stickman-vs-monster-school","title":"Red Stickman vs Monster School","description":"Stickman vs Monster School - is a perfect game for the lovers of Red And Blue Stickman Adventure! The Stick Adventure is an addictive platform fighting game, where you have to control characters. Participate in the Monster School challenge together with the Red Stickman.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/CD7KS/thumbnail/small.png","url":"https://play.gamepix.com/red-stickman-vs-monster-school/embed?sid=1","plays":42338,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"1TOD6","slug":"wounded-winter-a-lakota-story","title":"Wounded Winter A Lakota Story","description":"\n\nAbout\nWounded Winter: A Lakota Story is a free action / shooter western game with a beautiful low poly graphic.\nStory\nThe hero of the story is called Akecheta, who is a Lakota(Native American). The Akecheta tribe is attacked and its people are killed while he is hunting. The attackers also took Akecheta's wife with them. Akecheta embarks on a perilous journey to bring his wife back and avenge the murderers of his tribe.\nFeatures:\n\n    Beautiful low poly style graphic\n    Strong native American protagonist\n    Fun and exciting action/shooter gameplay\n    Easy to pick up and play\n    For fans of western and action games\n\n","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/1TOD6/thumbnail/small.png","url":"https://play.gamepix.com/wounded-winter-a-lakota-story/embed?sid=1","plays":42332,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40621","slug":"10-blocks","title":"10 Blocks","description":"10 Blocks puzzle game is addicting brain tester game play. You need to place the given blocks on grid, while trying to fill up with grid rowscolumns blocks will disappear when are filled up horizontally or vertically. Always plan for next move because some blocks are not easy to fit in. You can use GRAVITY BUTTON once. Use it if you feeling stuck.","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/40621/thumbnail/small.png","url":"https://play.gamepix.com/10x10/embed?sid=1","plays":42309,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40442","slug":"angry-gran","title":"Angry Gran","description":"Play the game that began the Angry Gran series and take to the streets and whack those punk neighbors! ","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/40442/thumbnail/small.png","url":"https://play.gamepix.com/angry-gran/embed?sid=1","plays":42292,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"57RZE","slug":"baby-hazel-backyard-party","title":"Baby Hazel Backyard Party","description":"Baby Hazel was busy watching her favorite TV show, suddenly she got an idea of backyard party. She will be hosting the party first time, so she needs your help in decorating the venue and making all other necessary arrangements for the gathering. Play the game to help Hazel in organizing the party and also make sure guests are served properly.","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/57RZE/thumbnail/small.png","url":"https://play.gamepix.com/baby-hazel-backyard-party/embed?sid=1","plays":42254,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"C494N","slug":"russian-car-drift-3d","title":"Russian Car Drift 3D","description":"Russian Car Drift 3D is an HTML5 3D driving game that challenges you to get rid of the snow in each level using nothing but your crazy Russian vehicle. To do so, just skid & drift non-stop. The more you drift, the better! Drift in an old or new Russian car!","category":"Arcade","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/C494N/thumbnail/small.png","url":"https://play.gamepix.com/russian-car-drift-3d/embed?sid=1","plays":42244,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"33","slug":"zombie-can-t-jump","title":"Zombie Can't Jump","description":"Préparez-vous à l'invasion des zombies! Prenez vos armes, votre kit de construction et ne laissez pas les zombies vous mettre K.O! Organisez votre défense: TNT, pieux ou encore nids de mitrailleuses, récupérez de nouvelles armes surpuissantes et libérez votre fureur pour survivre!","category":"Aventure","tags":["adventure","strategy"],"thumbnail":"https://games.assets.gamepix.com/33/thumbnail/small.png","url":"https://play.gamepix.com/zombie-cant-jump/embed?sid=1","plays":42239,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"2R2U6","slug":"draw-save-puzzle","title":"Draw Save Puzzle","description":"Le modèle de jeu Draw Save Puzzle est un modèle de projet complet qui est un jeu de puzzle 2D.","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/2R2U6/thumbnail/small.png","url":"https://play.gamepix.com/draw-save-puzzle/embed?sid=1","plays":42225,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"TOC58","slug":"tic-tac-toe-mania","title":"Tic Tac Toe Mania","description":"Tic Tac Toe Mania est un excellent moyen de passer votre temps. Arrêtez de gaspiller du papier et sauvez les arbres. Jouez à Tic Tac Toe Mania sur votre appareil et profitez de nombreuses heures de divertissement seul ou avec vos amis.\n","category":"Stratégie","tags":["board"],"thumbnail":"https://games.assets.gamepix.com/TOC58/thumbnail/small.png","url":"https://play.gamepix.com/tic-tac-toe-mania/embed?sid=1","plays":42187,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40334","slug":"grand-prix-hero","title":"Grand Prix Hero","description":"Compete across multiple continents as you race in the Grand Prix Series. Dodge traffic, boost at high speeds, collect coins and upgrade your car for the next race. Are you the Grand Prix Hero?","category":"Sport","tags":["arcade","sports"],"thumbnail":"https://games.assets.gamepix.com/40334/thumbnail/small.png","url":"https://play.gamepix.com/grand-prix-hero/embed?sid=1","plays":42179,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40417","slug":"boss-level-pumpkin-madness","title":"Boss Level - Pumpkin Madness","description":"Enjoy this Halloween version of the Boss Level Shootout original game. Billy boy fell into a retro game console and is now fighting the boss!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/40417/thumbnail/small.png","url":"https://play.gamepix.com/boss-level-pumpkin-madness/embed?sid=1","plays":42145,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"562TT","slug":"battboy-adventure","title":"Battboy Adventure","description":"“Battboy Adventure” is a platform game, where the hero must overcome all the levels by dodging the thorns and eliminating the villains (killer clowns). Collect all the stars to complete the game 100%. The graphics are colorful, cartoonized and beautiful. Altogether, there are 08 levels that increase the difficulty as the player goes through each one.","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/562TT/thumbnail/small.png","url":"https://play.gamepix.com/battboy-adventure/embed?sid=1","plays":42131,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"I29FM","slug":"flamit","title":"Flamit","description":"Light all the torches as fast as you can in this engaging platform.\nBut do it fast, because a your flame won't last forever!\nFeaturing:\n- 30 one-screen levels full of funny obstacles\n- 2 Different game mode\n- spikes\n- ice enemies\n- more spikes\n- snow\n- A lot of torches\n\nControls\nTouch the screen controls or use arrow keys to move the Player\n\n- 30 one-screen levels full of funny obstacles\n- 2 Different game mode\n- spikes\n- ice enemies\n- more spikes\n- snow\n- A lot of torches","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/I29FM/thumbnail/small.png","url":"https://play.gamepix.com/flamit/embed?sid=1","plays":42110,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"3E79E","slug":"robo-butcher","title":"Robo-Butcher","description":"A human outpost was attacked by an army of robots out of control, but it's not over yet! The human resistance has an\nultimate weapon to counteract the advance of the crazy robots: the Robo-butcher, a robot made with the sole purpose of protecting humans from other robots.\n\nFeatures:\n\nLots and lots of enemies\nPower-ups\nPerma-uprgrades\nDouble-jump \nOld-style pre-rendered graphics\nRobots\nFantastic BGM by Nosebreed\n\n\n\n\n","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/3E79E/thumbnail/small.png","url":"https://play.gamepix.com/robo-butcher/embed?sid=1","plays":42090,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"S4N5N","slug":"piano-tiles-game","title":"Piano Tiles Game","description":"Get the best score on Piano Tiles!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/S4N5N/thumbnail/small.png","url":"https://play.gamepix.com/piano-tiles/embed?sid=1","plays":42086,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"6D87D","slug":"dd-blocky","title":"DD Blocky","description":"Blocky is a fun and addictive puzzle game that you can match the blocks with drag & drop on the puzzle board. Play this game and strengthen your mind. game shapes are like the tetris shapes.\n\nFEATURES:\nAge Rating: 8 and Up\nResponsibility: Portrait\nGame Mode: Single-Player\nControls: Mouse / Touch","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/6D87D/thumbnail/small.png","url":"https://play.gamepix.com/dd-blocky/embed?sid=1","plays":42029,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40124","slug":"baby-bear","title":"Baby Bear","description":"Maman ours et papa ours sont très excités à l'idée d'avoir un petit ourson à la maison. Mais comme c'est leur tout premier bébé, ils sont un peu stressés et ont besoin d'être aidés dans leur rôle de parents. Saurez-vous être leur guide?","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/40124/thumbnail/small.png","url":"https://play.gamepix.com/baby-bear/embed?sid=1","plays":42028,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"20054","slug":"fruit-blaster","title":"Fruit Blaster","description":"Soyez rapide et précis ! C'est tout ce que vous avez besoin de savoir pour exceller dans \"Fruit Blaster\"! Touchez ou cliquez pour couper les fruits, et enchainez les \"slice\" pour débloquer des combos et exploser les high scores! Devenez un véritable ninja!","category":"Arcade","tags":["arcade","classics"],"thumbnail":"https://games.assets.gamepix.com/20054/thumbnail/small.png","url":"https://play.gamepix.com/fruit-blaster/embed?sid=1","plays":42022,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"2NP74","slug":"super-chains","title":"Super Chains","description":"Super Chains a fun puzzle game.\nTo capture and use them, create long links of chain blocks by simply touching an adjoining block that is one number higher, lower, or of the same value.\nPowerful mythical creatures are hidden in this super numbers puzzle game! Get powerful Heroes to help you in your task!\nCan you be the EPIC champion??\n\n","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/2NP74/thumbnail/small.png","url":"https://play.gamepix.com/super-chains/embed?sid=1","plays":42009,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40095","slug":"pigeon-bomber","title":"Pigeon Bomber","description":"Jack le pigeon a peur des gens. La peur mène à la colère. La colère mène à la haine. Et la haine mène aus fientes! Jack survole la ville et son but est de déféquer sur tout et tout le monde!","category":"Aventure","tags":["arcade","adventure"],"thumbnail":"https://games.assets.gamepix.com/40095/thumbnail/small.png","url":"https://play.gamepix.com/pigeon-bomber/embed?sid=1","plays":42002,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"S5498","slug":"kobadoo-shapes","title":"Kobadoo Shapes","description":"Kobadoo Shapes is a browser game that trains your brain by memorizing coloured geometric shapes in the right order.\n\nWhen you play Kobadoo Shapes you are actively using your working memory. Several scientific studies suggest that training of working memory has beneficial effects and can increase your cognitive functions.\n\nFull version: https://www.kobadoo.com","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/S5498/thumbnail/small.png","url":"https://play.gamepix.com/kobadoo-shapes/embed?sid=1","plays":41996,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40274","slug":"badland","title":"Badland","description":"BADLAND est un jeu primé d'aventure-action à défilement horizontal qui se déroule dans une magnifique forêt luxuriante, remplie de drôles d'habitants, de fleurs et d'arbres. Bien que la forêt ait l'air de sortir tout droit d'un conte de fées, l'atmosphère semble vraiment très étrange... Vous contrôlez l'un des habitants de la forêt pour découvrir ce qui s'y passe. Tout au long de votre périple, vous découvrirez tout un tas de pièges et d'obstacles plus ingénieux les uns que les autres.","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/40274/thumbnail/small.png","url":"https://play.gamepix.com/badland/embed?sid=1","plays":41993,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"A6167","slug":"squid-race","title":"Squid Race","description":"Squid Raceis a squid game specially designed to be fully-featured sugar game. Survive race, Carve dalgona honeycomb cookie, cross glass bridge and tug of war\n","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/A6167/thumbnail/small.png","url":"https://play.gamepix.com/squid-race/embed?sid=1","plays":41987,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"R5R16","slug":"face-breaker","title":"Face Breaker","description":"Face Breaker is an enjoyable puzzle game where you are a paddle\nDestroy all the blocks using your happy paddle to hit your square-face-ball, like in a weird tennis match!\nHit and destroy all the blocks as soon as you can.\nAfter any bounce the ball gains speed, making it harder and harder to intercept it!\nIf the ball falls on the bottom you lose!\nBeat all the 45 engaging levels if you can!\nYou will face (not pan intended) a lot of difficult challenges! Prepare yourself!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/R5R16/thumbnail/small.png","url":"https://play.gamepix.com/face-breaker/embed?sid=1","plays":41944,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"3K1I6","slug":"ski-king-2022","title":"Ski King 2022","description":"La saison de ski commence, alors venez skier dans ce jeu aux commandes intuitives et simples. Dévalez la pente, récupérez des pièces, améliorez vos compétences et devenez le roi du ski. Pouvez-vous échapper à l'avalanche aussi ?\n","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/3K1I6/thumbnail/small.png","url":"https://play.gamepix.com/ski-king-2022/embed?sid=1","plays":41938,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"78608","slug":"tiny-tomb","title":"Tiny Tomb","description":"C'est le type de jeu qui va te transporter :\n\nQuatre mondes éthérés magnifiquement rendus flottent aux confins de l'univers. Pour sauver tes amis, tu devras tous les visiter... en veillant à souvent nourrir un monstre goinfre au tempérament difficile !\n\n(Au cours de ton périple, essaie également de comprendre ce qui contrarie tant Birdman...)\n\nTiny Tomb propose un univers rogue-like avec notamment :\n- une histoire loufoque avec des personnages sympathiques et décalés.\n- un voxel-art classique et touchant\n- des animations en stop-motion\n- Des tombes en perpétuelle évolution\n- Plus de 25 objets à collecter\n- 4 mondes tout droit sortis d'un rêve et n'attendant qu'une chose : que tu les explores\n\nL'amusement t'attend dans ce jeu dynamique et facile à prendre en main. Idéal pour de longues sessions de jeu ou des parties éclair !","category":"Aventure","tags":["puzzles","strategy"],"thumbnail":"https://games.assets.gamepix.com/78608/thumbnail/small.png","url":"https://play.gamepix.com/tiny-tomb/embed?sid=1","plays":41936,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"36515","slug":"chess-2d","title":"Chess 2D","description":"Play Chess in 2D mode against the computer.\n\nChess 2D assist with all possible Chess moves, with a green indication for a valid move, with a blue indicator for En Passant and Castling, a yellow indicator indicating a move that is not allowed because the Chess piece, King is in danger if the move were to be valid, and a red indication of the Chess piece, King when in danger.\n\nThe space or square once selecting a Chess piece will lit up accordingly, and give a clear indication like real life robotic colours, green means go, orange means warning and red means danger.","category":"Stratégie","tags":["board"],"thumbnail":"https://games.assets.gamepix.com/36515/thumbnail/small.png","url":"https://play.gamepix.com/chess-2d/embed?sid=1","plays":41935,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"48I3D","slug":"mixed-world-weekend","title":"Mixed World Weekend","description":"Welcome to Mixed World, the cheerful platform puzzle game! Use your funny friends’ special skills to nudge all monsters off the platforms!","category":"Puzzle","tags":["adventure","puzzles"],"thumbnail":"https://games.assets.gamepix.com/48I3D/thumbnail/small.png","url":"https://play.gamepix.com/mixed-world-weekend/embed?sid=1","plays":41929,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"0OMID","slug":"zombie-road","title":"Zombie Road","description":"Un monde post-apocalyptique dangereux plein de zombies où seuls les conducteurs les plus courageux et les plus expérimentés tentent de survivre en affrontant d'innombrables armées des morts-vivants. Un jeu de course palpitant. Le plaisir de conduire et d'exterminer des zombies.\n","category":"Aventure","tags":["adventure","arcade"],"thumbnail":"https://games.assets.gamepix.com/0OMID/thumbnail/small.png","url":"https://play.gamepix.com/zombie-road/embed?sid=1","plays":41924,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40444","slug":"princess-hair-spa-salon","title":"Princess Hair Spa Salon","description":"Princess Hair Salon, Makeovers & Hair Spa Salon for brides, teenage girls, stars and celebrities. Hundreds of hair style, makeup, clothes, and accessories to choose from! Let's play the Hair Salon . To be a barber and design various hairstyles for your customer. Share your Princess with friends and family! Unlock more ways to dress up your Prom Princess, there’s no limit!","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/40444/thumbnail/small.png","url":"https://play.gamepix.com/princess-hair-spa-salon/embed?sid=1","plays":41914,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"IINV6","slug":"evo-city-driving","title":"EVO City Driving","description":"EVO City Driving features realistic graphics and big variety of super cars to drive across the evo city, drive as fast as you can and try to explore every road in town.","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/IINV6/thumbnail/small.png","url":"https://play.gamepix.com/evo-city-driving/embed?sid=1","plays":41903,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"91E6S","slug":"knife-smash","title":"Knife Smash","description":"Vous aimez lancer des trucs ? Comme des couteaux sur des cibles mouvantes ? Alors voici le défi ultime pour vous ! Synchronisez vos coups, visez bien et devenez le maître du couteau ! Pouvez-vous terminer tous les niveaux ? Un gameplay très simple mais qui est difficile à maîtriser ! Pourrez-vous collectionner tous les couteaux ridicules ?\n","category":"Arcade","tags":["adventure","arcade"],"thumbnail":"https://games.assets.gamepix.com/91E6S/thumbnail/small.png","url":"https://play.gamepix.com/knife-smash/embed?sid=1","plays":41900,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"F006A","slug":"baby-hazel-fun-time","title":"Baby Hazel Fun Time","description":"Baby Hazel enjoyed a nightlong sleep with sweet dreams. She woke up happily this morning and ready to enjoy her day. Help her in getting fresh and then feed her with lukewarm water. Make her fun hours more playful by offering toys of her choice. Enjoy having fun with Hazel and keep her happy by fulfilling all her needs.","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/F006A/thumbnail/small.png","url":"https://play.gamepix.com/baby-hazel-fun-time/embed?sid=1","plays":41891,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"CEIG5","slug":"cake-shop-cafe-pastries-waffles-cooking-game","title":"Cake Shop Cafe Pastries & Waffles cooking Game","description":"$5","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/CEIG5/thumbnail/small.png","url":"https://play.gamepix.com/cake-shop-cafe-pastries-waffles-cooking-game/embed?sid=1","plays":41882,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40420","slug":"icy-purple-head-2","title":"Icy Purple Head 2","description":"Icy slides , Purple sticks. Touch anywhere to become icy, try to reach the postage box to finish the level and void dangerous spikes and electricity!","category":"Puzzle","tags":["arcade","puzzles"],"thumbnail":"https://games.assets.gamepix.com/40420/thumbnail/small.png","url":"https://play.gamepix.com/icy-purple-head/embed?sid=1","plays":41879,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"B8IW8","slug":"rope-bowing-puzzle","title":"Rope Bowing Puzzle","description":"Rope Bowing Puzzle is an interesting and addictive puzzle game. It looks easy enough, but you also have to concentration and dodge some obstacles that will make it difficult for you.\n","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/B8IW8/thumbnail/small.png","url":"https://play.gamepix.com/rope-bowing-puzzle/embed?sid=1","plays":41863,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"3NM56","slug":"green-and-blue-cuteman","title":"Green and Blue Cuteman","description":"In the green and blue cuteman game played for two, you are two players as green and blue and you must reach the flag by passing through obstacles and defeating the enemies. reach the flag pass the level!\n\nHow to Play?\nWASD + Arrow keys & Mobile Touch Control \nPause \"P\"","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/3NM56/thumbnail/small.png","url":"https://play.gamepix.com/green-and-blue-cuteman/embed?sid=1","plays":41857,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"GG5EC","slug":"penalty-challenge","title":"Penalty Challenge","description":"\"Penalty Challenge Multiplayer is a Sport Game.\n\nSelect between 32 different teams your favorite one.\n\nYou have 5 attempts to pass the goalie and other 5 to save your opponent’s kicks!\n\nIt’s all in your hands and feet!\n\nTwo Game Modes:\n\n - Play against the computer in tournament mode!\n\n - Challenge a friend playing online multiplayer!\"","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/GG5EC/thumbnail/small.png","url":"https://play.gamepix.com/penalty-challenge/embed?sid=1","plays":41848,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"AA444","slug":"baby-hazel-annual-day","title":"Baby Hazel Annual Day","description":"Wow! Annual Day is organized at Baby Hazel's preschool. Baby Hazel has decided to dress up in clown outfits. First of all assist Hazel and mom in purchasing the required costume and accessories. Then dress her in clown costumes and apply attractive makeup shades to her. Finally, on Annual Day help Hazel and friends to perform onstage without getting nervous. Enjoy celebrating Annual Day with Baby Hazel and friends!","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/AA444/thumbnail/small.png","url":"https://play.gamepix.com/baby-hazel-annual-day/embed?sid=1","plays":41828,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"T016E","slug":"tiger-run","title":"Tiger Run","description":"Very exciting and interesting tiger parkour game, as fun as subway parkour","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/T016E/thumbnail/small.png","url":"https://play.gamepix.com/tiger-run/embed?sid=1","plays":41816,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"76D97","slug":"squidgames-3d","title":"Squidgames 3D","description":"Here is the Squid Game!\nYou will be playing Red Light, Green Light.\n\nYou are allowed to move forward when ‘it’ shouts out, ‘Green Light’, stop when ‘it’ shouts, ‘Red Light’.\nIf your movement is detected afterwards, you will be eliminated.\nLet me repeat the rule.\nYou are allowed to move forward when ‘it’ shouts out, ‘Green Light’, stop when ‘it’ shouts, ‘Red Light’.\nThose players who cross the finish line without being eliminated within the playtime will pass this round.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/76D97/thumbnail/small.png","url":"https://play.gamepix.com/squidgame-3d/embed?sid=1","plays":41812,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"AM511","slug":"amaze-escape","title":"Amaze Escape","description":"Un jeu hyper-décontracté passionnant de logique et d'ingéniosité. Le joueur doit résoudre un puzzle simple et sortir de prison.","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/AM511/thumbnail/small.png","url":"https://play.gamepix.com/amaze-escape/embed?sid=1","plays":41810,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"P0721","slug":"canjump","title":"Canjump","description":"Canjump is a game in which you can only jump, but you have to do it at the right time.","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/P0721/thumbnail/small.png","url":"https://play.gamepix.com/canjump/embed?sid=1","plays":41785,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"2EM1B","slug":"noob-vs-zombie","title":"Noob vs Zombie","description":"Welcome to Noob vs Zombie. Go through labyrinths of biomes with different zombies and enemies. Pro betrayed Noobik and left him in labyrinths with various zombies. Go through mysterious labyrinths defeating zombies in deadly battles. You need to go through the labyrinths in each biome in order to find Pro and fight with him, while the cheater with his insidious technologies will interfere with you. Collect coins, buy weapons and upgrade. Super entertaining gameplay: beat zombies and skeletons, beat inhabitants of biomes, earn coins and level up. All characters give coins and values. Open chests with mysterious items and gold. Do you have the courage to go through all the biomes with zombies and bosses and fight with Pro and Cheater. Go through villages, caves, deserts and the North Pole, dodge traps, escape enemies and solve riddles.","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/2EM1B/thumbnail/small.png","url":"https://play.gamepix.com/noob-vs-zombie/embed?sid=1","plays":41781,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"ISO19","slug":"noob-huggy-kissiy","title":"Noob Huggy Kissiy","description":"You must help them survive in the jungle and get home. Huggy and Kissiy miss their home so much and there are many dangers on the way to go home. It's snowing and it's getting cold. They need to watch out for the enemies in the snowy forest. You have to watch out for the bees and slime or you may die. Complete 10 different maps and reach home.\n\nHow to Play?\n*Move to WASD + Arrow Keys                 \n*Double Jump available                 \n*Mobile Touch Control","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/ISO19/thumbnail/small.png","url":"https://play.gamepix.com/noob-huggy-kissiy/embed?sid=1","plays":41775,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40439","slug":"beach-bowling-3d","title":"Beach Bowling 3D","description":"Beach Bowling 3D is a game where you can test your bowling skills on summer beach in gorgeous 3D. Defeat opponents in hundreds of levels. Or just play with your friends on one device. Just throw the ball and get a score. Very easy to start, but hard to master.","category":"Sport","tags":["arcade","classics","sports"],"thumbnail":"https://games.assets.gamepix.com/40439/thumbnail/small.png","url":"https://play.gamepix.com/beach-bowling-3d/embed?sid=1","plays":41765,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"RMSR4","slug":"puppets-cemetery","title":"Puppets Cemetery","description":"Shoot as many puppets as you can in this top down shooter full of pumpkins!\n\nWASD or ARROW KEYS to move the player\nMOUSE to aim and shoot\nRMB / E / SPACEBAR to pick up weapons","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/RMSR4/thumbnail/small.png","url":"https://play.gamepix.com/puppets-cemetery/embed?sid=1","plays":41753,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"75C06","slug":"checkers-legend","title":"Checkers Legend","description":"Le jeu de plateau classique et très simple que tout le monde connaît depuis son enfance. Il existe de nombreuses variantes, alors les règles sont fournies dans le jeu. Vous pouvez jouer simplement contre l'IA ou utiliser cette application pour jouer contre un ami sur le même appareil.\n","category":"Puzzle","tags":["board","classics","puzzles"],"thumbnail":"https://games.assets.gamepix.com/75C06/thumbnail/small.png","url":"https://play.gamepix.com/checkers-legend/embed?sid=1","plays":41741,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"ARR64","slug":"funny-hair-salon","title":"Funny Hair Salon","description":"George's hair is in a no bueno situation. His scalp is full of mites and pimps. The only way to fix his hair is going to the salon. Let's cure his scalp and plant new hair to his head, so he can show his true outter beauty!","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/ARR64/thumbnail/small.png","url":"https://play.gamepix.com/funny-hair-salon/embed?sid=1","plays":41734,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"OFO69","slug":"knife-io","title":"Knife io","description":"Knife.io is a multiplayer game. In the game, you can win by killing everyone. In the game, find a way to avoid the enemy’s attack. While killing the enemy, you will get different random skills to strengthen your attack power. Note that the game map will shrink automatically over time, hurry up and enter the experience, I wish you a happy game!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/OFO69/thumbnail/small.png","url":"https://play.gamepix.com/knife-io/embed?sid=1","plays":41729,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40411","slug":"hockey-hero","title":"Hockey Hero","description":"Choose your hero and compete against 3 fierce opponents in the Ice Hockey event. Avoid the attacking players to approach the goal line. Once in front of the goal time your shot to score! Will you win a Gold Medal by scoring in all 3 periods? Be a Hockey Hero!","category":"Sport","tags":["arcade","sports"],"thumbnail":"https://games.assets.gamepix.com/40411/thumbnail/small.png","url":"https://play.gamepix.com/hockey-hero/embed?sid=1","plays":41724,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"03772","slug":"just-golf","title":"Just Golf","description":"Just Golf combines minimalism with puzzle in 210 levels with gradual difficulty. You must drop the ball into the hole with the red flag. The plays are unlimited and you'll have guided aim to facilitate your shots. You can also use your skill to try to collect the 3 stars in each level!","category":"Sport","tags":["arcade","sports"],"thumbnail":"https://games.assets.gamepix.com/03772/thumbnail/small.png","url":"https://play.gamepix.com/just-golf/embed?sid=1","plays":41711,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"AL37X","slug":"galaxy-warriors","title":"Galaxy Warriors","description":"\"Combattez avec votre vaisseau ! Parcourez la galaxie et tirez sur des flottes extraterrestres ennemies. Récupérez des crédits pour améliorer votre vaisseau spatial.\n\nMéfiez-vous des ennemis qui ripostent et des boss puissants ! Vous pouvez éliminer les hordes d'ennemis grâce à différents bonus au choix. Esquivez l'enfer des balles et tirez !\"\n","category":"Aventure","tags":["adventure","arcade"],"thumbnail":"https://games.assets.gamepix.com/AL37X/thumbnail/small.png","url":"https://play.gamepix.com/galaxy-warriors/embed?sid=1","plays":41708,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"THREM","slug":"stickman-archero-fight","title":"Stickman Archero Fight","description":"Jouez à Stickman Archero Fight. Artisanat, mise à niveau, batailles avec stickman ennemi. Faites tout pour la victoire. Faire la meilleure fatalité. Devenez un pro !\n\nAméliorez votre stickman, combattez les ennemis dans le jeu Stickman Archero. Créez des fatalités cool et dynamiques. Beaucoup de magie et de batailles ! Le jeu est similaire à SupremeDuelistStickman. Combats dans le village avec d'autres stickman.\n\nAppuyez sur les touches W/A/S/D pour vous déplacer. Appuyez sur \"E\" pour interagir avec les éléments. Appuyez sur le bouton gauche de la souris pour frapper.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/THREM/thumbnail/small.png","url":"https://play.gamepix.com/stickman-archero-fight/embed?sid=1","plays":41702,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"215ES","slug":"tennis-open-2020","title":"Tennis Open 2020","description":"L'excitation du monde du tennis est prête ! Prenez une raquette et participez à tous les événements de tennis importants du monde ! Pouvez-vous gagner ? Pouvez-vous surmonter tous les obstacles ? Entraînez-vous dur, jouez bien et devenez une légende imbattable. Atteignez le sommet et écrivez l'Histoire. Montrez ce que vous valez et triomphez !\n","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/215ES/thumbnail/small.png","url":"https://play.gamepix.com/tennis-open-2020/embed?sid=1","plays":41694,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"7LTEK","slug":"ultimate-strike","title":"Ultimate Strike","description":"Ultimate Strike features big arsenal of weapons which consists of twenty seven different guns and intense multiplayer battles across nine highly detailed maps, you spawn with random weapons loadout and your mission is to shoot all rival players in order to win.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/7LTEK/thumbnail/small.png","url":"https://play.gamepix.com/ultimate-strike/embed?sid=1","plays":41689,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"71HB1","slug":"football-heads","title":"Football Heads","description":"Entrez sur le terrain, décimez votre adversaire avec diverses frappes puissantes et des bonus amusants et décalés. Enfin, montre-lui qui est le boss avec le système d'émoticones - devenez une légende du football aujourd'hui !\n","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/71HB1/thumbnail/small.png","url":"https://play.gamepix.com/football-heads/embed?sid=1","plays":41688,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"RYI7D","slug":"real-city-driving-2","title":"Real City Driving 2","description":"Select different super cars and drive them as fast as you can across the city.","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/RYI7D/thumbnail/small.png","url":"https://play.gamepix.com/real-city-driving-2/embed?sid=1","plays":41673,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"Y50DT","slug":"my-sweet-candy-outfits","title":"My Sweet Candy Outfits","description":"Welcome to the My Sweet Candy Outfits. Rainbow high girls Skyler, Sunny, Ruby, and Violet are planning a weekend party. But a party without a theme is not fun! So they planned to be in Sweet candy themes. Help the girls to browse the wardrobe and pick the cute candy outfit for them. Play and have fun!","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/Y50DT/thumbnail/small.png","url":"https://play.gamepix.com/my-sweet-candy-outfits/embed?sid=1","plays":41671,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"SD226","slug":"red-and-blue-stickman-rope","title":"Red and Blue Stickman Rope","description":"Are you ready for the adventure of two very cute brothers, namely blue and red stickman? Brothers red and blue need to get the key and reach the door. Be two people and get them to the door with your friend. reach the door and pass it to the new level. You will face multiple challenges but reach the door.   \n\nHow to Play?\n*Move to WASD + Arrow Keys                    \n*Double Jump available                    \n*Mobile Touch Control","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/SD226/thumbnail/small.png","url":"https://play.gamepix.com/red-and-blue-stickman-rope/embed?sid=1","plays":41665,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"OM649","slug":"moto-maniac-2","title":"Moto Maniac 2","description":"Overcome all the obstacles as fast as you can. This game is a sequel to Moto Maniac set in a different environment. This time it's a bridge in the night. It's under construction so you have to be careful not to fall into the abyss and not to hit your head. On top of the obstacles on the way, it's dark! Fortunately you have a drone that will light your way. ","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/OM649/thumbnail/small.png","url":"https://play.gamepix.com/moto-maniac-2/embed?sid=1","plays":41631,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"RLL94","slug":"roll-this-ball","title":"Roll this Ball","description":"Vous aimez les jeux de pousse-pousse classiques ? Alors ce jeu est fait pour vous ! Déplacez les tuiles en bois pour vous frayer un chemin et permettre à la boule en acier d'atteindre le but rouge et brillant. Avec ce casse-tête populaire, vous passerez d'agréables moments et vous ferez travailler vos méninges !\n","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/RLL94/thumbnail/small.png","url":"https://play.gamepix.com/roll-this-ball/embed?sid=1","plays":41630,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"S121Y","slug":"funny-bone-surgery","title":"Funny Bone Surgery","description":"Leah went to play stakeboard on the street. But she was distracted and hit a car! She got a nasty broken arm and foot. Help fix her injuries and broken bones!\n","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/S121Y/thumbnail/small.png","url":"https://play.gamepix.com/funny-bone-surgery/embed?sid=1","plays":41618,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"510IG","slug":"boxing-stars","title":"Boxing Stars","description":"Passez de la boxe clandestine aux championnats et devenez une star de la boxe. Améliorez vos compétences avec des récompenses pour participer à de meilleurs tournois.\n","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/510IG/thumbnail/small.png","url":"https://play.gamepix.com/boxing-stars/embed?sid=1","plays":41611,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"RR6SE","slug":"space-tower-defense","title":"Space Tower Defense","description":"Tower Defense est un jeu de stratégie où le but du joueur est de protéger ses territoires et la tour principale des attaques ennemies. Pour ce faire, le joueur construit des structures défensives le long de la trajectoire d'attaque, dont la force dépend du coût de l'énergie que le joueur reçoit pour vaincre l'équipement ennemi.","category":"Stratégie","tags":["strategy"],"thumbnail":"https://games.assets.gamepix.com/RR6SE/thumbnail/small.png","url":"https://play.gamepix.com/space-tower-defense/embed?sid=1","plays":41594,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"P93LE","slug":"block-puzzle-jewel","title":"Block Puzzle Jewel","description":"Le but est de déposer des blocs afin de créer et de détruire des lignes complètes sur l'écran à la fois verticalement et horizontalement. N'oubliez pas d'empêcher les blocs de remplir l'écran dans ce jeu de puzzle addictif.","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/P93LE/thumbnail/small.png","url":"https://play.gamepix.com/block-puzzle-jewel/embed?sid=1","plays":41586,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"3RR15","slug":"roar-of-city","title":"Roar of City","description":"Roar of City is a 2D isometric Beat 'em up game with high quality graphic and suitable gameplay for mobile and desktop. Fight with criminals gang and arrest their commander to rescue the city. But now the city is angry and the horrible roar of the city can be heard.","category":"Arcade","tags":["arcade","sports"],"thumbnail":"https://games.assets.gamepix.com/3RR15/thumbnail/small.png","url":"https://play.gamepix.com/roar-of-city/embed?sid=1","plays":41579,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40412","slug":"slalom-hero","title":"Slalom Hero","description":"Choose your hero and compete across 3 courses in the Slalom event. Steer between the slalom gates and collect boosts to improve your times. Will you win a Gold Medal? Be a Slalom Hero!","category":"Sport","tags":["arcade","sports"],"thumbnail":"https://games.assets.gamepix.com/40412/thumbnail/small.png","url":"https://play.gamepix.com/slalom-hero/embed?sid=1","plays":41572,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"I45E2","slug":"line-of-defense","title":"Line of Defense","description":"Line of Defense is a fun battle of defense against attacking enemy tanks. Using you defensive rockets painted with colors, match it with the color of attacking tanks and shoot in order to destroy it. If the color mismatches, you will lose. If tanks reaches the front line you will lose. Use your defense rockets effectively and watch out for enemy tanks coming from different sides.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/I45E2/thumbnail/small.png","url":"https://play.gamepix.com/line-of-defense/embed?sid=1","plays":41566,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"LNAOI","slug":"2d-platformer-coin","title":"2D Platformer Coin","description":"Help the dude collect coins, to win and pass the round !\n\nThe game is that you need to collect coins and win the round, Coins are collected by a character, you must pass a series of tests to reach the coins and pick it up, To pass and win you need to collect 8 coins, but you do not think that this is easy. Try and test your skills and mind!\n\nHow to play:\nControls: Button-W-jump up,\nButton-S-walk down,\nButton-D-walk right,\nButton-A-walk left,\nAnd if you jump to hold the SPACE button, the character will slowly descend to the ground as if gravity has turned off.","category":"Arcade","tags":["classics"],"thumbnail":"https://games.assets.gamepix.com/LNAOI/thumbnail/small.png","url":"https://play.gamepix.com/2d-platformer-coin/embed?sid=1","plays":41552,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"64L1R","slug":"water-sort-puzzle","title":"Water Sort Puzzle","description":"À propos de ce jeu\nWater Sort Puzzle est un jeu de puzzle amusant et addictif! Essayez de trier l’eau colorée dans les verres jusqu’à ce que toutes les couleurs dans le même verre. Un jeu stimulant mais relaxant pour exercer votre cerveau!\n\n★ COMMENT JOUER :\n• Tapoter n’importe quel verre pour verser de l’eau dans un autre verre.\n• La règle est que vous ne pouvez verser l’eau que si elle est liée à la même couleur et qu’il y a suffisamment d’espace sur le verre.","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/64L1R/thumbnail/small.png","url":"https://play.gamepix.com/water-sort-puzzle/embed?sid=1","plays":41545,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"TDO3T","slug":"d-copter-reloaded","title":"D. Copter Reloaded","description":"Reloaded D.Copter is a brand new shooting 3D game. You need to take a helicopter and perform shooting missions!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/TDO3T/thumbnail/small.png","url":"https://play.gamepix.com/d-copter-reloaded/embed?sid=1","plays":41524,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"4A866","slug":"baby-hazel-birthday-party","title":"Baby Hazel Birthday Party","description":"Hurray! Baby Hazel is celebrating her 3rd birthday. Let us join Hazel to enjoy dancing, feasting and magic shows at her birthday party. On this special occasion, keep Baby Hazel happy by fulfilling all her needs. Someone who is very dear to Hazel has planned a surprise for her to make her birthday more fun-filled. Let us see what the surprise is and who has planned it.","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/4A866/thumbnail/small.png","url":"https://play.gamepix.com/baby-hazel-birthday-party/embed?sid=1","plays":41518,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"5R4XE","slug":"2048-x2-merge-blocks","title":"2048 X2 Merge Blocks","description":"Une combinaison du jeu classique 2048 et de Tetris. Les nombres descendent et continuent d'affluer. Gérez la fusion des nombres et gardez la zone de jeu dégagée aussi longtemps que possible. Quelle est la meilleure fusion que vous puissiez faire ?\n","category":"Puzzle","tags":["arcade","puzzles"],"thumbnail":"https://games.assets.gamepix.com/5R4XE/thumbnail/small.png","url":"https://play.gamepix.com/2048-x2-merge-blocks/embed?sid=1","plays":41510,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40123","slug":"kuli","title":"KULI","description":"Vous revenez d'une ballade en montagne quand vous apprenez qu'une épidémie zombie vient d'avoir lieu. Que faites-vous ? Ce que vous savez faire le mieux pardi! Construire des défenses, les faire évoluer et vous battre! Tenez les zombies à distance et massacrez-en le plus possible grâce à vos tourelles et vos armes défensives, préparez votre stratégie le jour et combattez la nuit. Survivrez-vous à KULI?","category":"Aventure","tags":["adventure","strategy"],"thumbnail":"https://games.assets.gamepix.com/40123/thumbnail/small.png","url":"https://play.gamepix.com/kuli/embed?sid=1","plays":41508,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40416","slug":"boss-level-shootout","title":"Boss Level Shootout","description":"Gamer boy Billy loved to play video games but one day his retro console ate him. Now Billy is inside the retro style game and must beat the bosses in this ultimate shootout. Test your skills in shooting, running, picking power-ups and be a winner!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/40416/thumbnail/small.png","url":"https://play.gamepix.com/boss-level-shootout/embed?sid=1","plays":41507,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"II007","slug":"warzone-strike","title":"Warzone Strike","description":"Warzone Strike features next gen graphics and big arsenal of weapons which consists of 38 different guns to shoot rival players on various highly detailed maps.","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/II007/thumbnail/small.png","url":"https://play.gamepix.com/warzone-strike/embed?sid=1","plays":41502,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"7796R","slug":"tower-defense","title":"Tower Defense","description":"Une horde d'horribles monstres attaque votre royaume, bâtissez vos tours rapidement et survivez à toutes les vagues. Si les flèches et les pierres ne suffisent pas, utilisez les éléments à votre avantage et tuez-les tous.\n","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/7796R/thumbnail/small.png","url":"https://play.gamepix.com/tower-defense/embed?sid=1","plays":41499,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"9R3ET","slug":"steve-adventurecraft-nether","title":"Steve AdventureCraft Nether","description":"The nether section of the adventurecraft game, which is full of adventures, has 10 different levels and flying, crying creatures, zombies and many monsters are waiting for you. collect animals they are your friend. hunt monsters they are your enemy. complete the levels and achieve victory!     \n\nHow to Play?\n*WASD + F / Mobile Touch Control","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/9R3ET/thumbnail/small.png","url":"https://play.gamepix.com/steve-adventurecraft-nether/embed?sid=1","plays":41497,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"2PI32","slug":"lipuzz-water-sort-puzzle","title":"Lipuzz - Water Sort Puzzle","description":"You will think a lot and have a lot of fun while playing the Lipuzz game. A great game to exercise memory. The aim of the game is to collect liquids of the same color in a container by transferring the liquids in the containers to each other. The most important rule in the game is that the container you want to pour the liquid into must either be empty or the other container must have the same color liquid. If you can't pass the level in the game, you can get another container from the top menu.","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/2PI32/thumbnail/small.png","url":"https://play.gamepix.com/lipuzz-water-sort-puzzle/embed?sid=1","plays":41493,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"2R310","slug":"roller-coaster-simulator","title":"Roller Coaster Simulator","description":"Roller Coaster Simulator is a realistic 3D simulator game where you have to drive on winding tracks. With stunning 3D graphics, intuitive controls, and addictive mechanics this simulation 3D game is sure to keep to you addicted for hours. Take care of your passengers and make sure your reach the destination safely. Don’t lose your balance as you will be going to shake on the twisty turns and loops. On the way you will cross the murky seas and the gigantic mountains. Just keep equilibrium as it will much needed. ","category":"Stratégie","tags":["strategy"],"thumbnail":"https://games.assets.gamepix.com/2R310/thumbnail/small.png","url":"https://play.gamepix.com/roller-coaster-simulator/embed?sid=1","plays":41489,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"E7D81","slug":"super-drive","title":"Super Drive","description":"Super Drive features cool graphics and lots of super cars to drive across the big city crowded with pedestrians, drive as fast as you can and try to perform different stunts on your way.","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/E7D81/thumbnail/small.png","url":"https://play.gamepix.com/super-drive/embed?sid=1","plays":41486,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40414","slug":"soccer-hero","title":"Soccer Hero","description":"Choose your hero and compete against 3 fierce opponents in the World Soccer event. Will you win a Gold Medal by scoring all 3 chances? Be a Soccer Hero!","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/40414/thumbnail/small.png","url":"https://play.gamepix.com/soccer-hero/embed?sid=1","plays":41480,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"71BTT","slug":"battlebox","title":"BattleBox","description":"Battle Box is ad Idle game where the more you risk, the more you get! Try to collect all the jewels in each level and to memorize their location!\nBe careful tough! Under some blocks there is a devil that will hurt you! If you find three of them the game will be over! By the way, you can restore your health if you find a strawberry, so keep an eye on it.","category":"Stratégie","tags":["board"],"thumbnail":"https://games.assets.gamepix.com/71BTT/thumbnail/small.png","url":"https://play.gamepix.com/battlebox/embed?sid=1","plays":41480,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40421","slug":"penalty-superstar","title":"Penalty Superstar","description":"You are the goalkeeper starting his career from scratch: use power-ups to get better and try to catch the ball. Win all cups and become the champion of all leagues!","category":"Puzzle","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/40421/thumbnail/small.png","url":"https://play.gamepix.com/penalty-superstar/embed?sid=1","plays":41477,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40435","slug":"pudding-monsters","title":"Pudding Monsters","description":"Les monstres sont en mission pour sauver leurs amis d'un propriétaire de frigo sans coœur! Devenir un SUPER MONSTRE ULTIME semble être le meilleur plan…Depuis la table jusqu'aux abords de la maison, pour finir au cœur de la ville – agglutinez ensemble les monstres et sauvez leurs amis!","category":"Puzzle","tags":["puzzles","strategy"],"thumbnail":"https://games.assets.gamepix.com/40435/thumbnail/small.png","url":"https://play.gamepix.com/pudding-monsters/embed?sid=1","plays":41476,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"9PF8M","slug":"fidget-spinner-mania","title":"Fidget Spinner Mania","description":"Un fidget spinner, c'est quoi ? C'est un jouet sympa qui tourne dans votre main. C'est un jeu très simple, mais le divertissement qu'il procure est sans limite. Le fidget spinner vous aide à vous détendre et à évacuer le stress en quelques tours seulement. Arrêtez de vous ronger les ongles ou de faire tourner votre stylo. C'est un jouet qui permet aux adultes et aux enfants de faire passer le temps. Récupérez tous les différents fidget spinners. \n","category":"Arcade","tags":["arcade","junior"],"thumbnail":"https://games.assets.gamepix.com/9PF8M/thumbnail/small.png","url":"https://play.gamepix.com/fidget-spinner-mania/embed?sid=1","plays":41473,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"P1538","slug":"panda-fight","title":"Panda Fight","description":"Panda Fight is an action game with a drag and drop mechanic. Your main objective is to beat all the levels to save Panda Princess. Collect all the stars scattered throughout the levels to finish the game with 100% success. Save the princess from terrible enemy pandas. A game with colorful and beautiful pixel art graphics! Good fun!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/P1538/thumbnail/small.png","url":"https://play.gamepix.com/panda-fight/embed?sid=1","plays":41470,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"IN3K6","slug":"tiny-chick","title":"Tiny Chick","description":"Tiny Chick is inspired by the conception of“easy-to-play, hard-to-master”, it is not only a simple casual game you can play all the time, but also very challengable. Just tap, hold, and then release, the chick will jump over the pillars!\nAlthough it is easy to play, it will be hard to get high score. Players have to figure out when and where to go so as to make the chick jump over the pillars! The more pillars you can jump over, the more scores you can claim! With the scores, you can unlock more characters!\nHow long can you persist? How best can you score? Let's wait and see!","category":"Arcade","tags":["arcade","junior"],"thumbnail":"https://games.assets.gamepix.com/IN3K6/thumbnail/small.png","url":"https://play.gamepix.com/tiny-chick/embed?sid=1","plays":41467,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"7UM2S","slug":"stickman-huggy-2","title":"Stickman Huggy 2","description":"Help the cute blue monster huggy cross paths full of obstacles! stickman huggy must cross the obstacles and reach the finish line. Help him and get him to the finish.  \n\nhow to play?\nWASD + Mobile Touch Control","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/7UM2S/thumbnail/small.png","url":"https://play.gamepix.com/stickman-huggy-2/embed?sid=1","plays":41464,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"00AAA","slug":"baby-hazel-at-beach","title":"Baby Hazel At Beach","description":"Hurray! This vacation Baby Hazel is glad to be gifted with a beach treat from her mom and dad. Hazel is excited to play under sunny sky with golden sand, swim in blue water of sea, relax and sip exotic drinks and indulge in other beach activities. Play the game to have lots of fun with Baby Hazel at the beach. Help her in packing important accessories and gears and take care of all her needs.","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/00AAA/thumbnail/small.png","url":"https://play.gamepix.com/baby-hazel-at-beach/embed?sid=1","plays":41464,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"233ZE","slug":"idle-zoo","title":"Idle Zoo","description":"Devenez un riche investisseur et restaurez des zoos à travers le pays. Réparez les habitats naturels d'origine et construisez-en de nouveaux. Découvrez de nouveaux animaux et regardez votre zoo prospérer.\n","category":"Stratégie","tags":["strategy"],"thumbnail":"https://games.assets.gamepix.com/233ZE/thumbnail/small.png","url":"https://play.gamepix.com/idle-zoo/embed?sid=1","plays":41463,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"20052","slug":"speed-pool-king","title":"Speed Pool King","description":"Enfin un jeu de billard frénétique pour mobiles et tablettes! Mettez les boules dans les trous aussi vite que possible, et défiez la montre pour devenir le meilleur!","category":"Stratégie","tags":["board","classics"],"thumbnail":"https://games.assets.gamepix.com/20052/thumbnail/small.png","url":"https://play.gamepix.com/speed-pool-king/embed?sid=1","plays":41454,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"171PE","slug":"jigsaw-puzzle","title":"Jigsaw Puzzle","description":"Rencontrez des animaux mignons, visitez des endroits inconnus ou découvrez de nouvelles choses. Expérimentez tout cela en jouant confortablement sur votre téléphone. Choisissez la difficulté qui convient à votre rythme et terminez chaque puzzle.\n","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/171PE/thumbnail/small.png","url":"https://play.gamepix.com/jigsaw-puzzle/embed?sid=1","plays":41453,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"2G124","slug":"going-up","title":"Going up","description":"Help a lonely bird to reach its nest. Avoid obstacles and collect coins to unlock new skins.\n\nTouch the screen or Left Click to fly upwards","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/2G124/thumbnail/small.png","url":"https://play.gamepix.com/going-up/embed?sid=1","plays":41446,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"35013","slug":"car-defender","title":"Car Defender","description":"Play, Merge cars, and collect coins to Win Free Coins.\nEnjoy the car Defender game where you have to Merge & unlock new cool cars.\n\nHow to play:\n-Merge two cars of the same level to get higher level cars and defeat your enemies.\n\nFeatures:\nDestroy all of the bosses.\nDifferent car models to be merged!\nSimple 1-tap gameplay","category":"Stratégie","tags":["strategy"],"thumbnail":"https://games.assets.gamepix.com/35013/thumbnail/small.png","url":"https://play.gamepix.com/car-defender/embed?sid=1","plays":41445,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40448","slug":"go-chicken-go","title":"Go Chicken Go","description":"The chickens escaped from their hideous farm and the last obstacle between them and an everlasting life of freedom is a mere highway. Test your cold blood and truck dodging skills. 25 chickens put their lives in your trustworthy hands. Go Chicken Go!","category":"Arcade","tags":["classics"],"thumbnail":"https://games.assets.gamepix.com/40448/thumbnail/small.png","url":"https://play.gamepix.com/go-chicken-go/embed?sid=1","plays":41433,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"O2T25","slug":"the-eggsecutioner","title":"The Eggsecutioner","description":"If you don't like eggs, this is the game for you!\n\nUse the mouse or touch the screen to stop the marker in the middle of the bar","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/O2T25/thumbnail/small.png","url":"https://play.gamepix.com/the-eggsecutioner/embed?sid=1","plays":41432,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40324","slug":"zombie-massacre","title":"Zombie Massacre","description":"Zombies are invading the wild west! Grab your guns and protect innocent people from those pesky lifeless folk. Upgrade your guns, equip yourself or hire some help. Don't get killed! Outnumbered, but never outgunned!","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/40324/thumbnail/small.png","url":"https://play.gamepix.com/zombie-massacre/embed?sid=1","plays":41432,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"4482P","slug":"call-of-ops-2","title":"Call of Ops 2","description":"Call of Ops 2 features next-gen graphics and big arsenal of weapons to shoot rival players on different maps.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/4482P/thumbnail/small.png","url":"https://play.gamepix.com/call-of-ops-2/embed?sid=1","plays":41422,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"0914B","slug":"biozombie-outbreak","title":"Biozombie Outbreak","description":"Biozombie Outbreak features intense zombie shooting on the city streets crowded with blood thirsty zombies, use different types of weapons to shoot all incoming zombies and try to survive before the time runs out.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/0914B/thumbnail/small.png","url":"https://play.gamepix.com/biozombie-outbreak/embed?sid=1","plays":41421,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"7111H","slug":"baby-hazel-bathroom-hygiene","title":"Baby Hazel Bathroom Hygiene","description":"Its high time for Baby Hazel to learn the importance of bathroom hygiene. If proper hygiene standards are not maintained, Hazel may easily come in contact of germs. Today, Hazel will be learning techniques of bathroom hygiene. Guide her on clearing all the mess, removing clogs in wash basin and cleaning stained bathroom accessories. Keep Hazel healthy by maintaining good personal hygiene so that she is shielded from germ infection.","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/7111H/thumbnail/small.png","url":"https://play.gamepix.com/baby-hazel-bathroom-hygiene/embed?sid=1","plays":41418,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"A4LRB","slug":"baby-hazel-ballerina-dance","title":"Baby Hazel Ballerina Dance","description":"Cheerful morning of Baby Hazel starts with surprise gifts. While having shower, she is given interesting tasks to complete and on winning receives ballerina toys from mom. Another reason for Hazel to be very excited is that she is going to learn ballerina dance. But our little doll is feeling bit nervous and uneasy in her dance class. Can your encourage Hazel and make her comfortable so that she follows the instructions of teacher carefully.","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/A4LRB/thumbnail/small.png","url":"https://play.gamepix.com/baby-hazel-ballerina-dance/embed?sid=1","plays":41418,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"N976N","slug":"sliding-slide","title":"Sliding Slide","description":"Enjoy and relax with a classi puzzle game. Six different images with 3 difficulty levels to satisfy the tastes of every players!\nBeat your highscores trying to solve the puzzle as fast as you can!\n\nTouch / Click the screen to move the blocks","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/N976N/thumbnail/small.png","url":"https://play.gamepix.com/sliding-slide/embed?sid=1","plays":41365,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"YH597","slug":"the-lost-joystick","title":"The Lost Joystick","description":"They stole your joystick… but they don’t know who you are!\nYou will do everything to get it back\nIn this psychedelic pixel-artish platformer, you have to jump around the levels looking for coins and keys, killing monsters and avoiding traps . Simple as that.","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/YH597/thumbnail/small.png","url":"https://play.gamepix.com/the-lost-joystick/embed?sid=1","plays":41364,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"8R08I","slug":"robot-bar-find-the-differences","title":"Robot Bar - Find the differences","description":" Spot the differences game in a sci-fi environment full of happy robots enjoying their free time in a club.\n\nTry to find all the differences in each picture before the time runs out. Be careful though: Do not touch the screen randomly trying to catch all the differences this way!\nIf you touch the screen 5 times without touching one of the differences is game over!\n\n","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/8R08I/thumbnail/small.png","url":"https://play.gamepix.com/robot-bar-find-the-differences/embed?sid=1","plays":41359,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"R821H","slug":"ghost-walker","title":"Ghost Walker","description":"Ghost Walker is a game about a ninja who went on a hunt for reputable bandit leaders. This game will amaze you with cool ninja controls in Slow Motion and dynamism.\n\nYour main task is to destroy the bosses. And whether you will kill their entire team while you go to them or do without bloodshed is your choice.\n\nThis is a game in which you will fully feel like an unsurpassed, elusive, super dexterous and strong master of melee weapons.\n\nKey features of the game:\n- Dynamic battles in Slow Motion\n- Lots of weapons\n- Cool assassin skins to choose from\n- Lots of bosses and enemies\n\nTry to experience this incredible feeling of elusiveness yourself, defeat all the bandits without a single scratch and become a legend.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/R821H/thumbnail/small.png","url":"https://play.gamepix.com/ghost-walker/embed?sid=1","plays":41358,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40130","slug":"your-queen-destiny","title":"Your Queen Destiny","description":"Quel genre de reine auriez-vous aimé être ? Toutes les reines ne sont pas forcément pleines de beauté, de grâce et de sagesse. Faites le quiz et découvrez quelle reine vous auriez pu être. Peut-être serez-vous une reine gentille, peut être aussi une reine maléfique ? Essayez-vite pour le savoir!","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/40130/thumbnail/small.png","url":"https://play.gamepix.com/your-queen-destiny/embed?sid=1","plays":41358,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40253","slug":"king-of-thieves","title":"King of Thieves","description":"Mettez vos talents de voleur à l'épreuve dans ce mélange unique de jeu de plateformes et de jeu multijoueur JcJ. Profitez de cette expérience époustouflante avec King of Thieves, l'un des meilleurs jeux de 2015. Rivalisez avec plus de 24 millions de joueurs dans le monde et créez votre propre clan de voleurs. Introduisez-vous dans le donjon de vos ennemis et volez leurs trésors. Prouvez que vous êtes plus intelligent et plus adroit. REMARQUE : le jeu est très addictif et vous fera inévitablement rencontrer de nouveaux amis.","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/40253/thumbnail/small.png","url":"https://play.gamepix.com/king-of-thieves/embed?sid=1","plays":41357,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"R6NMN","slug":"gold-mine","title":"Gold Mine","description":"Make riches by collecting gold and diamonds in mines. The bigger the nugget, the more money you earn, stay away from the gallons so you don’t lose money and the stones that end up taking your time. You can find dynamite, use it wisely so you don’t waste time or money. There are 10 levels for fun.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/R6NMN/thumbnail/small.png","url":"https://play.gamepix.com/gold-miner/embed?sid=1","plays":41342,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"90Y88","slug":"final-freeway","title":"Final Freeway","description":"Experience arcade racing over many diverse levels of fast-paced driving fun.\nBeat the clock and speed through each goal to proceed to the next stage.\nBoasting a diverse range of exciting levels, this popular title has reached #1 on racing game charts for major mobile platforms.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/90Y88/thumbnail/small.png","url":"https://play.gamepix.com/final-freeway/embed?sid=1","plays":41339,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40440","slug":"street-freekick-3d","title":"Street Freekick 3D","description":"Street Freekick 3D takes freekick game in modern city streets. Curve the ball and defeat opponents in hundreds of levels in gorgeous 3D. Play on any of your devices. Just kick the ball in gates and get a score. Very easy to start, but hard to master.","category":"Sport","tags":["arcade","sports"],"thumbnail":"https://games.assets.gamepix.com/40440/thumbnail/small.png","url":"https://play.gamepix.com/street-freekick-3d/embed?sid=1","plays":41336,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40188","slug":"key-shield-2","title":"Key & Shield 2","description":"L'île de Gorlik n'est toujours pas sûre! Un sort a été lancé et a recouvert l'île de rochers alors que vos amis s'y trouvent toujours prisonniers. Attrapez votre bouclier et votre clé et parcourez l'île pour libérer vos amis et en finir une bonne fois pour toute!","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/40188/thumbnail/small.png","url":"https://play.gamepix.com/key-shield-2/embed?sid=1","plays":41334,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40313","slug":"get-10","title":"Get 10","description":"Associer des nombres n'a jamais été aussi amusant! Trouvez et connectez les nombres pour obtenir le nombre et score les plus élevés. Chaque nombre plus élevé représente un nouveau défi. Jusqu'où pouvez-vous aller?","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/40313/thumbnail/small.png","url":"https://play.gamepix.com/get-10/embed?sid=1","plays":41334,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"1L8EP","slug":"penalty-challenge-multiplayer","title":"Penalty Challenge Multiplayer","description":"Penalty Challenge Multiplayer is a HTML5 Sport Game. Select between 32 different team your favorite one. \nYou have 5 attempts to pass the goalie and other 5 to save your opponent’s kicks!\nIt’s all in your hands and feet! 3 Game’s Mode: - Multiplayer mode - Play against the pc - Challenge a friend playing on the same device","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/1L8EP/thumbnail/small.png","url":"https://play.gamepix.com/penalty-challenge-multiplayer/embed?sid=1","plays":41333,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"3R02S","slug":"drink-drive-survive","title":"Drink Drive Survive","description":"Have you ever tried to drive while drunk? If the answer is no, good for you! me neither! So, what about a simulator that shows you the all the issues that a drunken driver has to face?\n\nUse the mouse / or touch the screen to drive the car around","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/3R02S/thumbnail/small.png","url":"https://play.gamepix.com/drink-drive-survive/embed?sid=1","plays":41332,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"E6O54","slug":"cerkio","title":"Cerkio","description":"Touch the screen at the right time to throw the ball in the white circle.\nRepeat it for more than 30 levels and prove yourself you are skilled enough to complete the game!\n\n34 levels\nNice music\nRelaxing game\none hand game","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/E6O54/thumbnail/small.png","url":"https://play.gamepix.com/cerkio/embed?sid=1","plays":41326,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"O5W86","slug":"jigsaw-collections","title":"Jigsaw Collections","description":"Jigsaw puzzle is one of the entertaining, educational games that requires perseverance, accuracy, patience, and most importantly - to be attentive to the little things. Online jigsaw puzzles always attract a huge audience of completely different ages. In our game, everyone can find interesting collections for themselves! A game of this kind is an intrigue, a mystery that both an adult and a child would like to unravel. Search and combine the pieces into a single picture. For convenience, you can zoom in or out on the work surface. We wish you only victories!","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/O5W86/thumbnail/small.png","url":"https://play.gamepix.com/jigsaw-collections/embed?sid=1","plays":41323,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"6I66L","slug":"island-puzzle","title":"Island Puzzle","description":"$6","category":"Puzzle","tags":["adventure","classics","junior","puzzles"],"thumbnail":"https://games.assets.gamepix.com/6I66L/thumbnail/small.png","url":"https://play.gamepix.com/island-puzzle/embed?sid=1","plays":41310,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"4AC46","slug":"crap-attack","title":"Crap Attack","description":"A man, a woman, a date,  and tons and tons of pooh.\n\nYou are the miraculous pill that can fix the situation!\n\n\n\n        \n\nTry to keep clean the man that swallowed you, and kill all the crap before it is too late!     \n\nNobody but you can do that! You have only 5 minutes per level to clean the man's intestine and save the date.\n                                                                               \n\nABOUT THE GAME\n\n- 7 Levels full of \"crappy monsters\" to defeat.\n\n- Two different modes: Story Mode and Crap Hysteria Mode (NOTE: you have to finish the Story Mode to unlock this mode).\n\n- Two endings (with 2 different FMV.)\n\n- Try to finish the game without swear like a trooper (The Crap Hysteria  Mode is REALLY HARD, so we're not responsable of your frustration).","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/4AC46/thumbnail/small.png","url":"https://play.gamepix.com/crap-attack/embed?sid=1","plays":41297,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40257","slug":"donutosaur-2","title":"Donutosaur 2","description":"Help Donutosaur get his donut! Collect candies by changing the shape of Donutosaur and switching the direction of gravity. Donutosaur's friends will be of great help - they can push, pull and destroy objects.","category":"Puzzle","tags":["arcade","puzzles"],"thumbnail":"https://games.assets.gamepix.com/40257/thumbnail/small.png","url":"https://play.gamepix.com/donutosaur-2/embed?sid=1","plays":41295,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"18255","slug":"jurassic-run","title":"Jurassic Run","description":"Un voyage d'aventures qui a mal tourné ! Un dinosaure sanguinaire est à vos trousses ! Pas le temps de descendre un rocher et escalader l'autre. Vous devez utiliser le bâton pour passer de l'autre côté. Veillez à ce que le bâton soit de la bonne longueur, sinon vous tomberez ou vous serez mangé ! Et n'oubliez pas de ramasser les œufs de dinosaure pour avoir une deuxième chance.\n","category":"Arcade","tags":["adventure","arcade"],"thumbnail":"https://games.assets.gamepix.com/18255/thumbnail/small.png","url":"https://play.gamepix.com/jurassic-run/embed?sid=1","plays":41288,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40312","slug":"flow-mania","title":"Flow Mania","description":"Un jeu de casse-têtes simple mais addictif. Reliez des paires de points colorés avec des tuyaux pour créer du courant entre eux. Vous devez aussi remplir le plateau de jeu de tuyaux. Les tuyaux ne peuvent ni se croiser, ni se chevaucher.","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/40312/thumbnail/small.png","url":"https://play.gamepix.com/flow-mania/embed?sid=1","plays":41284,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"8A3W8","slug":"tac-tac-way","title":"Tac Tac Way","description":"Tac Tac Way, the only game who require a personal Zen master to be played.\nYou are the ball that needs to drive around psychedelic states of consciousness. Be careful to stay on the wall and follow the path as much as you can!\n\nTap the screen to change the direction or to teleport over lava. If you fall off the edges, you're gone!\n\nHow far can you go? Someone will tell you you need no stress and anxiety if you want to succeed in this Zen game, are you calm enough?\nMaybe you'll need a personal Zen master to play this game.\nRemember, this is not a classic zigzag game!","category":"Arcade","tags":["classics","puzzles"],"thumbnail":"https://games.assets.gamepix.com/8A3W8/thumbnail/small.png","url":"https://play.gamepix.com/tac-tac-way/embed?sid=1","plays":41284,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"N0NS8","slug":"angry-sharks","title":"Angry Sharks","description":"Le requin a été exposé à des radiations et il a muté. Il flotte dans la mer et mange des poissons. Plus il en mange, plus il grossit. Les gens ont peur de lui et essaient de le détruire. Essayez de survivre à leurs attaques.\n","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/N0NS8/thumbnail/small.png","url":"https://play.gamepix.com/angry-sharks/embed?sid=1","plays":41275,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"555ER","slug":"red-and-green-3","title":"Red and Green 3","description":"red and green 3 is a two player game. An adventurous game for two, depicting the friendship between the red man and the green man, consisting of 10 chapters. collect candies and earn points. watch out for lasers.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/555ER/thumbnail/small.png","url":"https://play.gamepix.com/red-and-green-3/embed?sid=1","plays":41274,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"P731E","slug":"pop-pop-kitties","title":"Pop-Pop Kitties","description":"Play a cute puzzle as you pop-pop all the kitties using strategy and reflexes! With 100+ challenging puzzles and adorable kitties this kawaii Match-3 Puzzle Shooter game will charm players for hours. Can you collect all the stars?","category":"Puzzle","tags":["arcade","classics","puzzles","strategy"],"thumbnail":"https://games.assets.gamepix.com/P731E/thumbnail/small.png","url":"https://play.gamepix.com/pop-pop-kitties/embed?sid=1","plays":41272,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"0004P","slug":"robot-police-iron-panther","title":"Robot Police Iron Panther","description":"When the monster alien come to attack the earth, there's no body can save us except the police robot. Build your own Iron Panther robot and fight the monster in an epic fighting! It's not finished yet...","category":"Arcade","tags":["arcade","junior"],"thumbnail":"https://games.assets.gamepix.com/0004P/thumbnail/small.png","url":"https://play.gamepix.com/robot-police-iron-panther/embed?sid=1","plays":41268,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"022EE","slug":"open-dune-2","title":"Open Dune 2","description":"Dune 2 is a Westwood Studios game put together back in 1992, and it's probably best known for being the prototypical RTS, one of the first games to put together all of the elements that later led to the genre that made StarCraft and Command & Conquer so popular. \n\nThis version is authentic. It's a nice trip down memory lane, or maybe just a free introduction to a piece of PC gaming history.","category":"Stratégie","tags":["strategy"],"thumbnail":"https://games.assets.gamepix.com/022EE/thumbnail/small.png","url":"https://play.gamepix.com/open-dune-2/embed?sid=1","plays":41267,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"T0OO6","slug":"dotto-botto","title":"Dotto Botto","description":"Dotto Botto is a classic platformer game.\n\nHelp Dotto to find his way home and try to beat all the levels!\n\nYou will face deadly enemies, weird creatures and hideous obstacles on your way back home, so be careful!\n\nFEATURES\n\n10 Levels full of moving platforms, obstacles, power-ups, spikes, enemies and much more! (not so much more, actually)\n2 game endings! (yes, not 1 but 2!!!! unbelievable!!!)\nColorful pixelated graphics\n\nA monstrous Final Boss!\n4 Different enemies\nDozens of traps and obstacles!\n","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/T0OO6/thumbnail/small.png","url":"https://play.gamepix.com/dotto-botto/embed?sid=1","plays":41260,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"LE29T","slug":"creative-puzzle","title":"Creative Puzzle","description":"Loves coloring? Even puzzles? This game have 32 pictures to satisfy your loves for coloring and puzzles. Play this game to have a blast fun in coloring and puzzles!","category":"Arcade","tags":["junior","puzzles"],"thumbnail":"https://games.assets.gamepix.com/LE29T/thumbnail/small.png","url":"https://play.gamepix.com/creative-puzzle/embed?sid=1","plays":41244,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40349","slug":"princess-nail-art","title":"Princess Nail Art","description":"Princess Nail Art is more-games-in-one of manicure and pedicure, just for girls! It's full of tips for all girls and there are lots of colors to paint nails and have fun!","category":"Puzzle","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/40349/thumbnail/small.png","url":"https://play.gamepix.com/princess-nail-art/embed?sid=1","plays":41244,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"8G55I","slug":"fishing-io","title":"Fishing.io","description":"Dans ce jeu amusant et facile aux beaux graphismes, vous allez devenir le premier pêcheur à avoir atteint le fond de l'océan. Collectez des poissons et des trésors pour acheter des améliorations de filet de pêche qui vous permettront d'aller plus profondément. Trouvez plus de personnages pris au piège en mer et remplissez votre salle des trophées.\n","category":"Arcade","tags":["adventure","arcade","sports"],"thumbnail":"https://games.assets.gamepix.com/8G55I/thumbnail/small.png","url":"https://play.gamepix.com/fishing-io/embed?sid=1","plays":41234,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40125","slug":"fun-summer-holiday","title":"Fun Summer Holiday","description":"L'été est enfin là! Et que faites-vous quand l'été est là? Vous partez à la Plage? En vacances? Certainement les deux, tout comme Ashley et ses amis, qui veulent passer leur été ensemble mais n'ont pas encore décidé quelles seraient leurs activités nautiques. Aidez Ashley à choisir ses plus beaux maillots de bain et à passer un été de folie!","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/40125/thumbnail/small.png","url":"https://play.gamepix.com/fun-summer-holiday/embed?sid=1","plays":41232,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"5","slug":"duelers","title":"Duelers","description":"Sauvez la Princesse du mal absolu qui s'apprête à s'abattre sur le monde ! Dégainez votre épée et venez à bout de tous vos ennemis!","category":"Aventure","tags":["adventure","strategy"],"thumbnail":"https://games.assets.gamepix.com/5/thumbnail/small.png","url":"https://play.gamepix.com/duelers/embed?sid=1","plays":41232,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"MM125","slug":"drag-me-ow","title":"Drag me-ow","description":" Drag and drop game where you have to  bring a cat to his beloved cushion without getting killed.\n\nUse the mouse or touch the screen to drag the cat around bring it to its soft pillow","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/MM125/thumbnail/small.png","url":"https://play.gamepix.com/drag-me-ow/embed?sid=1","plays":41223,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"R6TS4","slug":"steve-adventurecraft","title":"Steve Adventurecraft","description":"Hunt down zombies, skeleton men and exploding monsters with Steve, but don't forget the designs, they are your friends. Use with Steve through the gates of kill monsters world to reach victory and finish the game! 20 different levels 3 different monsters and 5 different friends!\n\nHow to Play?\nWASD + F / Mobile Control Touch","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/R6TS4/thumbnail/small.png","url":"https://play.gamepix.com/steve-adventurecraft/embed?sid=1","plays":41221,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"L06IR","slug":"loaf-clicker","title":"Loaf Clicker","description":"Loaf clicker est un jeu de clicker dans lequel vous devez collecter des pains. Vous pouvez acheter diverses améliorations pour augmenter votre collection de pains. Débloquez toutes les réalisations et devenez un milliardaire!","category":"Stratégie","tags":["strategy"],"thumbnail":"https://games.assets.gamepix.com/L06IR/thumbnail/small.png","url":"https://play.gamepix.com/loaf-clicker/embed?sid=1","plays":41219,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"61067","slug":"a-mole-in-a-hole","title":"A Mole in a Hole","description":"Help a forgetful mole to find his way home!\nLook at the map and choose the right path!\nGo home to your wife before dinner is ready! She'is waiting for you!\n\nFeatures:\n-20 Levels to dig\n-10 Achievements to unlock\n- Many different ways to die\n- Plenty of distractions to avoid\n- That's it! This is a game about a mole that digs holes, what else do you want?","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/61067/thumbnail/small.png","url":"https://play.gamepix.com/a-mole-in-a-hole/embed?sid=1","plays":41215,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40419","slug":"the-green-mission-inside-a-cave","title":"The Green Mission Inside a Cave","description":"The Green Mission Inside a Cave! Buddy is a green cucumber who has an ability to change color. Go through the mysterious cave to find secret recipes. Switch colors to solve puzzles, avoid red enemies and fly on the Buddy Rocket to finish all levels!","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/40419/thumbnail/small.png","url":"https://play.gamepix.com/the-green-mission-inside-a-cave/embed?sid=1","plays":41214,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"1E47I","slug":"red-and-green-pumpkin","title":"Red and Green Pumpkin","description":"Slime pumpkins and scary pumpkin monsters are waiting for you in the red and green pumpkin game, the scariest series of the red and green series. be careful, it is the game of the hardest series. You need teamwork. The game is for two players.\n\nHow to Play?\n*Use \"WASD\" keys to move red.\n*Use \"Arrow Keys\" keys to move Green.\n*Jump twice to jump higher! ( Double Jump available )\n*Watch out for monsters, you may die to them.\n*Find the key and reach the door!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/1E47I/thumbnail/small.png","url":"https://play.gamepix.com/red-and-green-pumpkin/embed?sid=1","plays":41214,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40341","slug":"diggy","title":"Diggy","description":"Diggy is back! Dig all the way to the center of the moon. Collect treasure and upgrade your mining equipment to help you along the way.","category":"Puzzle","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/40341/thumbnail/small.png","url":"https://play.gamepix.com/diggy/embed?sid=1","plays":41201,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"4","slug":"octane-racing","title":"Octane Racing","description":"Vous conduisez une puissante voiture de sport et devez éviter les véhicules adverses aussi longtemps que possible. Faites attention, chaque Crash vous coûtera une vie!","category":"Sport","tags":["arcade","sports"],"thumbnail":"https://games.assets.gamepix.com/4/thumbnail/small.png","url":"https://play.gamepix.com/octane-racing/embed?sid=1","plays":41192,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"S11I6","slug":"big-shark","title":"Big Shark","description":"Big Shark is a fish-eating game with many challenges. Through each level, you will discover many animals in the ocean.\n\nHow to play: Tap on the screen to control the shark avoids bigger fishes and eat smaller fishes. Your shark will grow up when he eats enough food.\n\nPufferfish, ray, swordfish, whale, killer whale (orca), sunfish, whale shark, electric eel... is waiting for you to discover.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/S11I6/thumbnail/small.png","url":"https://play.gamepix.com/big-shark/embed?sid=1","plays":41191,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40133","slug":"collect-the-gift","title":"Collect the Gift","description":"Le père-Noël a des ennuis! C'est déjà le soir de Noël et tous les cadeaux ne sont pas encore prêts..vite, coupez des cordes, utilisez votre fronde et activez des tas de boutons pour l'aider à finir tous les cadeaux à l'heure!","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/40133/thumbnail/small.png","url":"https://play.gamepix.com/collect-the-gift/embed?sid=1","plays":41188,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"4ER7I","slug":"noob-huggy-winter","title":"Noob Huggy Winter","description":"It is snowing in game 2 of the series and are you up for the adventure of a noob huggy running with a christmas hat on a cold winter day? In this adventure, we must protect ourselves by jumping from dangerous slime and thorns in the snow-covered forest. We have to be careful with the bees, they can sting, if they do, you may die. collect the diamonds, get the key and go through the door. You can nature in a cave or in a forest, but don't give up, go straight to the door!   \n\nHow to Play?\nWASD\" to move & \"Arrow Keys\" to move         \nMobile Touch Control         \nDouble jump is active in the game.            ","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/4ER7I/thumbnail/small.png","url":"https://play.gamepix.com/noob-huggy-winter/embed?sid=1","plays":41185,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"73LEY","slug":"cycle-extreme","title":"Cycle Extreme","description":"Take part in a mountain bike downhill racing challenge. \n\nYou control a bicycle rushing down from the mountains. Be careful - the track is very steep, and there are several obstacles and deadly holes ahead. Be careful and finish each of 20 levels as fast as you can to gain 3 stars!","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/73LEY/thumbnail/small.png","url":"https://play.gamepix.com/cycle-extreme/embed?sid=1","plays":41173,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"KOI6G","slug":"cooking-korean-lesson","title":"Cooking Korean Lesson","description":"Do you love Korean foods? Do you know how to make kimchi? Or do you know how to make bibimbap? Let's play and find out together in this fun cooking game where you will learn how to cook and serve the best kimchi and bibimbap you can make!","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/KOI6G/thumbnail/small.png","url":"https://play.gamepix.com/cooking-korean-lesson/embed?sid=1","plays":41168,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"7O68O","slug":"takeover","title":"Takeover","description":"Takeover is a real-time strategy game where you command squads of units to protect your strongholds from enemies and seize their buildings to win.\n\nFor centuries the Rivadis Empire ruled the continent in its shine and glory. But now it fell into necromancers’ hands and dying. Time for Takeover has come! \n\nLead one of 3 nations in the battle for Rivadis. Each nation has 5 types of squads, 3 types of strongholds and magic spells. In addition, you can build gold mines, farms to hire more squads, and obelisks to get more mana.\n\nKey features:\n- Real-time strategy with squads\n- 3 nations that you can control (and an extra Necromancers nation)\n- 5 squad types\n- 3 spells and a powerful Grand Spell for each nation.\n- Edicts - upgrades that make your army stronger\n- 8 levels for each nation","category":"Stratégie","tags":["strategy"],"thumbnail":"https://games.assets.gamepix.com/7O68O/thumbnail/small.png","url":"https://play.gamepix.com/takeover/embed?sid=1","plays":41165,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"3RE59","slug":"extreme-drift-racing","title":"Extreme Drift Racing","description":"Extreme Drift Racing est un jeu de course. Le jeu dispose de cinq emplacements où le joueur dérive et accumule des points pour lesquels il peut acheter des véhicules (13 voitures).","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/3RE59/thumbnail/small.png","url":"https://play.gamepix.com/extreme-drift-racing/embed?sid=1","plays":41151,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"7105F","slug":"furious-speed","title":"Furious Speed","description":"Speed is the essence of this game! Get a super cool sport car and drive as fast as you can! Avoid collision with other cars and don’t let the police to get you. Unlock new cars be scoring enough points. You get points for overtaking the other cars (if the car is on the lane next to yours). Let the speed make you furious!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/7105F/thumbnail/small.png","url":"https://play.gamepix.com/furious-speed/embed?sid=1","plays":41137,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"20063","slug":"top-shootout","title":"Top Shootout","description":"Devenez la meilleure gachette de tout le Far West! Des bandits ont capturé des otages et les retiennent prisonniers dans le saloon. Vous êtes le seul à pouvoir les sauver! Rechargez votre arme et descendez tous les malfrats ainsi que leurs chefs!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/20063/thumbnail/small.png","url":"https://play.gamepix.com/top-shootout/embed?sid=1","plays":41133,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"OIGOI","slug":"city-blocks","title":"City Blocks","description":"City Blocks is a match-3 puzzle game. Strategically place new buildings and upgrade them to build the largest possible city before you run out of space.","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/OIGOI/thumbnail/small.png","url":"https://play.gamepix.com/city-blocks-highscore-puzzle/embed?sid=1","plays":41129,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40380","slug":"don-t-touch-the-red","title":"Don’t touch the red","description":"Un jeu conçu pour vous divertir dès le début. Chaque mode respecte une seule règle: toucher autant de tuiles vertes que possible, et ne pas toucher la tuile rouge!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/40380/thumbnail/small.png","url":"https://play.gamepix.com/dont-touch-the-red/embed?sid=1","plays":41125,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40159","slug":"mixed-world","title":"Mixed World","description":"Mixed World est un jeu de puzzle particulièrement cool et fun dans lequel vous devrez faire disparaitre toutes les balles rouges de la plateforme en faisant glisser votre personnage dessus. Vous pourrez aussi utiliser différents objets pour vous aider à passer les niveaux les plus difficiles.","category":"Aventure","tags":["arcade","adventure","puzzles"],"thumbnail":"https://games.assets.gamepix.com/40159/thumbnail/small.png","url":"https://play.gamepix.com/mixed-world/embed?sid=1","plays":41118,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"YA1N9","slug":"final-freeway-2r","title":"Final Freeway 2R","description":"Speed through several exciting stages. Pick a character and choose your path as you drive!\nThe impressive sense of speed, catchy tunes and a super-retro look, will kick you back to the 80s! Beat the clock to the next checkpoint and don't let the pesky challenger beat you!","category":"Arcade","tags":["arcade","sports"],"thumbnail":"https://games.assets.gamepix.com/YA1N9/thumbnail/small.png","url":"https://play.gamepix.com/final-freeway-2r/embed?sid=1","plays":41107,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"830T0","slug":"save-kitten","title":"Save kitten","description":"CATASTROPHE! Angry Tom Cat decoyed kittens into his tower. Save as many kittens as you can!\nRun, catch them with a trampoline, and carry them to their Mother Cat’s basket!\nKittens are desperate for your help. Who will save them, if not you?\n\n- Colorful HD graphics and animation\n- Buy cool clothes and improve them\n- Complete exciting missions and earn coins\n- Discover the magic chest and receive gifts\n- Catch super boosters: time increase, super speed and magnetism, but beware of bombs\n- Raise your level and beat the records of other players!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/830T0/thumbnail/small.png","url":"https://play.gamepix.com/save-kitten/embed?sid=1","plays":41104,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"323G7","slug":"going-right","title":"Going Right","description":"Bring the bird to its nest without getting hit by the obstacles\nA simple one touch avoid and collect game, with five differents game modes:\n20 Hard Levels to enjoy!\n\nNORMAL MODE: You can start the game from any level you have already completed.\nDEATH MODE: You got only 10 attempts to complete all the levels.\nTIME ATTACK: Beat your best time in this game mode, and show yourself what you can do.\nINFINITE RUN: Fly as long as you can avoiding the obstacles and collecting coins.\nSHOP: Buy new skins and choose different colors to customize your bird.\n\nThat’s all!","category":"Arcade","tags":["arcade","puzzles"],"thumbnail":"https://games.assets.gamepix.com/323G7/thumbnail/small.png","url":"https://play.gamepix.com/going-right/embed?sid=1","plays":41102,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"0SSTD","slug":"shotwildwest","title":"ShotWildWest","description":"ShotWildWest is an arcade game set in the wild west.\nTest your fingers by challenging the speed,\ntrain your mind to hit obstacles quickly and accurately, trying to break all records!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/0SSTD/thumbnail/small.png","url":"https://play.gamepix.com/shotwildwest/embed?sid=1","plays":41085,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"811YS","slug":"funny-rescue-gardener","title":"Funny Rescue Gardener","description":"Samantha is a great gardener, but even the best will get accidents sometimes. Let's play and rescue Samantha from the horrible accident! Help her recover from the wounds and have fun!","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/811YS/thumbnail/small.png","url":"https://play.gamepix.com/funny-rescue-gardener/embed?sid=1","plays":41085,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"91EM7","slug":"demon-killer","title":"Demon Killer","description":"Vous êtes le seul à pouvoir sauver le monde ! Armez-vous d'un arsenal d'armes et arrêtez l'invasion de démons. Ne vous arrêtez pas et utilisez votre potentiel de tir.\n","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/91EM7/thumbnail/small.png","url":"https://play.gamepix.com/demon-killer/embed?sid=1","plays":41083,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"1O81W","slug":"runaway-toad","title":"Runaway Toad","description":"$7","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/1O81W/thumbnail/small.png","url":"https://play.gamepix.com/runaway-toad/embed?sid=1","plays":41082,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"1MIC9","slug":"moto-maniac","title":"Moto Maniac","description":"This trial bike game is simple yet challengling - the levels look short, but it's not that easy to reach the finish line. Get through the piles of logs, boxes and even boats carefully - this is what 'trial' is all about.\n\nOvercome all the obstacles and don't let the biker hit head or flop. The balance is key - lean back or forward for the best grip.\n\nCompete for the best score with the other players via highscore table - show your skills to everyone.","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/1MIC9/thumbnail/small.png","url":"https://play.gamepix.com/moto-maniac/embed?sid=1","plays":41082,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"16B4U","slug":"noob-huggy","title":"Noob Huggy","description":"You must be a partner in the adventure of a huggy living in a cute block world. Huggy, who is both noob and funny, needs to escape from slimes. You have to get the key and activate the door and help him move to the next level.    \n\nHow to Play?\n\"WASD\" to move & \"Arrow Keys\" to move    \nMobile Touch Control    \nDouble jump is active in the game.          \n","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/16B4U/thumbnail/small.png","url":"https://play.gamepix.com/noob-huggy/embed?sid=1","plays":41076,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"2UAPU","slug":"super-cute-cat","title":"Super Cute Cat","description":"You need to help super sweet cat hunt the mutated cats. You must destroy the mutated cats and get the key and move on to the next level. There are different difficulties in each level, do not forget to collect candies.  \n\nHow to Play?\nWASD + Mobile touch control","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/2UAPU/thumbnail/small.png","url":"https://play.gamepix.com/super-cute-cat/embed?sid=1","plays":41067,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"64O55","slug":"moto-fury","title":"Moto Fury","description":"Un jeu de course palpitant. Découvrez le plaisir des virées en moto sur une autoroute infinie et très empruntée. Plus vous roulez dangereusement, plus vous accumulez d'argent et de points. Avec votre argent, vous pouvez acheter de meilleures motos plus puissantes. Devenez un rebelle et semez la pagaille sur la route ! Essayez juste de ne pas vous écraser en roulant à une vitesse folle.\n","category":"Arcade","tags":["arcade","sports"],"thumbnail":"https://games.assets.gamepix.com/64O55/thumbnail/small.png","url":"https://play.gamepix.com/moto-fury/embed?sid=1","plays":41060,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40438","slug":"3d-darts","title":"3D Darts","description":"Darts 3D, a famous classic game now on your device in gorgeous 3D, defeat opponents in hundreds of levels. Or just play with your friends on one device. Just throw the dart and get a score. Very easy to start, but hard to master.","category":"Sport","tags":["arcade","classics","sports"],"thumbnail":"https://games.assets.gamepix.com/40438/thumbnail/small.png","url":"https://play.gamepix.com/3d-darts/embed?sid=1","plays":41060,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"24OP4","slug":"popit-vs-spinner","title":"Popit vs Spinner","description":"Try to remove all the popits in those 3 levels by matching at least 2 of the same tiles at once. Use the spinner mode when no matches are left to generate new ones and clean the whole level.","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/24OP4/thumbnail/small.png","url":"https://play.gamepix.com/popit-vs-spinner/embed?sid=1","plays":41054,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"6270S","slug":"slimoban-2","title":"Slimoban 2","description":"In each level, you need to collect the golden coin, escape from the slimes, and destroy them if possible. The girl can collect magic potions that help to lift big wooden blocks and slimes. After lifting the blocks or the slimes, you need to drop them in the right places. There is also water in the game, and you can drop things in there. You can move blocks, collect them, and drop them. You also need to lure the slimes in the trap, throw boxes in them, and push them into the water. But all of these things you can do are not obligatory, the main thing you need to do to pass the level is to collect the coin.","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/6270S/thumbnail/small.png","url":"https://play.gamepix.com/slimoban-2/embed?sid=1","plays":41050,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"IISR2","slug":"slalom-ski-simulator","title":"Slalom Ski Simulator","description":"Slalom Ski Simulator is a HTML5 Sport Game. \nGo around gates to complete the track and try to improve your best time on each track!","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/IISR2/thumbnail/small.png","url":"https://play.gamepix.com/slalom-ski-simulator/embed?sid=1","plays":41046,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"R33T3","slug":"morphit","title":"Morphit","description":"Morphit is a hypercasual game where you have to change your shape to pass trough the obstacles.\nTry to last as long as you can and unlock all the achievements!\nGame Controls:\ntouch the buttons to change the shape of the player and match the obstacles'ones.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/R33T3/thumbnail/small.png","url":"https://play.gamepix.com/morphit/embed?sid=1","plays":41037,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"00UT9","slug":"funny-pet-haircut","title":"Funny Pet Haircut","description":"Take your messy pets, alpaca and cat to the hair salon. Wash and dry your pets before\ngiving them a brand new look by changing their colors and giving them pattern look.\nDress up too. And turn them into a stylish beauty!","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/00UT9/thumbnail/small.png","url":"https://play.gamepix.com/funny-pet-haircut/embed?sid=1","plays":41036,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40454","slug":"cricket-championship","title":"Cricket Championship","description":"Choose your favorite International teams and start playing Cricket Championship. Watch the line of the ball and swing your bat in time to hit the ball out of the park. This game is really fun for all true cricket fans who like to smash boundaries and win the match in style.","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/40454/thumbnail/small.png","url":"https://play.gamepix.com/cricket-championship/embed?sid=1","plays":41028,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"26A1R","slug":"saguaro","title":"Saguaro","description":"Help Saguaro, a mexican cactus, to go for a jog without hit his balloon friends. Avoid them as long as you can. Every time you hit a balloon you will lose one your beloved items, like his hat or one of his maracas! You can restore your lives collecting the glowing maracas you will find on the road!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/26A1R/thumbnail/small.png","url":"https://play.gamepix.com/saguaro/embed?sid=1","plays":41023,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"2OD06","slug":"maze-of-death","title":"Maze of Death","description":"Escape from a maze full of zombies in this old style first person shooter like doom. You can use all the weapons you can find in the game to make your way through hordes of zombies. Find the exit as fast as you can.","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/2OD06/thumbnail/small.png","url":"https://play.gamepix.com/maze-of-death/embed?sid=1","plays":41020,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"LEL11","slug":"doll-queen-designer","title":"Doll Queen Designer","description":"Create her dream toy by collecting the dresses and coloring them.\nDoll Queen Designer have smooth controls and over 100 levels.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/LEL11/thumbnail/small.png","url":"https://play.gamepix.com/doll-queen-designer/embed?sid=1","plays":41017,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40451","slug":"amazing-sheriff","title":"Amazing Sheriff","description":"Pin on your shiny sheriff's badge, load up your six-shooters, and get ready for some amazing action. Take control of this high flying Sheriff on a wheel-spinning, bottle-breaking wild ride! Yee-haw!","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/40451/thumbnail/small.png","url":"https://play.gamepix.com/amazing-sheriff/embed?sid=1","plays":41006,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"90E9T","slug":"poppy-strike","title":"Poppy Strike","description":"Poppy Strike is a 3D shooting game which features gun game mode with big arsenal of weapons and famous dust 2 map crowded with huggy wuggy, your mission is to shoot all incoming huggy wuggy and try to survive by the end of each round in order to get new weapons.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/90E9T/thumbnail/small.png","url":"https://play.gamepix.com/poppy-strike/embed?sid=1","plays":40996,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"7079I","slug":"hit-em-up","title":"Hit Em Up","description":"Hit Em Up is a very cool game to destroy zombies and you have a bazooka with super bombs. Save the whole world by clearing the planet from the zombie invasion!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/7079I/thumbnail/small.png","url":"https://play.gamepix.com/hit-em-up/embed?sid=1","plays":40988,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40293","slug":"doctor-teeth","title":"Doctor Teeth","description":"Become a dentist and take care of your patients' teeth! Use different tools to treat caries, bad breath and extract teeth. Play fun mini games and use the stethoscope hints in case you're stuck on your to-do list. Can you give all your patients their smile back?","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/40293/thumbnail/small.png","url":"https://play.gamepix.com/doctor-teeth/embed?sid=1","plays":40986,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"T7RIP","slug":"super-pop-it","title":"Super Pop It","description":"Super Pop It! is a fun relaxing game and a unique game to play on. This is a super relaxing game to play for hours.\nWe have got different shapes of pop gadgets, click on the pops to smash them and clear the board.\nBe quick and smash all the pops and feel the relax from the tensions, this game is for all ages and you can play for hours. ","category":"Arcade","tags":["arcade","junior"],"thumbnail":"https://games.assets.gamepix.com/T7RIP/thumbnail/small.png","url":"https://play.gamepix.com/super-pop-it/embed?sid=1","plays":40977,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"60T90","slug":"santa-games","title":"Santa Games","description":"Collect some gifts along the way to find the magic sleigh! In this pixel-art game there are 7 levels to play. Besides gifts, you can also collect magic letters and then play another 7 special levels (minigames): Diamond rain, Drop gift, Brick out and more!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/60T90/thumbnail/small.png","url":"https://play.gamepix.com/santa-games/embed?sid=1","plays":40975,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40148","slug":"pixeroids","title":"Pixeroids","description":"Naviguez avec votre vaisseau spatial et détruisez les astéroïdes qui vous barrent le chemin sans les percuter! FEU!","category":"Arcade","tags":["arcade","classics"],"thumbnail":"https://games.assets.gamepix.com/40148/thumbnail/small.png","url":"https://play.gamepix.com/pixeroids/embed?sid=1","plays":40964,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40120","slug":"intergalactic-battleship","title":"Intergalactic Battleship","description":"Détruisez les vaisseaux alien pour sauver la planète terre! Appuyez ou cliquez sur la grille ennemie pour localiser et détruire les vaisseaux des envahisseurs…avant qu'ils n'anéantissent les votres!","category":"Arcade","tags":["classics","strategy"],"thumbnail":"https://games.assets.gamepix.com/40120/thumbnail/small.png","url":"https://play.gamepix.com/intergalactic-battleship/embed?sid=1","plays":40959,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"66C9L","slug":"incredible-box","title":"Incredible Box","description":"Incredible Box is a very traditional puzzle game. Roll the box to the target position, nothing more.\n\nIt looks simple, but this game is hard, very hard.\n\nIn order to help all of you can finish all of the levels. We have provided the solution of all levels.\n\nThe control is simple. Simply touch the box and roll it. And the game is completely 3D with very beautiful water effect.","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/66C9L/thumbnail/small.png","url":"https://play.gamepix.com/incredible-box/embed?sid=1","plays":40957,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"8NSL3","slug":"gun-simulator","title":"Gun Simulator","description":"Gun Simulator Shooting Range offers realistic and closest experience for semi-automatic and modern weapons shooting on the firing range. Imagine classic gun shooting closest experience with dynamic weapons sounds when you pull off the trigger aim for bull's eye.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/8NSL3/thumbnail/small.png","url":"https://play.gamepix.com/gun-simulator/embed?sid=1","plays":40955,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"58851","slug":"road-fury","title":"Road Fury","description":"Libérez votre fureur sur l'autoroute et abattez tout ce qui bouge ! Si vous ne pouvez pas tirer sur quelque chose, prenez-le... ce sont des bonus ! Améliorez votre voiture pour réaliser un trajet plus long, abattez les boss et allez aussi loin que vous pouvez pour pouvoir comparer vos meilleurs scores avec les autres ! Devenez le roi de la route !\n","category":"Arcade","tags":["adventure","arcade"],"thumbnail":"https://games.assets.gamepix.com/58851/thumbnail/small.png","url":"https://play.gamepix.com/road-fury/embed?sid=1","plays":40950,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"LU96E","slug":"triangle-run","title":"Triangle Run","description":"Play Triangle Run a Hypercasual game that will make your head spin!\n\nJust one click/tap to play!\n\nJust press and hold once on the screen and the triangle changes direction as soon as you release the button the triangle returns to the initial direction as the world rotates around you!\n\nSo try to complete the impossible level and try to get the best possible record!\n\nIt sounds easy but instead it will be a tough task!\n\nEnjoy Triangle run!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/LU96E/thumbnail/small.png","url":"https://play.gamepix.com/triangle-run/embed?sid=1","plays":40946,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40300","slug":"baseball-for-clowns","title":"Baseball for Clowns","description":"Henk was the best baseball player in the world before jokers cheated and defeated him with false means. And now, after Henk has retired, the jokers are back again to cause trouble! Help him get rid of the jokers once and for all!","category":"Puzzle","tags":["puzzles","sports"],"thumbnail":"https://games.assets.gamepix.com/40300/thumbnail/small.png","url":"https://play.gamepix.com/baseball-for-clowns/embed?sid=1","plays":40943,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40437","slug":"cricket-hero","title":"Cricket Hero","description":"Are you ready to test your reaction times? In Cricket Hero you’ll face the thrills and ecstasy of being a cricket player. Besides regular cricket balls, they may throw at you some other stuff too.","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/40437/thumbnail/small.png","url":"https://play.gamepix.com/cricket-hero/embed?sid=1","plays":40935,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40072","slug":"cut-the-rope-time-travel","title":"Cut The Rope: Time Travel","description":"Remonte le temps avec Om Nom pour nourrir ses ancêtres avec des bonbons ! Cut the Rope: Time Travel est une nouvelle aventure remplie d'action et basée sur la physique qui te fera voyager à travers le temps pour aller croquer du bonbon!","category":"Aventure","tags":["adventure","classics","puzzles"],"thumbnail":"https://games.assets.gamepix.com/40072/thumbnail/small.png","url":"https://play.gamepix.com/cut-the-rope-time-travel/embed?sid=1","plays":40925,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"R467U","slug":"funny-nose-surgery","title":"Funny Nose Surgery","description":"Mia has always had a snotty nose. But now it has been gone too far, and she need to clean it. Help fix her nose problems, maybe with some surgery. You can also put stickers on her nose after that!","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/R467U/thumbnail/small.png","url":"https://play.gamepix.com/funny-nose-surgery/embed?sid=1","plays":40925,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"R7R75","slug":"dark-world","title":"Dark World","description":"Dark World, the platformer you're been waiting for!\nComplete 30 unique levels to escape the dark world but but careful with your enemies. There is always an easier way to reach the end of the level, check all the game platforms to find useful items\n\n-instructions-\n\nJump - Touch/click the jump button or press `w` on your keyboard\nSword Attack - Touch/click the hit button or press `space` on your keyboard\nThrow sword - Touch/click the sword button or press `c` on your keyboard\n\n-key game features-\n\n30 Unique levels\n2 types of attacks\nMobile browser optimized\nlightweight\nHD graphics\n3 enemies, each having their own attack\n20 languages localization\npause option\nLandscape orientation\n","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/R7R75/thumbnail/small.png","url":"https://play.gamepix.com/dark-world/embed?sid=1","plays":40923,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40413","slug":"skating-hero","title":"Skating Hero","description":"Choose your hero and compete across 3 programs in the Figure Skating event. Hit the matching button (or swipe) as they line up with the top slot. Time your moves perfectly to boost your score and win!","category":"Sport","tags":["arcade","sports"],"thumbnail":"https://games.assets.gamepix.com/40413/thumbnail/small.png","url":"https://play.gamepix.com/skating-hero/embed?sid=1","plays":40920,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"K3V1A","slug":"las-vegas-blackjack","title":"Las Vegas Blackjack","description":"Profitez de l'ambiance authentique du casino de Las Vegas. L'occasion unique de tenter votre chance et gagner de superbes prix dans le monde dangereux du black jack. Testez différentes stratégies et trouvez celle qui vous assurera la victoire.  \n","category":"Stratégie","tags":["arcade","board","classics"],"thumbnail":"https://games.assets.gamepix.com/K3V1A/thumbnail/small.png","url":"https://play.gamepix.com/las-vegas-blackjack/embed?sid=1","plays":40916,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"U11U6","slug":"coins-rush-run","title":"Coins Rush Run","description":"Join the crazy Coins Rush Run and multiply your virtual coins, select the best gates and collect lots of cash!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/U11U6/thumbnail/small.png","url":"https://play.gamepix.com/coins-rush-run/embed?sid=1","plays":40912,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"0A7MN","slug":"battalion-commander","title":"Battalion Commander","description":"Get armed to the teeth and fight your way through the enemy territory. You’ll need the help from your fellow soldiers trapped by the foe, ton of upgrades and mighty skills to survive.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/0A7MN/thumbnail/small.png","url":"https://play.gamepix.com/battalion-commander/embed?sid=1","plays":40909,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"9A3FN","slug":"funny-camping-day","title":"Funny Camping Day","description":"Do you want to take part in a summer camp?! Funny Camping Day is an exciting camping adventure game ever! Go outdoor with your forest-loving friends. Help them to do amazing camp activities: Clean up the camp, set up your tends, enjoy fishing, and light the campfire. Play the role of your friends in different activities. Have fun with Funny Camping day!","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/9A3FN/thumbnail/small.png","url":"https://play.gamepix.com/funny-camping-day/embed?sid=1","plays":40904,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"DOM50","slug":"model-wedding-girl-games","title":"Model Wedding - Girl Games","description":"$8","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/DOM50/thumbnail/small.png","url":"https://play.gamepix.com/model-wedding-girl-games/embed?sid=1","plays":40898,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"81AAO","slug":"las-vegas-roulette","title":"Las Vegas Roulette","description":"Préparez-vous à ressentir les sensations fortes du jeu de hasard de Las Vegas. Cette application de roulette est idéale pour apprendre les bases et élaborer la bonne stratégie ! Jouez à la roulette à tout moment et  n'importe où !\n","category":"Stratégie","tags":["board"],"thumbnail":"https://games.assets.gamepix.com/81AAO/thumbnail/small.png","url":"https://play.gamepix.com/las-vegas-roulette/embed?sid=1","plays":40894,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"I841E","slug":"zombie-killer","title":"Zombie Killer","description":"Survivez dans une ville apocalyptique envahie de morts-vivants. Choisissez votre héros et débarrassez la ville des zombies. Utilisez des armes et des explosifs. Gagnez des pièces et réalisez des améliorations pour survivre plus longtemps.\n","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/I841E/thumbnail/small.png","url":"https://play.gamepix.com/zombie-killer/embed?sid=1","plays":40885,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"H9G7J","slug":"journey-through-hell","title":"Journey Through Hell","description":"Journey Through Hell  is a free 3D platformer game with a beautiful low poly graphics.\n\nStory\n\nAfter burning in Hell for decades, Hitler takes a few days off from Hell officials to see other parts of Hell.\n\nGame Features\n\nBeautiful low poly environment\nFun and challenging 3D platformer gameplay\nEasy to pick up and play\nFunny and strange ","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/H9G7J/thumbnail/small.png","url":"https://play.gamepix.com/journey-through-hell/embed?sid=1","plays":40885,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"44H12","slug":"gt-ghost-racing","title":"GT Ghost Racing","description":"Choose your vehicle and race through the various tracks compete against the ghosts of racing legends to prove you are the best of the best and collect all the stars! Race through the seasons, night tracks, winter tracks and futuristic neon tracks. \n\n8 Cars, 9 Tracks, 27 Stars. Race during the seasons, at night and even an icy track.","category":"Sport","tags":["arcade","sports"],"thumbnail":"https://games.assets.gamepix.com/44H12/thumbnail/small.png","url":"https://play.gamepix.com/gt-ghost-racing/embed?sid=1","plays":40880,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40408","slug":"dunk-up-basketball","title":"Dunk Up Basketball","description":"Dunk Up Basketball is a crazy arcade that anybody will enjoy... Shoot the hoops, unlock new balls, become a basketball star!","category":"Puzzle","tags":["arcade","sports"],"thumbnail":"https://games.assets.gamepix.com/40408/thumbnail/small.png","url":"https://play.gamepix.com/dunk-up/embed?sid=1","plays":40880,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"1EE7L","slug":"ludo-legend","title":"Ludo Legend","description":"Faites une petite partie de Ludo ! Le jeu de plateau préféré de tous ! Jouez seul ou avec vos amis sur un seul appareil ! Il suffit de se le faire passer ! Le design coloré et la mécanique de jeu simple vous divertiront pendant des heures ! \n","category":"Stratégie","tags":["board"],"thumbnail":"https://games.assets.gamepix.com/1EE7L/thumbnail/small.png","url":"https://play.gamepix.com/ludo-legend/embed?sid=1","plays":40874,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40321","slug":"street-driver","title":"Street Driver","description":"Drive dangerously fast on a highway in traffic, overtake every vehicle, earn cash and buy better cars! Try not to crash at the highest speed. Time to start your engine!","category":"Puzzle","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/40321/thumbnail/small.png","url":"https://play.gamepix.com/street-driver/embed?sid=1","plays":40870,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"OA2OC","slug":"my-ice-cream-shop","title":"My Ice Cream Shop","description":"$9","category":"Stratégie","tags":["junior","strategy"],"thumbnail":"https://games.assets.gamepix.com/OA2OC/thumbnail/small.png","url":"https://play.gamepix.com/my-ice-cream-shop/embed?sid=1","plays":40858,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"4E495","slug":"let-me-in","title":"Let me in","description":"It’s time to test your real skills. A puzzle game. At a bus stop in a bustling big city, as an assistant policeman, you have to get everyone on board safely, and you can’t be overstaffed, and overstaffed cars will be crowded Explosion, so you have to direct the platform personnel to get on and off the bus in an orderly way. Be careful not to hit the passengers on the opposite car, otherwise you will lose, come on.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/4E495/thumbnail/small.png","url":"https://play.gamepix.com/let-me-in/embed?sid=1","plays":40854,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"N17Q4","slug":"bunny-quest","title":"Bunny Quest","description":"Ce lapin se lance dans une folle chasse aux carottes ! Aidez-le à atteindre son but en faisant glisser les tuiles pavées pour former un chemin. Un jeu de casse-têtes classique plus difficile qu'il n'y paraît ! Des tonnes de niveaux à travers trois modes à maîtriser. Testez vos compétences et rejoignez le lapin dans son aventure !\n","category":"Puzzle","tags":["adventure","junior","puzzles"],"thumbnail":"https://games.assets.gamepix.com/N17Q4/thumbnail/small.png","url":"https://play.gamepix.com/bunny-quest/embed?sid=1","plays":40848,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40449","slug":"water-me-please","title":"Water Me Please!","description":"This family-friendly puzzle game ‘Water Me Please!’ is beautifully designed to keep everybody happy. It is a perfect mix between puzzles and your childhood memories in a grassy land. Enjoy these easy-to-love characters, a small watering can and a lovely flower in a green farm. Ready to keep your lovely flower happy?","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/40449/thumbnail/small.png","url":"https://play.gamepix.com/water-me-please/embed?sid=1","plays":40846,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"04R15","slug":"wall-painter","title":"Wall Painter","description":"Wall Painter  is a casual but very fun puzzle game in which you need to fill all the wall spaces on a building. It can get very tricky at some times, so make sure you move in the right way to ensure that you don’t miss any spot. How many levels can you beat in this game? How far can you go ? We are waiting to see ! Enjoy.\n","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/04R15/thumbnail/small.png","url":"https://play.gamepix.com/wall-painter/embed?sid=1","plays":40846,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"E5S42","slug":"line-of-defense-2","title":"Line of Defense 2","description":"The best digital battle: shoot approaching enemies tanks and destroy them all! Do not let the enemies cross the red border line!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/E5S42/thumbnail/small.png","url":"https://play.gamepix.com/line-of-defense-2/embed?sid=1","plays":40843,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40428","slug":"fidget-spinner-creator","title":"Fidget Spinner Creator","description":"Do you like fidgets spinners and have you always wanted to create your own? Design your own spinner and start spinning. Each 5 spins you earn 1 coin.","category":"Puzzle","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/40428/thumbnail/small.png","url":"https://play.gamepix.com/fidget-spinner-creator/embed?sid=1","plays":40841,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"51953","slug":"swim-or-die","title":"Swim or Die","description":"Save a drowning pet touching the screen as fast as you can.\nCollect Time Points and unlock new pets' skins!\nSee the world changing around you and try to not drown!\nWho knows what could happen if you hang in there long enough...","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/51953/thumbnail/small.png","url":"https://play.gamepix.com/swim-or-die/embed?sid=1","plays":40840,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40432","slug":"switch-colors","title":"Switch Colors","description":"Tap the ball and follow the color pattern on each obstacle to cross it! Be careful not to pass through the wrong color, or you’ll have to start again.","category":"Puzzle","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/40432/thumbnail/small.png","url":"https://play.gamepix.com/switch-colors/embed?sid=1","plays":40840,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"4U604","slug":"anime-dress-up","title":"Anime Dress Up","description":"Create your perfect anime character!\nMake a screenshot and use it as your avatar.\n\nFeatures:\n1. Graphics in anime style\n2. 10 692 000 combinations of the appearance\n3. Many unusual items\n4. Cute cats\n5. Screenshot button\n6. Random button","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/4U604/thumbnail/small.png","url":"https://play.gamepix.com/anime-dress-up/embed?sid=1","plays":40832,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"8I51T","slug":"trz-battleship","title":"TRZ Battleship","description":"In alternate turns, you must guess the positions of all enemy ships, one shot at a time, and defeat them all. But do it before the opponent annihilates all yours!","category":"Stratégie","tags":["board","classics"],"thumbnail":"https://games.assets.gamepix.com/8I51T/thumbnail/small.png","url":"https://play.gamepix.com/trz-battleship/embed?sid=1","plays":40831,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"1Y335","slug":"crazy-knife","title":"Crazy Knife","description":"Chop in the kitchen like a real master. It's so satisfying! - Easy control - Addictive gameplay - Crazy Knife is simple and fun!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/1Y335/thumbnail/small.png","url":"https://play.gamepix.com/crazy-knife/embed?sid=1","plays":40826,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"L2H09","slug":"fall-heroes-guys","title":"Fall Heroes Guys","description":"Fall heroes Guys.io Finish dozens of courses and collect crowns. Be the winner of the day! Buy the costumes and change your image. Race with 10-40 people, be the winner of the race! Join the world of Fall heroes guys.io . Race with different costumes on different maps! Make the Difference.\n\nHow to Play?\nWASD + ZQSD and Arrow Keys - Mobile Control","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/L2H09/thumbnail/small.png","url":"https://play.gamepix.com/fall-heroes-guys/embed?sid=1","plays":40821,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"2QE95","slug":"jewel-blocks-quest","title":"Jewel Blocks Quest","description":"Testez vos compétences logiques dans ce puzzle d'arcade complexe. Jouez à un nombre infini de niveaux dans un environnement mystique et battez votre score. Facile et amusant ! Essayez toutes les fonctionnalités de jeu uniques.\n","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/2QE95/thumbnail/small.png","url":"https://play.gamepix.com/jewel-blocks-quest/embed?sid=1","plays":40820,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40441","slug":"mahjong-master-2","title":"Mahjong Master 2","description":"Le solitaire classique qui consiste à connecter des tuiles chinoises est à portée de main. Pensez bien chacun de vos coups et videz le plateau de ses tuiles empilées en pyramides complexes. Cherchez des tuiles libres similaires pour les connecter et les enlever. Il n'est possible de connecter que les tuiles qui ont au moins un côté libre. Jouez rapidement et marquez des points bonus. Gagnerez-vous toutes les étoiles dorées de tous les modes de jeu ?","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/40441/thumbnail/small.png","url":"https://play.gamepix.com/mahjong-master-2/embed?sid=1","plays":40820,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"66TN7","slug":"pop-it-infinity","title":"Pop it Infinity","description":"Pop It Infinity is a fun relaxing game and a unique game to play on.\nWe have got over 160 different shapes of pop gadgets, click on the pops to smash them and clear the board.\nBe quick and smash all the pops and feel the relax from the tensions, this game is for all ages and you can play for hours.","category":"Arcade","tags":["junior","classics"],"thumbnail":"https://games.assets.gamepix.com/66TN7/thumbnail/small.png","url":"https://play.gamepix.com/pop-it-infinity/embed?sid=1","plays":40803,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"U6AL0","slug":"neon-king-a-local-multiplayer-platformer","title":"Neon King - A local multiplayer Platformer","description":"Neon King est un jeu de canapé multijoueur local\n\n dans lequel ton seul but est\n\n pour éliminer votre adversaire.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/U6AL0/thumbnail/small.png","url":"https://play.gamepix.com/neon-king-a-local-multiplayer-platformer/embed?sid=1","plays":40782,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"E9OI8","slug":"chiellini-pool-soccer","title":"Chiellini Pool Soccer","description":"Try now \"Chiellini Pool Soccer\" and you can play the new game of Pool billiard soccer themed.\nTest the different game modalities, choose your best tactics, you can use 4 different modules, choose the your favorite shirt team and then sign your best record possible, and then see what position you have in the ranking! don't give up plays and replays to beat all your opponents !","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/E9OI8/thumbnail/small.png","url":"https://play.gamepix.com/chiellini-pool-soccer/embed?sid=1","plays":40774,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"MNI6O","slug":"neon-slimes","title":"Neon Slimes","description":"Make your opponent fall. Jump on his had to make him weak and small.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/MNI6O/thumbnail/small.png","url":"https://play.gamepix.com/neon-slimes/embed?sid=1","plays":40765,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40256","slug":"donutosaur","title":"Donutosaur","description":"Feed hungry adorable monster named Donutosaur. He likes candies but the thing he likes the most is a sweet yummy Donut!","category":"Puzzle","tags":["arcade","puzzles"],"thumbnail":"https://games.assets.gamepix.com/40256/thumbnail/small.png","url":"https://play.gamepix.com/donutosaur/embed?sid=1","plays":40764,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"20060","slug":"pixzombies","title":"PixZombies","description":"Dans Pix Zombies, un jeu 100% arcade, explosez tous les zombies  que vous croiserez et sauvez le monde!","category":"Aventure","tags":["arcade","adventure"],"thumbnail":"https://games.assets.gamepix.com/20060/thumbnail/small.png","url":"https://play.gamepix.com/pixzombies/embed?sid=1","plays":40764,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"SQSO7","slug":"squid-hero-impostor","title":"Squid Hero Impostor","description":"Green 456 hero squid impostor watch out for the guys. kill them and find the key get the key reveal the invisible door. You must kill the impostors. Kill them all.\n\nHow to Play?\nWASD + Mobile Touch Control","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/SQSO7/thumbnail/small.png","url":"https://play.gamepix.com/squid-hero-impostor/embed?sid=1","plays":40763,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"U8R5E","slug":"yummy-churros-ice-cream","title":"Yummy Churros Ice Cream","description":"Create your own Churros Ice Cream! Go through every step in the tasklist to make your delicious ice cream. Pick your favorite flavour and finish it with a combination of syrups and toppings. Complete your tasklist and unlock achievements!","category":"Arcade","tags":["junior","puzzles"],"thumbnail":"https://games.assets.gamepix.com/U8R5E/thumbnail/small.png","url":"https://play.gamepix.com/yummy-churros-ice-cream/embed?sid=1","plays":40763,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"21DBU","slug":"bunny-graduation-double","title":"Bunny Graduation Double","description":"Two cute blue and purple bunnies escape from the forest. They must escape from the forest because everything is getting snow white more and more. they need to reach the guard at the end of each level reach the guard and pass the levels!  \n\nHow to Play?\n*Purple Rabbit Control : WASD  \n*Blue Rabbit Control : Arrow Keys  \n*Double Jump Available","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/21DBU/thumbnail/small.png","url":"https://play.gamepix.com/bunny-graduation-double/embed?sid=1","plays":40760,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"GK233","slug":"street-food-cooking-game","title":"Street Food - Cooking Game","description":"Welcome to Street Food - cooking games the number one free cooking games in the world that puts you in charge of your own street food truck & become a kitchen chef!\n\nBe a master chef of street food and start cooking delicious snacks in this virtual cooking games. There are hot dogs van, pizza van, hamburgers van, French fries van and nachos van! Which one do you want to try first? They all look so yummy! Let's cook the yummy & delicious street food with add some amazing toppings on them so they look as good as the taste. You will love playing chef free cooking games as you make your favorite foods, and you'll love that cooking up a chef quality snack doesn't mess up your whole kitchen!","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/GK233/thumbnail/small.png","url":"https://play.gamepix.com/street-food-cooking-game/embed?sid=1","plays":40749,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"SEA12","slug":"funny-shopping-supermarket","title":"Funny Shopping Supermarket","description":"Help Hippo n friends to find all products in their shopping list. There are lists of goods you must find. Pick and put them to their grocery bags. Don't forget to go to the cashier to pay! Funny Shopping Supermarket sells varieties of products: vegetables, candies, clothes, fruits, meats, n carpentry tools. Unlock the achievements, have fun and enjoy the game!\n","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/SEA12/thumbnail/small.png","url":"https://play.gamepix.com/funny-shopping-supermarket/embed?sid=1","plays":40746,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40164","slug":"paper-craft-wars","title":"Paper Craft Wars","description":"Envahis les bâtiments ennemis pour gagner la bataille! Rassemble une armée de chats, de taureaux ou de renards dans Paper Craft Wars. Au début de chaque querelle, toutes tes troupes gardent un bâtiment. Déploie tes forces pour contrôler tout le champ de bataille!","category":"Stratégie","tags":["strategy"],"thumbnail":"https://games.assets.gamepix.com/40164/thumbnail/small.png","url":"https://play.gamepix.com/paper-craft-wars/embed?sid=1","plays":40737,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"0CEE0","slug":"tactical-penguin","title":"Tactical Penguin","description":"Help the penguins not to starve!🥴\n\nThis game is inspired to the classic Missile Command gameplay.\nDefend your fishies from the pelicans, the penguins will starve if there are not at least 5 fishies.\nWhen the missile is armed by one penguin, simply click to aim at pelican is in a dive, but be careful to blizzard and the wind that affects the flight path.\n\nhave fun!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/0CEE0/thumbnail/small.png","url":"https://play.gamepix.com/tactical-penguin/embed?sid=1","plays":40710,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40427","slug":"drop-dunks","title":"Drop Dunks","description":"Slide your finger to guide the falling balls into the hoop. How many balls can you get?","category":"Puzzle","tags":["arcade","sports"],"thumbnail":"https://games.assets.gamepix.com/40427/thumbnail/small.png","url":"https://play.gamepix.com/drop-dunks/embed?sid=1","plays":40709,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"O1DI7","slug":"quiz-squid-round","title":"Quiz Squid Round","description":"Quiz Squid Game is a trivia-style game to see if the player has paid attention to the details of the series, let's go show us your best!","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/O1DI7/thumbnail/small.png","url":"https://play.gamepix.com/quiz-squid-round/embed?sid=1","plays":40709,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"1N274","slug":"knives","title":"Knives","description":"Knives - Extreme - arcade game in which you will throw knives on a rotating surface, trying not to get into knives. Put your record in this addictive arcade!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/1N274/thumbnail/small.png","url":"https://play.gamepix.com/knives/embed?sid=1","plays":40709,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"526A7","slug":"moto-maniac-3","title":"Moto Maniac 3","description":"This is a tilty bike game that will challenge your trial skills to the max. The trial competition is set up in the forest, so be ready to climb over trees and rocks. Your main goal is to overcome all the obstacles as fast as you can. But there is a second (yet important) goal - a wild bear was annoyed by the loud engine sounds and it is chasing you, so be quick not to be caught by the beast!","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/526A7/thumbnail/small.png","url":"https://play.gamepix.com/moto-maniac-3/embed?sid=1","plays":40704,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"9NGW6","slug":"swimming-pool-romance","title":"Swimming Pool Romance","description":"Lucas is looking for a girl, obviously, at the swimming pool. And he find one, Natasha. She's so cute, he can't resist. Help him attract her with his mojo so they can spend a romantic evening together!","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/9NGW6/thumbnail/small.png","url":"https://play.gamepix.com/swimming-pool-romance/embed?sid=1","plays":40696,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"9618T","slug":"catch-cats","title":"Catch Cats","description":"Welcome to Catch Cats, have fun in this fantastic game where you have to catch all the cats to increase your best score, what are you waiting for? go and play catch cats and the fun will be guaranteed !!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/9618T/thumbnail/small.png","url":"https://play.gamepix.com/catch-cats/embed?sid=1","plays":40692,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40093","slug":"little-bouncing-guys","title":"Little Bouncing Guys","description":"La tribu des petits hommes-gommes s'est perdue…en laissant un de ses membres derrière elle! Aidez-le à rejoindre les siens, faites-le sauter toujours plus fort et toujours plus haut. Utilisez votre adresse et votre intelligence pour venir à bout des 30 niveaux qui attendent ce petit homme gomme!","category":"Arcade","tags":["adventure","classics"],"thumbnail":"https://games.assets.gamepix.com/40093/thumbnail/small.png","url":"https://play.gamepix.com/little-bouncing-guys/embed?sid=1","plays":40688,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"3AHG1","slug":"hill-racing","title":"Hill Racing","description":"Hill Racing! Race your way uphill            \nIf you're looking for a racing game that does what it takes to be classic, Hill Racing! is the game for you. In Hill Racing, you race your way uphill towards the finish line with plenty of challenges in between! This physics-based game is perfect for those who love to race their cars, and we know how you feel: we've put together a full game cassette containing all the tools you need to drive these hills!            \nIn Hill Racing, you take on the challenge of driving your way uphill in order to reach the top of the hill. The game features a variety of unique hill climbing environments, as well as different cars that can be upgraded with coins and tricks. You'll need to use your skills and luck to make it to the top, and beware of obstacles along the way!            \n","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/3AHG1/thumbnail/small.png","url":"https://play.gamepix.com/hill-racing/embed?sid=1","plays":40688,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"66LT1","slug":"music-tools","title":"Music Tools","description":"Play music on three instruments, piano, drums, and guitar.\nBecome a pro musician by learning and playing all the instruments and have a fun time by playing online.\nJust use your skills and show them here online and play more games here only with Mapi Games.","category":"Arcade","tags":["classics"],"thumbnail":"https://games.assets.gamepix.com/66LT1/thumbnail/small.png","url":"https://play.gamepix.com/music-tools/embed?sid=1","plays":40687,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"34I2O","slug":"big-donuts-mania","title":"Big Donuts Mania","description":"Big Donuts Mania is all about these ring-shaped sweets. In this fun and addictive game, you need to match a combination of 3 donuts or \nmore. You simply need to swap donuts position by tapping or dragging them. Sounds \nIf you've made a match, the donuts will be clear, and you will get the points! The more \nyou get, the better you will rank in the high score.\nWarning: Big Donuts Mania is as addictive as a box of donuts!","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/34I2O/thumbnail/small.png","url":"https://play.gamepix.com/big-donuts-mania/embed?sid=1","plays":40685,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"NRSET","slug":"funny-rescue-carpenter","title":"Funny Rescue Carpenter","description":"Leia is a great carpenter, but even the best will get accidents sometimes. Let's play and rescue Leia from the horrible accident! Help her recover from the wounds and have fun!","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/NRSET/thumbnail/small.png","url":"https://play.gamepix.com/funny-rescue-carpenter/embed?sid=1","plays":40672,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"3A434","slug":"yummy-toast","title":"Yummy Toast","description":"Yummy Toast is the funnest cooking game ever!\nYour goal is to make delicious toast by tapping the correct materials and ingredients u needed. Make the tastiest toast and serve to ur customers. Be the best toast master and to unlock all the achievements!","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/3A434/thumbnail/small.png","url":"https://play.gamepix.com/yummy-toast/embed?sid=1","plays":40668,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40401","slug":"basketball-master-2","title":"Basketball Master 2","description":"Play through the 40 challenging levels and try to solve physics based puzzles. You’ll need to avoid solid obstacles, players, smash through glass and wood and figure out how to put the ball through the hoop!","category":"Puzzle","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/40401/thumbnail/small.png","url":"https://play.gamepix.com/basketball-master-2/embed?sid=1","plays":40668,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"89M21","slug":"bike-mania-2","title":"Bike Mania 2","description":"The most famous bike game of the flash era is back! Tilt and balance your way over the obstacles. Containing 20 levels of sheer frustration and \"just one more go\" addictiveness, Bike Mania 2 is the ultimate in driving games for those who like a challenge.","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/89M21/thumbnail/small.png","url":"https://play.gamepix.com/bike-mania-2/embed?sid=1","plays":40661,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"R4VUG","slug":"comics-456-survival-game","title":"Comics 456 - Survival Game","description":"🧩 Comics 456 - Squid Survival Game - Mind-bending erase game and fun comedy!\n\nComics 456 - S-quid Survival Game is an erase game full of comedy stories. Comics 456 - Squid Story is created to bring you the story of the player 456 trying to pass all challenged to be the last survivor and reach 45.6 billion won. In each level, you will laugh out loud with classic but funny scenes of the K-drama.\n\nWhat are you waiting for? 👀 👀\nDownload Comics 456 - Survival Game and discover the unexpected twists 🔥🔥\n","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/R4VUG/thumbnail/small.png","url":"https://play.gamepix.com/comics-456-survival-game/embed?sid=1","plays":40660,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"AO2ID","slug":"a-day-in-the-countryside","title":"A day in the countryside","description":"A pleasant and relaxing day in the countryside?\nYou will play the role of a farmer struggling with the cultivation of his fields... and some funny and spiteful animals.\n\nMOVE:\n- Use arrow keys\n- Click or touch and hold on left/right of the character\n\nACTIONS:\n- Click or touch in the animals, something will happen\n- Use mouse wheel to zoom\n- In winter, click or touch on the screen to jump​ \n\nHOW TO PLAY\n- Take the moles and send them to sleep\n- Take the blackbirds with bomb and send them away\n- Feed the cute animals for an extra life\n- In winter, save snowmen from snowballs","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/AO2ID/thumbnail/small.png","url":"https://play.gamepix.com/a-day-in-the-countryside/embed?sid=1","plays":40659,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"O8O7P","slug":"bloxdhop","title":"BloxdHop","description":"Play through parkour inspired obbys and make your way to the end of the maps! Twist, turn, run and jump your way through large themed worlds - all without falling to your demise. Race to the end, get a high score and earn gold while doing so.\n\n\nControls:\n\nWASD - movement\nShift - Run (alternately, double tap w)\nCrouch - C (alternately, Z, | or CAPS LOCK)\nChat - T or ENTER\nOpen Shop - B\nStart command - /\n\nCommands:\n\n/rtv - not a fan of this map? Vote to skip it!\n/players - see the current players in your lobby.\n/xp - See your level and xp.\n/played - See how much time you've spent having tons of fun.\n","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/O8O7P/thumbnail/small.png","url":"https://play.gamepix.com/bloxdhop/embed?sid=1","plays":40652,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"B0209","slug":"daddy-rabbit","title":"Daddy Rabbit","description":"Daddy Rabbit must find all his lost babies inside the most amazing underground burrow you've ever seen. These baby rabbits sleep peacefully everywhere, but when daddy rabbit passes by, they will follow him all the way.    \nBaby bunnies will follow dad but will cry if they are awake and his dad wanders too far. When that happens, the zombies will get upset and go straight to eat them. That's when daddy rabbit will defend his sons with a carrot punch and give those evil zombies what they deserve. ","category":"Stratégie","tags":["adventure","strategy"],"thumbnail":"https://games.assets.gamepix.com/B0209/thumbnail/small.png","url":"https://play.gamepix.com/daddy-rabbit/embed?sid=1","plays":40650,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"S5L11","slug":"basketball","title":"BasketBall","description":"Let’s experience the Retro Style Basketball in 3D. Start shooting the ball and score as much as you can.\nThere are 3 deadly challenging modes to make you addictive with Basketball action game.\n\n1. Time Attack\n2. Sudden Death\n3. Challenge\n\nIt’s time to dribble, shoot, score, WIN! Choose the ball and head to the basketball court for some awesome shoots. Flick the ball towards the basket to take a shot and feel the fun on playing real basketball. Basketball 3D is an awesome real feel game which can really challenge your shooting skills.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/S5L11/thumbnail/small.png","url":"https://play.gamepix.com/basketball/embed?sid=1","plays":40648,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40236","slug":"master-checkers","title":"Master Checkers","description":"Master Checkers is the best Board Game. Play this stylish version ot the classic board game Checkers.\nThe game is based on the Italian Checkers gameplay!","category":"Puzzle","tags":["casino","classics","puzzles"],"thumbnail":"https://games.assets.gamepix.com/40236/thumbnail/small.png","url":"https://play.gamepix.com/master-checkers/embed?sid=1","plays":40648,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"SCM86","slug":"carmiss","title":"CarMiss","description":"A great action game with you. You have to dodge the attacks with the car you have. They are attacking missiles from all sides. You can get yourself a new and faster vehicle by collecting gold while escaping. If you wish, you can increase the protection of the vehicle with gold or you can strengthen the protection shield by purchasing an anti-rocket gun. To destroy the rockets, you have to collide them with each other.","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/SCM86/thumbnail/small.png","url":"https://play.gamepix.com/carmiss/embed?sid=1","plays":40639,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40079","slug":"cowboy-vs-martians","title":"Cowboy VS Martians","description":"Les martiens ont débarqué sur terre et ils n'ont pas l'air de venir en amis! Attrapez votre fusil, peignez votre belle moustache et commencez à les dézinguer! Serez-vous le cowboy qui les abattra tous ?","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/40079/thumbnail/small.png","url":"https://play.gamepix.com/cowboy-vs-martians/embed?sid=1","plays":40635,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40126","slug":"panda-hair-do","title":"Panda Hair-do","description":"Vous aimez les pandas ? Cette jeune fille les adore mais ce qu'elle aime encore plus, c'est de prendre soin de son apparence! Aidez-la à s'occuper de ses cheveux, à s'habiller et à se préparer à passer une super journée. Commencez déjà par lui laver les cheveux avant de passer à la suite!","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/40126/thumbnail/small.png","url":"https://play.gamepix.com/panda-hairdo/embed?sid=1","plays":40634,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"6PD09","slug":"car-rapide","title":"Car Rapide","description":"Drive and avoid obstacles on the roads of Senegal.\nCollect coins and unlock special cars!","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/6PD09/thumbnail/small.png","url":"https://play.gamepix.com/car-rapide/embed?sid=1","plays":40632,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"748S4","slug":"endless-car-chase","title":"Endless Car Chase","description":"Préparez-vous à une montée d'adrénaline ultime avec Endless Car Chase, le jeu rapide qui vous met derrière le volant d'une course-poursuite à grande vitesse ! Collectez de l'argent et des power-ups alors que vous foncez à travers les rues de la ville, mais attention à la police qui est à vos trousses. Avec des contrôles faciles à utiliser et un gameplay addictif, ce jeu est prêt à jouer directement hors de la boîte. Mais pourquoi se contenter de l'expérience par défaut quand vous pouvez personnaliser le jeu selon vos préférences ? Modifiez l'environnement, les voitures, et même la musique pour créer une expérience de jeu unique et personnalisée. Préparez-vous à semer la loi et devenir le meilleur pilote de fuite dans Endless Car Chase !","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/748S4/thumbnail/small.png","url":"https://play.gamepix.com/endless-car-chase/embed?sid=1","plays":40626,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"7300A","slug":"parmesan-partisan","title":"Parmesan Partisan","description":"You are the last defence, you are a lonely cheesy partisan who has to protect his people from the menace of the Mice People, who wants to conquer an eat all the cheese they can find! You are the last hope of your people: defend them with your shotgun, kill as many rats as you can, and free your nation from the rodents conquerors!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/7300A/thumbnail/small.png","url":"https://play.gamepix.com/parmesan-partisan/embed?sid=1","plays":40623,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"U2G53","slug":"bowling-hero-multiplayer","title":"Bowling Hero Multiplayer","description":"\"Compete with your friends on the same device or with other players from all over the world.\n\nChoose a hero from the six available.\n\nThrow the ball and shoot down as many pins as possible!\n\nHow many strikes will you hit?\"","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/U2G53/thumbnail/small.png","url":"https://play.gamepix.com/bowling-hero-multiplayer/embed?sid=1","plays":40619,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40436","slug":"mafia-billiard-tricks","title":"Mafia Billiard Tricks","description":"Mafia Billiard Tricks is a billiard arcade game in which you can play the challenging game of billiards. You are not only playing for fun though; your opponents are part of the infamous mafia. You must earn their respect by beating each crew member!","category":"Arcade","tags":["classics","sports","strategy"],"thumbnail":"https://games.assets.gamepix.com/40436/thumbnail/small.png","url":"https://play.gamepix.com/mafia-billiard-tricks/embed?sid=1","plays":40619,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"I6ST5","slug":"cross-the-bridge","title":"Cross the Bridge","description":"In this fun game you must try to complete the path for the car to pass before time runs out, agility and reasoning are a good combination for this game.","category":"Stratégie","tags":["strategy"],"thumbnail":"https://games.assets.gamepix.com/I6ST5/thumbnail/small.png","url":"https://play.gamepix.com/cross-the-bridge/embed?sid=1","plays":40612,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"L35GT","slug":"nastya-cute-blogger","title":"Nastya Cute Blogger","description":"Cute Nastya is a very popular blogger. Her mom and dad help her make cool videos. In this episode, Nastya's family will decorate the house for the holiday, and Nastya herself will choose stylish outfits and help her dad turn into a glamorous fairy. Let's join her and master her makeup skills. Have fun with cute blogger Nastya!","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/L35GT/thumbnail/small.png","url":"https://play.gamepix.com/nastya-cute-blogger/embed?sid=1","plays":40611,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"RO492","slug":"run-gun-robots","title":"Run Gun Robots","description":"Run Gun Robots is a run and gun game, where you have to jump from building to building destroying aggressive robots and avoiding deadly traps. Earn money buy defeating enemies and buy new powerups to to better address this new threat.\n\nControls:\nMobile: Touch the button on the screen to Jump, Shoot or pass trough a platform.\nKeyboard: W or Up to jump, X or Spacebar to shoot, S or Down to pass trough a platform\nGame pad: A or LT to Jump, B or RT to shoot, D-pad Down to pass trough a platform\n\n-4 different enemies\n-10 levels with increasing difficulty\n- Engaging music","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/RO492/thumbnail/small.png","url":"https://play.gamepix.com/run-gun-robots/embed?sid=1","plays":40610,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40080","slug":"fantasy-star-pinball","title":"Fantasy Star Pinball","description":"Atteignez les sommets du high score dans ce magnifique jeu de flipper fantasy en 3D! Shootez la boule, et trouvez les scénarios cachés pour booster vos points.","category":"Arcade","tags":["arcade","puzzles"],"thumbnail":"https://games.assets.gamepix.com/40080/thumbnail/small.png","url":"https://play.gamepix.com/fantasy-star-pinball/embed?sid=1","plays":40598,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"146AA","slug":"maga-run","title":"MAGA run","description":"Le président sortant doit s'échapper du FBI.\nTrouve les bulletins de vote perdus, collecte suffisamment d'argent et utilise Twitter pour réussir.\nPeut-être peux tu regagner ta présidence?","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/146AA/thumbnail/small.png","url":"https://play.gamepix.com/maga-run/embed?sid=1","plays":40598,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"TAPQO","slug":"two-impostor-squid-challenge","title":"Two Impostor Squid Challenge","description":"Are you ready for the two impostor squid challenge game that you can play with your friend for two? Play with your friend in two player green light red light game and tug of war game.\n\nHow to Play?\nBlue Player \"A\" Press Key & Mobile Touch Control / Red Player \"P\" Press Key & Mobile Touch Control","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/TAPQO/thumbnail/small.png","url":"https://play.gamepix.com/two-impostor-squid-challenge/embed?sid=1","plays":40596,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"064S4","slug":"crossword","title":"Crossword","description":"Solve thousands of crossword puzzles for free, no subscription required!\nSolving crosswords is like mental excercise, it's challenging and relaxing at the same time. Let’s get solving! Play  \"Crossword\" now and join the thousands of crossword enthusiasts!","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/064S4/thumbnail/small.png","url":"https://play.gamepix.com/crossword/embed?sid=1","plays":40594,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"CEE94","slug":"office-io","title":"Office.io","description":"Office.io is an office simulator game in which you are the boss. Hire employees and accept or deny their requests. Be careful! Your decisions will make your employees happy or sad. If motivation is too low, employees will do crazy things!","category":"Stratégie","tags":["arcade","strategy"],"thumbnail":"https://games.assets.gamepix.com/CEE94/thumbnail/small.png","url":"https://play.gamepix.com/office-io/embed?sid=1","plays":40593,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40147","slug":"astro-digger","title":"Astro Digger","description":"Astro Digger est un jeu d'arcade solo fun et addictif qui se joue avec les flèches de votre clavier ou simplement au doigt. Faites la connaissance de Astro Digger, le mineur de l'espace, et aidez-le à accomplir sa tâche en récupérant de l'or et des minerais sur les plus gros astéroïdes. Attention car il y a de grandes distractions sur le chemin, alors utilisez les téléporteurs et plantez des bombes si vous vous retrouvez coincé.","category":"Arcade","tags":["arcade","adventure"],"thumbnail":"https://games.assets.gamepix.com/40147/thumbnail/small.png","url":"https://play.gamepix.com/astro-digger/embed?sid=1","plays":40591,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40423","slug":"rabbit-samurai","title":"Rabbit Samurai","description":"Rabbit Samurai is on a big adventure to help his Sensei. Your goal is to find all mice and rescue them from the wolf's lair. Use the rope and sticking grappling hook to fly over the land. Launch yourself from the ninja cannon, collect all carrots and find hidden crystals. Avoid dangerous spikes!","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/40423/thumbnail/small.png","url":"https://play.gamepix.com/rabbit-samurai/embed?sid=1","plays":40590,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"6778N","slug":"candy-bubble","title":"Candy Bubble","description":"Amazing candy bubble buster game comes, it's the best Bubble\nShooter with amazing effects! Your goal is to match groups of three or more same-colored candy bubbles to clear the playing field; use the least small ball to end level.\nUse the superb technique to break in one fell swoop, and experience the happiness of success!","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/6778N/thumbnail/small.png","url":"https://play.gamepix.com/candy-bubble/embed?sid=1","plays":40590,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"7R19C","slug":"one-card-game","title":"ONE Card Game","description":"Le jeu amusant et passionnant ONE vous manque ? Ou bien peut-être vous n’avez pas joué à ce jeu merveilleux auparavant ? Alors allez-y, sélectionnez un personnage et participez à des batailles amicales remarquables. Vous aurez une atmosphère parfaite de jeu, des règles détaillées, une gestion facile et plusieurs adversaires intéressants qui sont prêts à vous tenir compagnie à tout moment.","category":"Stratégie","tags":["board"],"thumbnail":"https://games.assets.gamepix.com/7R19C/thumbnail/small.png","url":"https://play.gamepix.com/one-card-game/embed?sid=1","plays":40586,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"642G0","slug":"my-golf","title":"My Golf","description":"Do you like golf? Try one shot hole in My Golf, unlock new levels and new balls by completing the world with all the stars... ","category":"Sport","tags":["arcade","classics","sports"],"thumbnail":"https://games.assets.gamepix.com/642G0/thumbnail/small.png","url":"https://play.gamepix.com/my-golf/embed?sid=1","plays":40583,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"NL9HE","slug":"spear-toss-challenge","title":"Spear Toss Challenge","description":"How far can you throw a spear?","category":"Sport","tags":["sports","arcade"],"thumbnail":"https://games.assets.gamepix.com/NL9HE/thumbnail/small.png","url":"https://play.gamepix.com/spear-toss-challenge/embed?sid=1","plays":40581,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"444E0","slug":"towerland","title":"Towerland","description":"Towerland is a top-down shooter with game mechanics inspired by the famous Binding of Isaac.\nFeatures:\n-Dozen of monsters\n-Unlockable Powerups\n-3 Different game modes\n-3 Bosses\n\nGAME CONTROLS\n\nKeyboard:\n\nWASD to move\n\nArrow Keys to Shoot\n\nP to Pause the game\n\nGamepad:\n\nLeft Analog / D-pad Move\n\nRight Analog / XYBA to Shoot\n\nStart/Menu to Pause the game\n\n","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/444E0/thumbnail/small.png","url":"https://play.gamepix.com/towerland/embed?sid=1","plays":40580,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"FE9I1","slug":"soldiers-fury","title":"Soldiers Fury","description":"C'est la guerre ! Et en tant que soldat d'élite, vous avez des missions à accomplir ! Foncez, récupérez des armes et des bonus, et tirez sur tous les ennemis en tentant de survivre ! Améliorez votre arsenal et laissez libre cours à votre fureur ! Les soldats ennemis ne cessent d'arriver par vagues, mais vous pouvez utiliser votre environnement.\n","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/FE9I1/thumbnail/small.png","url":"https://play.gamepix.com/soldiers-fury/embed?sid=1","plays":40580,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"20","slug":"sweet-monsters","title":"Sweet Monsters","description":"Sweet Monsters est un jeu de Parkour en 2d qui vous fera courir et sauter des tonnes d'obstacles pour déguster des friandises. Le but n'est pas forcément d'aller le plus loin possible, car plus vous mangerez, plus vous ferez de combos et boosterez votre score pour obtenir des récompenses. Plus vous jouerez, plus la difficulté augmentera. Etes-vous prêt à relever le défi?","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/20/thumbnail/small.png","url":"https://play.gamepix.com/sweet-monsters/embed?sid=1","plays":40577,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"1T124","slug":"hit-master","title":"Hit Master","description":"Are you ready to become a hero, spy, and legend? Solve puzzling challenges, show off your deadly accuracy and take aim at the enemies. Come experience the shooting phenomenon.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/1T124/thumbnail/small.png","url":"https://play.gamepix.com/hit-master/embed?sid=1","plays":40570,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"AP482","slug":"perfect-car-parking","title":"Perfect Car Parking","description":"Perfect Car Parking game created specially for whom wants to park car very carefully. \n\nAre you annoyed by all the similar parking games, and lack of high quality graphics and uniqueness? Are you looking forward to have a new car parking to park your vehicle as much as you want? We know you are here with a hope to find a game that suits you perfectly.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/AP482/thumbnail/small.png","url":"https://play.gamepix.com/perfect-car-parking/embed?sid=1","plays":40570,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"1RR76","slug":"rope-draw","title":"Rope Draw","description":"Rope draw is a puzzle game in wich you will push ropes to make new arrangements with them. Your objective is to copy the arrangement that will appear above. If needed, there is a hint button that will show you the first moves. There are 120 different levels and the 'Fun' mode (unlocked after beating level 40), in which you can insert new ropes or even push them as you wish.","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/1RR76/thumbnail/small.png","url":"https://play.gamepix.com/rope-draw/embed?sid=1","plays":40569,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"66EE6","slug":"airspace2","title":"AirSpace2","description":"Bienvenue dans Airspace, passez tous les astéroïdes sans détruire votre vaisseau, marquez des points en prenant toutes les sphères bleues, qu'attendez-vous ?? Allez jouer à Airspace maintenant et le plaisir sera garanti !!!!","category":"Arcade","tags":["strategy"],"thumbnail":"https://games.assets.gamepix.com/66EE6/thumbnail/small.png","url":"https://play.gamepix.com/the-escape/embed?sid=1","plays":40567,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"6EMO6","slug":"design-my-home-makeover","title":"Design My Home Makeover","description":"Home Design est une passion, et si vous voulez transformer les rêves en réalité en aidant les familles chanceuses à concevoir une maison de rêve. Ce jeu de conception de maison - Dream House Makeover est un gameplay parfait avec un mode hors ligne de plaisir relaxant sans fin pour transformer des maisons obsolètes en un magnifique manoir familial. Vous pouvez redessiner un beau manoir en rénovant la maison et en la relookant en concevant et en restaurant pour concevoir et décorer ma maison de chacun de vos clients.","category":"Arcade","tags":["classics","junior"],"thumbnail":"https://games.assets.gamepix.com/6EMO6/thumbnail/small.png","url":"https://play.gamepix.com/design-my-home-makeover/embed?sid=1","plays":40567,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"9G14G","slug":"gems-swipe","title":"Gems Swipe","description":"gems swipe is an html5 match 3 game, match gems and execute and get the highest score ","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/9G14G/thumbnail/small.png","url":"https://play.gamepix.com/gems-swipe/embed?sid=1","plays":40567,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"49311","slug":"infinity","title":"Infinity","description":"Welcome to Infinity, you control your character, avoid the red apples and collect the yellow ones to accumulate points, what are you waiting for, go now to play Infinity and the fun is guaranteed !!!!!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/49311/thumbnail/small.png","url":"https://play.gamepix.com/infinity/embed?sid=1","plays":40567,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"PAN42","slug":"ninja-in-cape","title":"Ninja in Cape","description":"Are you ready for adventure with the ninja in cape?\nA journey full of action and adrenaline awaits you!\nThere are 20 adventurous levels for you to play without breathing.\nYou have weapons that you can use against enemies.\nLet's start the adventure now and complete the levels!","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/PAN42/thumbnail/small.png","url":"https://play.gamepix.com/ninja-in-cape/embed?sid=1","plays":40567,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"KT6O8","slug":"retro-basketball","title":"Retro Basketball","description":"Retro Basketball a fun sport game to play on.\nThis basket ball game gives always fun to play.\nThis is the game just to throw as many balls as you can and achieve high score.\nAim the ball exactly in the basket and achive goal.","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/KT6O8/thumbnail/small.png","url":"https://play.gamepix.com/retro-basketball/embed?sid=1","plays":40567,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"15S18","slug":"sea-rush","title":"Sea Rush","description":"Utilisez votre imagination et découvrez ce que renferme l'océan. Sauvez tous les poissons dispersés à travers les niveaux et admirez toutes leurs belles couleurs.\n","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/15S18/thumbnail/small.png","url":"https://play.gamepix.com/sea-rush/embed?sid=1","plays":40567,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"IA1AO","slug":"mad-mad-unicorn","title":"Mad Mad Unicorn","description":"Mad Mad Unicorn is a game about a nasty flying unicorn who is out for blood!\nHelp him in is hell race against poor and defenceless birds!\nBut the humankind won't let this evil unicorn do whatever he wants: they will try to shoot him down with powerful misseles launched from any direction!\nMaybe a magic carrot will give him the power to whitstand those deadly weapons...\n\nFEATURES:\n- One endless sky level with increasing difficulty\n- 10 artworks to unlock\n- Achievements\n- A crazy flying unicorn\n- Misseles, explosive birds, and other funny visual effects\n- One Touch game controls.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/IA1AO/thumbnail/small.png","url":"https://play.gamepix.com/mad-mad-unicorn/embed?sid=1","plays":40565,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"77F6O","slug":"fireblob-winter","title":"FireBlob Winter","description":"Sequel to FireBlob, now with more levels and detail, better graphics, new puzzles, speedrun mode, and a final boss battle!\n\nFireBlob is a Platform-Puzzle game where you command a small fireball in order to reach and ignite a wood fire; use the ball's heat abilities to melt the ice or use some level objects to help her to complete his task. ","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/77F6O/thumbnail/small.png","url":"https://play.gamepix.com/fireblob-winter/embed?sid=1","plays":40559,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40115","slug":"tic-tac-toe-html5","title":"Tic Tac Toe HTML5","description":"Retrouvez le célèbre \"Morpion\" en version HTML5 et profitez de nouveau modes de jeu en 3X3, 5X5 et même 7X7 où vous devrez remplir 4 cases au lieu de 3!","category":"Stratégie","tags":["board","classics","puzzles"],"thumbnail":"https://games.assets.gamepix.com/40115/thumbnail/small.png","url":"https://play.gamepix.com/tic-tac-toe-html5/embed?sid=1","plays":40554,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40447","slug":"superstar-kitty-fashion-award","title":"Superstar Kitty Fashion Award","description":"Express your fashion and unique style to transform your little kitty in real beauty like a superstar in this amazing Superstar Kitty Fashion Award game with new hairstyles and fabulous makeover. Start with a spa treatment for a lovely facial and make her skin smooth, shinny, and glowing to look good at the award show.","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/40447/thumbnail/small.png","url":"https://play.gamepix.com/superstar-kitty-fashion-award/embed?sid=1","plays":40550,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"16645","slug":"2048-hex-chain-merge","title":"2048 Hex Chain Merge","description":"248 merge is an amazing block merge game.\n ","category":"Stratégie","tags":["strategy"],"thumbnail":"https://games.assets.gamepix.com/16645/thumbnail/small.png","url":"https://play.gamepix.com/2048-hex-chain-merge/embed?sid=1","plays":40549,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"E23EK","slug":"bike-mania-3-on-ice","title":"Bike Mania 3 On Ice","description":"Slip and slide your way through 20 levels of classic Bike Mania action! Frustration, adrenaline and the potential for a broken keyboard all await you as you take on the original and the best bike trail game of all time!","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/E23EK/thumbnail/small.png","url":"https://play.gamepix.com/bike-mania-3-on-ice/embed?sid=1","plays":40546,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"SMMM1","slug":"456-impostor","title":"456 impostor","description":"You are astronaut number \"456\" trying to survive in space. Your only solution is to destroy the men in the red suits. you have to jump on them and crush them to destroy them. destroy them and reach the final level. every 10 levels there is an endless run and men in red suits you have to kill.\n\nHow to Play\nWASD + Mobile Touch Control","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/SMMM1/thumbnail/small.png","url":"https://play.gamepix.com/456-impostor/embed?sid=1","plays":40544,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"36BI9","slug":"brick-breaker-retro","title":"Brick Breaker Retro","description":"Welcome to the Brick Breaker Retro. If you like breaking bricks, this is your game. Will you be able to overcome all the levels? What about getting the highest score?\n\nEvery time you pass four levels, you can unlock the next ones and continue from there, although you can also start from the beginning to obtain a higher score.","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/36BI9/thumbnail/small.png","url":"https://play.gamepix.com/brick-breaker-retro/embed?sid=1","plays":40543,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"C8S62","slug":"soccer-heroes","title":"Soccer Heroes","description":"Show all your skill in this football game. Choose your dream team and get into the fast-paced football action where you control um jogador. You can score goals with just a swipe of your finger or mouse. You are in charge of both the offense and the defense in this game, so you have to be quick to gain the upper hand.\n\nInstructions:\nTouch and drag your player to move.\nUse your player to attack and defend the goal.","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/C8S62/thumbnail/small.png","url":"https://play.gamepix.com/soccer-heroes/embed?sid=1","plays":40542,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"20066","slug":"broom","title":"Broom","description":"Broom est un jeu de course en pixel art qui vous fera traverser une autoroute sans fin. Utilisez vos super réflexes à bon escient pour exploser votre high score. Plongez dans un univers minimaliste et hyper arcade, et confrontez-vous à une difficulté de jeu très élevée!","category":"Sport","tags":["arcade","sports"],"thumbnail":"https://games.assets.gamepix.com/20066/thumbnail/small.png","url":"https://play.gamepix.com/broom/embed?sid=1","plays":40538,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"4NOI1","slug":"noob-vs-stickman-zombies","title":"Noob vs Stickman Zombies","description":"Noob vs Stickman Zombies un matin d'été tranquille, alors que Noob dormait encore doucement dans sa cabane confortable, quelqu'un a allumé une musique assourdissante qui a fait trembler toute la maison. Quand il est sorti, il a découvert que juste à côté de lui, un groupe de Stickmen organisait une soirée dansante féroce, comme s'il essayait exprès de l'ennuyer. Dans un accès de rage, Noob retira son arc du mur pour venger sa journée gâchée et instruire tous ceux qui osaient troubler sa tranquillité ! \"Noob vs Stickman Zombies\" est un jeu d'arcade amusant avec une histoire intéressante dans laquelle vous devez donner une leçon aux voisins ennuyeux !","category":"Puzzle","tags":["arcade","puzzles"],"thumbnail":"https://games.assets.gamepix.com/4NOI1/thumbnail/small.png","url":"https://play.gamepix.com/noob-vs-stickman-zombies/embed?sid=1","plays":40537,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40161","slug":"glauron-dragon-tales","title":"Glauron: dragon tales","description":"Glauron, le premier né du clan des Dragons Ailés, s'est finalement échappé de sa prison dans laquelle il était retenu depuis 500 ans! Bien sûr il souhaite se venger et vous allez pouvoir l'aider en répandant chaos et désolation parmi les citoyens innocents...mais méfiez-vous car ces derniers sont armés et tenteront de se défendre!","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/40161/thumbnail/small.png","url":"https://play.gamepix.com/glauron-dragon-tales/embed?sid=1","plays":40535,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"20065","slug":"zombie-invasion","title":"Zombie Invasion","description":"Plongez dans Zombie Invasion, le jeu de survie par excellence. Survivez à la horde zombie aussi longtemps que vous le pouvez et empêchez-les de traverser le pont. A chaque zombie qui passe entre les mailles de votre défense, vous perdez des points d'énergie. Prenez soin de ne pas blesser les survivants et éliminez tous les zombies!","category":"Aventure","tags":["arcade","adventure"],"thumbnail":"https://games.assets.gamepix.com/20065/thumbnail/small.png","url":"https://play.gamepix.com/zombie-invasion/embed?sid=1","plays":40533,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"ENTOS","slug":"monster-popsy-dolls","title":"Monster Popsy Dolls","description":"Rencontrez un monstre incroyable-popsy. Ces jouets sont à la fois beaux et terribles! Choisissez parmi une variété de coiffures et de tenues pour créer votre propre poupée unique. Utilisez vos compétences de maquilleur pour choisir le bon maquillage pour votre popsy. Essayez des robes, des hauts, des vestes en cuir, des bottes et des bijoux amusants.","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/ENTOS/thumbnail/small.png","url":"https://play.gamepix.com/monster-popsy-dolls/embed?sid=1","plays":40524,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"2S2KM","slug":"clash-of-kingdom","title":"Clash of Kingdom","description":"Clash of Kingdom is a free online game featuring a war among kingdoms. Now, it’s not just the fun games on the computer that you can enjoy completely free \nIf you are looking for an amazing game to play this weekend, I can highly recommend Clash of Kingdom. This game is wonderful and all types of people can enjoy it, rich or poor, beginner or the most experienced gamer out there.","category":"Stratégie","tags":["strategy"],"thumbnail":"https://games.assets.gamepix.com/2S2KM/thumbnail/small.png","url":"https://play.gamepix.com/clash-of-kingdom/embed?sid=1","plays":40523,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"44NA6","slug":"ant-maze","title":"Ant Maze","description":"A leading ant must find his way home, for that he must eliminate the enemy blue ants, but he is not alone, he has allies to turn to to be stronger","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/44NA6/thumbnail/small.png","url":"https://play.gamepix.com/ant-maze/embed?sid=1","plays":40522,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"10035","slug":"brazil-cup-2014","title":"Brazil Cup 2014","description":"Embarquez pour la Coupe du Monde 2014 grâce à \"Brazil Cup 2014\", un des meilleurs jeux de football disponible sur le web.","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/10035/thumbnail/small.png","url":"https://play.gamepix.com/brazil-cup-2014/embed?sid=1","plays":40518,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"T6I69","slug":"trimat","title":"Trimat","description":"Trimat is a video game set in space with some levels. Avoid lasers, bombs, lava and cannonballs and travel the vastness of the galaxy!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/T6I69/thumbnail/small.png","url":"https://play.gamepix.com/trimat/embed?sid=1","plays":40517,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"6ATHD","slug":"football-champ-3d","title":"Football Champ 3D","description":"Football Champ 3D is the best football and matchless combination for footballlovers. Enjoy this fantasy football game!","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/6ATHD/thumbnail/small.png","url":"https://play.gamepix.com/football-champ-3d/embed?sid=1","plays":40514,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"S9STO","slug":"bowmastery-zombies","title":"Bowmastery - Zombies!","description":"Bowmastery zombies is a fascinating game that will give a lot of pleasure to children and adults. Your job is to kill terrible zombies. You have a bow and arrows, but only on the first level you can directly shoot your opponents. At other levels, obstacles will arise between the hero and the zombies. Think where you can shoot to win.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/S9STO/thumbnail/small.png","url":"https://play.gamepix.com/bowmastery-zombies/embed?sid=1","plays":40514,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"666B3","slug":"run-rabbit-run","title":"Run Rabbit Run","description":"Imagine you are a cute blue bunny and you have to reach the guard at the end of each level! Reach the guards and join the army in the latest episode and defeat enemies and monsters!   \n\nHow to Play?\nWASD & Mobile Touch Control (Double Jump Available)","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/666B3/thumbnail/small.png","url":"https://play.gamepix.com/run-rabbit-run/embed?sid=1","plays":40513,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"76K67","slug":"snake-brawl","title":"Snake Brawl","description":"Swipe your finger to guide a snake of balls and break the bricks on SNake Brawl!\nTry to break as many bricks as possible and increase your score.\nGet additional balls and make the biggest snake ever!\nVery easy to play but very hard to reach high scores!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/76K67/thumbnail/small.png","url":"https://play.gamepix.com/snake-brawl/embed?sid=1","plays":40510,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"NRLO0","slug":"mandala-coloring-book","title":"Mandala Coloring Book","description":"Détendez-vous tout en coloriant de belles images. Coloriez-les selon vos goûts. Tout ce que vous avez à faire, c'est laisser libre cours à votre imagination et colorier tout ce que vous aimez. Essayez de créer une œuvre d'art à couper le souffle.\n","category":"Arcade","tags":["classics"],"thumbnail":"https://games.assets.gamepix.com/NRLO0/thumbnail/small.png","url":"https://play.gamepix.com/mandala-coloring-book/embed?sid=1","plays":40509,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"6P4N1","slug":"open-ttd","title":"Open TTD","description":"OpenTTD is a business simulation game in which players try to earn money by transporting passengers and freight via road, rail, water and air. It is an open-source remake and expansion of the 1994 Chris Sawyer video game Transport Tycoon Deluxe. \n\nTo start building a transport empire, the player must construct transport routes, consisting of stations near industries or towns, and in the case of trains or road vehicles, near physical routes. One transport route can utilize several different forms of transport, e.g. truck→ship→train. The player's company and the individual stations each have ratings that depend largely on their efficiency at moving goods from one stations to the other. A station with high ratings may attract more goods. ","category":"Stratégie","tags":["strategy"],"thumbnail":"https://games.assets.gamepix.com/6P4N1/thumbnail/small.png","url":"https://play.gamepix.com/openttd/embed?sid=1","plays":40508,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"16PA5","slug":"space-war","title":"Space War","description":"Space War est un jeu unique et innovant en son genre, en effet en plus de présenter une version classique du \"Space Shooter\", il dispose d'un mode complètement innovant dans lequel vous devrez utiliser le microphone pour tirer sur les ennemis, le jeu peut être joué à la fois sur ordinateur et sur mobile, qu'attendez-vous ? Jouez à Space War maintenant !\n","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/16PA5/thumbnail/small.png","url":"https://play.gamepix.com/space-war/embed?sid=1","plays":40507,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"I1A3S","slug":"princess-kawaii-swimwear","title":"Princess Kawaii Swimwear","description":"La saison de baignade est ouverte! Les princesses vont à la plage. Quel est le vêtement le plus chaud sur la plage? Maillot de bain, bien sûr! Il suffit de regarder cette nouvelle collection de maillots de bain kawaii mignons: il y a suffisamment de tenues pour satisfaire même la princesse la plus maussade. La couleur délicate-bleu, rose, tons pastel-soulignera la sophistication de n'importe quelle fille. Choisissez votre maillot de bain princesse kawaii et détendez-vous avec style!","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/I1A3S/thumbnail/small.png","url":"https://play.gamepix.com/princess-kawaii-swimwear/embed?sid=1","plays":40504,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40294","slug":"jelly-bomb","title":"Jelly Bomb","description":"Jelly Bomb has spread all over your kitchen tables! You can get rid of it by dripping it with a jelly remover, but watch out: there are only a few drops left, you will have to use them wisely to ensure the perfect splashing chain reaction!","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/40294/thumbnail/small.png","url":"https://play.gamepix.com/jelly-bomb/embed?sid=1","plays":40504,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"P1526","slug":"jump-bottle","title":"Jump Bottle","description":"Bouteille Flip - Jeu de défi de saut. Vous devez simplement sauter! Affrontez des joueurs du monde entier !","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/P1526/thumbnail/small.png","url":"https://play.gamepix.com/jump-bottle/embed?sid=1","plays":40503,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40292","slug":"fox-adventurer","title":"Fox Adventurer","description":"Play Fox Adventurer and help Mr. Fox in his magical adventure.. Switch between day and night to choose the right way to finish level. Create stone clones to jump higher and collect green gems.","category":"Aventure","tags":["adventure","puzzles"],"thumbnail":"https://games.assets.gamepix.com/40292/thumbnail/small.png","url":"https://play.gamepix.com/fox-adventurer/embed?sid=1","plays":40501,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"9TM1L","slug":"tic-tac-toe-multiplayer","title":"Tic Tac Toe Multiplayer","description":"Ultimate Tic Tac Toe is a HTML5 Board Game. \nEnjoy this nice version of the classic Tic Tac Toe Game. 3 Game’s Mode: \n- Multiplayer mode \n- Play against the pc \n- Challenge a friend playing on the same device","category":"Stratégie","tags":["board"],"thumbnail":"https://games.assets.gamepix.com/9TM1L/thumbnail/small.png","url":"https://play.gamepix.com/tic-tac-toe-multiplayer/embed?sid=1","plays":40496,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"0159B","slug":"unblock-that","title":"Unblock That","description":"Unblock That est un jeu de casse-têtes simple et addictif. Le but est de faire sortir le bloc rouge du plateau de jeu en faisant glisser les autres blocs qui sont sur le chemin. Faites-le avec le moins de coups possible. Le jeu comprend 4 niveaux de difficulté allant de Débutant à Expert. Unblock That peut vous aider à entraîner votre cerveau et à garder un esprit aiguisé au quotidien.\n","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/0159B/thumbnail/small.png","url":"https://play.gamepix.com/unblock-that/embed?sid=1","plays":40494,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40172","slug":"fancy-diver","title":"Fancy Diver","description":"Votre but est d'aider tous les plongeurs à remonter jusqu'en haut de l'écran avant que leur oxygène soit à zéro. Touchez les groupes de coraux de couleur similaire (3 ou plus) de façon à les faire disparaitre. Faites disparaitres de grands groupes de coraux de manière à gagner des mines spéciales et des power-ups!","category":"Puzzle","tags":["arcade","puzzles"],"thumbnail":"https://games.assets.gamepix.com/40172/thumbnail/small.png","url":"https://play.gamepix.com/fancy-diver/embed?sid=1","plays":40491,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"S068C","slug":"kids-cute-pairs","title":"Kids: Cute Pairs","description":"Laissez vos enfants jouer à un jeu de concentration traditionnel. Il y a trois difficultés différentes, chacune avec ses propres images incluant des fruits et des légumes, des instruments de musique et des animaux. C'est un jeu stimulant pour les enfants de tout âge. Il comprend aussi un mode Deux joueurs pour vous permettre de jouer ensemble ! \n","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/S068C/thumbnail/small.png","url":"https://play.gamepix.com/kids-cute-pairs/embed?sid=1","plays":40489,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"M46I6","slug":"kobadoo-emojis","title":"Kobadoo Emojis","description":"Kobadoo Emojis is a browser game that trains your brain by memorizing funny emojis in the right order.\n\nWhen you play Kobadoo Emojis you are actively using your working memory. Several scientific studies suggest that training of working memory has beneficial effects and can increase your cognitive functions.","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/M46I6/thumbnail/small.png","url":"https://play.gamepix.com/kobadoo-emojis/embed?sid=1","plays":40487,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"E83S5","slug":"mahjong-sweet-easter","title":"Mahjong Sweet Easter","description":"Easter eggs and candies, what could be better? Celebrate easter with our new game! Match as many tiles as you can before time is up and try to deal with \"gravity\"!","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/E83S5/thumbnail/small.png","url":"https://play.gamepix.com/mahjong-sweet-easter/embed?sid=1","plays":40484,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40396","slug":"color-blocks","title":"Color Blocks","description":"Color Blocks is easy to play and a pleasurable game for all ages! Simply drag the blocks and fill up all colored grids. Once you start, you will definitely be hooked: this 3D-style game awaits you!","category":"Arcade","tags":["arcade","puzzles"],"thumbnail":"https://games.assets.gamepix.com/40396/thumbnail/small.png","url":"https://play.gamepix.com/color-blocks/embed?sid=1","plays":40483,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"8407E","slug":"barbarian-run","title":"Barbarian Run","description":"barbarian run is a retro endless run game, run and kill monster with jump and collecting coins to get a lot of scores \n","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/8407E/thumbnail/small.png","url":"https://play.gamepix.com/fire-soldier/embed?sid=1","plays":40480,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"13T40","slug":"jet-strike","title":"Jet Strike","description":"Jet Strike is the super arcade casual game everyone is playing right now. Enjoy!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/13T40/thumbnail/small.png","url":"https://play.gamepix.com/jet-strike/embed?sid=1","plays":40480,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"0410S","slug":"smash-the-flies","title":"Smash the Flies","description":"This is a cool, easy, and fun to play, endless game.\nTap or Click on the Flies with your fingers to smash them, before they leave the screen.\nBut don't tap the red one, or you finish the game! Be fast and quick to smash all of them and achieve high scores.","category":"Arcade","tags":["arcade","classics"],"thumbnail":"https://games.assets.gamepix.com/0410S/thumbnail/small.png","url":"https://play.gamepix.com/smash-the-flies/embed?sid=1","plays":40480,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"5C9TC","slug":"ocean-kids-back-to-school","title":"Ocean Kids Back to School","description":"Welcome to Ocean Kids Back to school. It’s back to school time for these Kids. Can you help them get ready for their first day of classes? They’ll need to pick some cool outfits, new hairstyles, accessories, and school supplies too in this online dress-up and design game for girls. After you’re all done, help them to repair their vespa. Play and have fun!","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/5C9TC/thumbnail/small.png","url":"https://play.gamepix.com/ocean-kids-back-to-school/embed?sid=1","plays":40479,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"20526","slug":"gs","title":"GS","description":"Easy and simple game, you have to pass two levels to be able to catch all the birds and fly them within a time limit","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/20526/thumbnail/small.png","url":"https://play.gamepix.com/gs/embed?sid=1","plays":40478,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"U66A7","slug":"urban-sniper-multiplayer-2","title":"Urban Sniper Multiplayer 2","description":"Urban Sniper Multiplayer 2 features ultimate sniper warfare in grand city, use different sniper rifles to shoot rival players across vast highly detailed map and try to get the highest amount of frags in order to win.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/U66A7/thumbnail/small.png","url":"https://play.gamepix.com/urban-sniper-multiplayer-2/embed?sid=1","plays":40478,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"7BO15","slug":"shadobirds","title":"Shadobirds","description":"Don't download this game! it's too hard for you! You won't complete this game! Never! Trust me, I programmed this, I know what I'm saying. I literally lost the best part of my life trying to beat it. I made it at last, but the price was too high! I lost everything I love to beat it, and now I'm alone and lonely, but at least I can say \"I completed Shadobirds\". Can you say the same?\nFEATURING:\n20 Levels full of obstacles\nBirds\nBlack Shadows\nOther Birds\nNest\nObstacles\nand when you think you are done... More obstacles!\nEnjoy... if you can","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/7BO15/thumbnail/small.png","url":"https://play.gamepix.com/shadobirds/embed?sid=1","plays":40478,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"5516C","slug":"blueguy-escape","title":"BlueGuy Escape","description":"blue guy escape is an adventure html5 retro game, run collect score by eating many fruits and avoid obstacles by flipping up and down ","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/5516C/thumbnail/small.png","url":"https://play.gamepix.com/blueguy-escape/embed?sid=1","plays":40477,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"6C187","slug":"fruit-clicker","title":"Fruit Clicker","description":"A game about collecting as much FruitCoins as you can. The FruitCoins can be used to purchase upgrades at the store. Play this game now and try to unlock the secret reward.","category":"Arcade","tags":["arcade","classics"],"thumbnail":"https://games.assets.gamepix.com/6C187/thumbnail/small.png","url":"https://play.gamepix.com/fruit-clicker/embed?sid=1","plays":40474,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"L26C1","slug":"flashcount","title":"FlashCount","description":"Guess how many red dots appear disappear from the screen","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/L26C1/thumbnail/small.png","url":"https://play.gamepix.com/flashcount/embed?sid=1","plays":40471,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"46OMG","slug":"olympian-mahjong","title":"Olympian Mahjong","description":"Match identical sport tiles to remove them from the playing field. All mahjong tiles represent kinds of winter sports that will be played at the Olympic Winter Games in Beijing 2022.","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/46OMG/thumbnail/small.png","url":"https://play.gamepix.com/olympian-mahjong/embed?sid=1","plays":40471,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"W81OB","slug":"cowboy-s-shooter","title":"Cowboy's Shooter","description":"Cowboy's Shooter est un jeu qui se déroule dans l'ouest antique. Œil! De nombreux bandits voudront votre prime, tuez-les tous mais faites attention aux tirs ! La charge est assez lente, alors choisissez le bon moment pour charger ! Jouez à Cowboy's Shootooter sur votre ordinateur, smartphone ou tablette ! De nouvelles armes sortiront chaque mois, alors revenez de temps en temps ! Qu'est-ce que tu attends? Plongez dans le jeu !\n","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/W81OB/thumbnail/small.png","url":"https://play.gamepix.com/cowboy-s-shooter/embed?sid=1","plays":40470,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"RAS9H","slug":"dark-chess","title":"Dark Chess","description":"It is a very interesting chess, it is using Chinese Chess to play but the game rule is very different.\n\nOnly higher level chess can eat lower level chess, if all of your chesses are eaten or you cannot move any chess. You will loss.","category":"Stratégie","tags":["board"],"thumbnail":"https://games.assets.gamepix.com/RAS9H/thumbnail/small.png","url":"https://play.gamepix.com/dark-chess/embed?sid=1","plays":40470,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"UL1OA","slug":"domino-multiplayer","title":"Domino Multiplayer","description":"Domino Multiplayer is a HTML5 Board Game. \nEnjoy this stylish version of the classic Domino Game. \n3 Game’s Mode: \n- Multiplayer mode \n- Play against the pc \n- Challenge a friend playing on the same device","category":"Stratégie","tags":["board","classics","strategy"],"thumbnail":"https://games.assets.gamepix.com/UL1OA/thumbnail/small.png","url":"https://play.gamepix.com/domino-multiplayer/embed?sid=1","plays":40470,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"TAAOS","slug":"dots-attack","title":"Dots Attack","description":"Switch color dot! Put your record in this addictive arcade!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/TAAOS/thumbnail/small.png","url":"https://play.gamepix.com/dots-attack/embed?sid=1","plays":40470,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"91E14","slug":"fast-finders-io","title":"Fast Finders IO","description":"Find colored shape of a requested type faster than your opponents!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/91E14/thumbnail/small.png","url":"https://play.gamepix.com/fast-finders-io/embed?sid=1","plays":40470,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"IMEMG","slug":"squid-game-survival-challenge","title":"Squid Game Survival Challenge","description":"Welcome to the opportunity of a lifetime. Just try to give your best at the squid game challenge.\nAre you short on money?\nYou can earn 45.6 Billion Won just by sticking to fair play. There is only one rule, don’t get eliminated.\nRemember our card? Call us now. Challenge for our childish game event, it will be fun, but the stakes are deadly.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/IMEMG/thumbnail/small.png","url":"https://play.gamepix.com/squid-game-3d/embed?sid=1","plays":40470,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"UD8U4","slug":"tap-double-tap-remake","title":"Tap Double-Tap REMAKE!","description":"A simple video game in which you will have to send the central ball to the half screen of the correct color. You will have to tap once to send the ball to the left, to send the ball to the right instead, you will have to tap it twice!","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/UD8U4/thumbnail/small.png","url":"https://play.gamepix.com/tap-double-tap/embed?sid=1","plays":40470,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"7EEE1","slug":"east-runner","title":"East Runner","description":"Help the prince to run faster than everyone! Run as far as you can. Collect coins and buy things in the store. Become the best runner of the East!\nEndless game with great graphics to keep you playing.\nRun without hitting obstacles in the eastern safari.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/7EEE1/thumbnail/small.png","url":"https://play.gamepix.com/east-runner/embed?sid=1","plays":40470,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40189","slug":"space-cord","title":"Space Cord","description":"Explore the space and collect all trophies through its energy platforms avoiding dangerous traps on your way! Try to hold on as long as possible in a space race!","category":"Puzzle","tags":["arcade","puzzles"],"thumbnail":"https://games.assets.gamepix.com/40189/thumbnail/small.png","url":"https://play.gamepix.com/space-cord/embed?sid=1","plays":40469,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"6B1OB","slug":"bigboom","title":"BigBoom","description":"Reach more and more objectives increase the mines","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/6B1OB/thumbnail/small.png","url":"https://play.gamepix.com/bigboom/embed?sid=1","plays":40468,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"F2W1I","slug":"fairy-wingerella","title":"Fairy Wingerella","description":"Wingerella is a fairy girl that is going to become the most cool and powerful fairy in the world.","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/F2W1I/thumbnail/small.png","url":"https://play.gamepix.com/fairy-wingerella/embed?sid=1","plays":40468,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"S4173","slug":"neon-block","title":"Neon Block","description":"A fun casual game with a neon theme. try to pass all levels with the least amount of deaths possible. Challenge your friends.","category":"Puzzle","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/S4173/thumbnail/small.png","url":"https://play.gamepix.com/teste/embed?sid=1","plays":40468,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"CAR76","slug":"red-and-green-color-rain","title":"Red and Green Color Rain","description":"Crazy sharp wheels and diamonds you need to collect welcome you in 6 games of the red and green series. collect diamonds, overcome obstacles and go to the next level!\n\nHow to Play?\nWASD and Arrow Keys - Mobile Touch","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/CAR76/thumbnail/small.png","url":"https://play.gamepix.com/red-and-green-color-rain/embed?sid=1","plays":40468,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"3BUBI","slug":"road-builder-simulator","title":"Road Builder Simulator","description":"Using heavy machinery like heavy excavator, crane, road roller and a dumper truck in this City Road Construction 2020, learn and build your city with excellent fine-tuned construction simulation. This is a fun to construct like a real builder with hydraulic controls that provides an excellent driving view. Know inside story of road construction with the use of heavy machinery. Enjoy heavy machinery simulator to repair and construct new roads","category":"Arcade","tags":["classics"],"thumbnail":"https://games.assets.gamepix.com/3BUBI/thumbnail/small.png","url":"https://play.gamepix.com/road-builder-simulator/embed?sid=1","plays":40468,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"S6AU1","slug":"squid-game-3d-survival-squad","title":"Squid Game 3D Survival Squad","description":"$a","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/S6AU1/thumbnail/small.png","url":"https://play.gamepix.com/squid-game-3d-survival-squad/embed?sid=1","plays":40468,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"10O49","slug":"touchme","title":"Touchme","description":"Welcome to Touch Me, have fun accumulating points by touching the yellow ball and avoiding the yellow blue and white ones including bats, what are you waiting for ??? Go play Touch me now and the fun will be guaranteed !!!!!!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/10O49/thumbnail/small.png","url":"https://play.gamepix.com/touchme/embed?sid=1","plays":40468,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"MM7AW","slug":"two-x2","title":"Two x2","description":"A very addicting Puzzle Game, similar to the popular 2048 game, but with a different logic. Connect the numbers and don’t run out of moves! Make lines connecting as many numbered points as possible. The longer is the line, the more points you get. Every time you connect numbers, you get a new doubled number.\nChallenge your friends, play it right now!\n","category":"Stratégie","tags":["board"],"thumbnail":"https://games.assets.gamepix.com/MM7AW/thumbnail/small.png","url":"https://play.gamepix.com/two-for-2-match-the-numbers/embed?sid=1","plays":40468,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"4766P","slug":"simply-breakout","title":"Simply Breakout","description":"This is the best Brick Breaker that everyone can play, extremely simple, but really fun.\nThere are many elements and object, various levels and easy game controls.","category":"Arcade","tags":["classics"],"thumbnail":"https://games.assets.gamepix.com/4766P/thumbnail/small.png","url":"https://play.gamepix.com/simply-breakout/embed?sid=1","plays":40468,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"KZI7R","slug":"zombie-strike-2","title":"Zombie Strike 2","description":"You are trapped in a farm crowded with zombies and your mission is to survive five waves of zombies with increasing difficulty, use big arsenal of weapons to shoot hordes of incoming zombies and try to survive in order to successfully complete your mission.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/KZI7R/thumbnail/small.png","url":"https://play.gamepix.com/zombie-strike-2/embed?sid=1","plays":40465,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"L6H44","slug":"alien-hunter-remastered","title":"Alien Hunter Remastered","description":"alien hunter remastered is an html5 platformer game, explore levels earn coins and destroy aliens ","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/L6H44/thumbnail/small.png","url":"https://play.gamepix.com/alien-hunter-remastered/embed?sid=1","plays":40464,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"17786","slug":"silent-asylum","title":"Silent Asylum","description":"You are trapped in silent asylum crowded with scary monsters and your mission is to shoot your way through dark corridors and find all keys to unlock the exit.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/17786/thumbnail/small.png","url":"https://play.gamepix.com/silent-asylum/embed?sid=1","plays":40463,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"2PE91","slug":"apples","title":"Apples","description":"Welcome to the apple game. only pick apples, be very careful not to get hit by the bullet, you have three chances to lose to get your high score","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/2PE91/thumbnail/small.png","url":"https://play.gamepix.com/apples/embed?sid=1","plays":40462,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"Z69R9","slug":"merge-block-puzzle","title":"Merge Block Puzzle","description":"MERGE BLOCK PUZZLE is a FREE and FUN puzzle game for all ages;\nMERGE BLOCK PUZZLE is a good game to help you relax and train your brain;\n\nHow to play this puzzle game?\n• Drag the number blocks to move them.\n• 2 same numbers could be merged into a larger numbe","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/Z69R9/thumbnail/small.png","url":"https://play.gamepix.com/merge-block-puzzle/embed?sid=1","plays":40462,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"ZI893","slug":"zoo-trivia","title":"Zoo Trivia","description":"Il est temps de montrer votre connaissance des animaux ! Combien d'entre eux en connaissez-vous ? Pouvez-vous épeler les noms correctement ? Des dizaines d'animaux vous attendent. Des mammifères, chiens, chats, poissons, insectes et beaucoup plus ! C'est plus difficile que vous ne le pensez ! Mais ne vous inquiétez pas, vous pouvez toujours utiliser l'élégant système d'indices pour vous aider à surmonter les difficultés.\n","category":"Puzzle","tags":["classics","puzzles"],"thumbnail":"https://games.assets.gamepix.com/ZI893/thumbnail/small.png","url":"https://play.gamepix.com/zoo-trivia/embed?sid=1","plays":40462,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"19616","slug":"exploder-io","title":"Exploder.io","description":"Exploder is a game similar to the classic Bomberman but with a space theme. Players need to fight other players as well as monsters by planting bombs and running away from attacks and explosions. Starting the game is pretty easy and straightforward; though, it is incredibly hard to master all the game tricks. All graphical game assets are pixel artwork to reflect on the original game. Battles in Exploder are very entertaining and challenging, with virtual coins and experience points as gratification! In the game shop, you can use the coins to upgrade your character's appearance by buying new skins and other aspects.","category":"Arcade","tags":["classics"],"thumbnail":"https://games.assets.gamepix.com/19616/thumbnail/small.png","url":"https://play.gamepix.com/exploder-io/embed?sid=1","plays":40461,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"48O2T","slug":"retro-speed","title":"Retro Speed","description":"Feel the thrill of high speed racing in Retro Speed. It is an arcade racing game in which the speed of your car constantly increases as you keep collecting coins. Overtake as many cars as possible and emerge as the leader. Don't miss playing this highly addictive and fun game.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/48O2T/thumbnail/small.png","url":"https://play.gamepix.com/retro-speed/embed?sid=1","plays":40461,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"W393C","slug":"m3-power-3d-city-racing","title":"M3 Power 3D City Racing","description":"7 different bmw m3 survival games. be the last and be the first to achieve victory collect points you own the best car of the day! Are you ready to be the winner of m3 power 3d city racing?","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/W393C/thumbnail/small.png","url":"https://play.gamepix.com/m3-power-3d-city-racing/embed?sid=1","plays":40459,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40389","slug":"crazy-switch-color","title":"Crazy Switch Color","description":"Faites sauter prudemment la balle à travers chaque obstacle lorsqu'il est de la même couleur que la balle.\nAttention de ne pas traverser la mauvaise couleur, sinon vous devrez recommencer.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/40389/thumbnail/small.png","url":"https://play.gamepix.com/crazy-switch-color/embed?sid=1","plays":40457,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"HACSD","slug":"head-ball-hyper-casual-game","title":"Head Ball Hyper Casual Game","description":"The Head Ball Hyper Casual Game is a new type of sport that involves the player's head. It was designed with an emphasis on creativity, agility and balance in mind while also ensuring they have fun!  \nAt Head Ball, they are always looking for new ways to make the game more exciting. One way is by giving their head coaches an opportunity to show off their creative and innovative side while staying competitive on all levels!  \n","category":"Sport","tags":["sports"],"thumbnail":"https://games.assets.gamepix.com/HACSD/thumbnail/small.png","url":"https://play.gamepix.com/head-ball-hyper-casual-game/embed?sid=1","plays":40457,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"99110","slug":"traigon","title":"Traigon","description":"Traigon is an obstacle course game, where we will be able to jump over ravines and spikes to reach the end of the level.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/99110/thumbnail/small.png","url":"https://play.gamepix.com/traigon/embed?sid=1","plays":40454,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"9ER29","slug":"extreme-way","title":"Extreme Way","description":"You are a ninja who has to go through a bunch of obstacles! Run, jump and destroy walls on your way! Put your record in this addictive arcade!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/9ER29/thumbnail/small.png","url":"https://play.gamepix.com/extreme-way/embed?sid=1","plays":40453,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"61FAB","slug":"baby-hazel-african-safari","title":"Baby Hazel African Safari","description":"Baby Hazel and her parents along with Bruno have gone on holiday to South Africa. After experiencing the beautiful scenic of Cape Town, they have decided to spend a night in the jungle safari tent. Isn't that exciting? Do you want to be part of this jungle adventure? Join Baby Hazel and her family and taste the wilderness of the Jungle. You need to be careful as jungles are a bit risky for young girls like Baby Hazel. Be with the little one and help in her needs. Make sure she does not get lost in the wilds.","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/61FAB/thumbnail/small.png","url":"https://play.gamepix.com/baby-hazel-african-safari/embed?sid=1","plays":40450,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"6BE8B","slug":"mech-battle-simulator","title":"Mech Battle Simulator","description":"Simulateur de combat - robots, tanks et tourelles! La bataille réveille l'épopée!\n\nLes robots à fourrure jouent un rôle décisif lors de la guerre de 3070.\n\nCaractéristiques:\n• Simulateur de combat (Battle Simulator)\n• Dommages et coups de bélier complètement renversants et réalistes\n• Beau champ de bataille 3D\n• Unités des chars de forme, robots d'araignées, guerriers de robot de fourrure\n\nMaintenant, chaque robot de combat vaut son pesant d'or, et chaque bataille est un véritable test de jeu.\n\nSounds_freesound_org\nMusic_McGorilla42_Hidden-Tension","category":"Stratégie","tags":["strategy"],"thumbnail":"https://games.assets.gamepix.com/6BE8B/thumbnail/small.png","url":"https://play.gamepix.com/mech-battle-simulator/embed?sid=1","plays":40450,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40418","slug":"doctor-acorn-2","title":"Doctor Acorn 2","description":"Doctor Acorn travels through a puzzle world: fly on the bumblebee, jump from cloud to cloud, collect all stars and beware of wild boars!","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/40418/thumbnail/small.png","url":"https://play.gamepix.com/doctor-acorn-2/embed?sid=1","plays":40449,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"6SSG6","slug":"christmas-fishing","title":"Christmas Fishing","description":"Le Père Noël est allé à la pêche. Aidez-le à attraper autant de poissons que possible et à atteindre le fond. Il y a même des cadeaux avec des décorations de Noël qui flottent. Prenez-les et décorez le sapin de Noël dans la pièce du Père Noël.\n","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/6SSG6/thumbnail/small.png","url":"https://play.gamepix.com/christmas-fishing/embed?sid=1","plays":40447,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"HS445","slug":"catch-the-beats","title":"Catch the Beats","description":"\nAll you need to play this game is your spacebar, your ears and your eyes! Watch and listen carefully, and hit the spacebar when the beat is in the patch.\n\nUse your listening skills for this game! Hit the spacebar every time the yellow dot is in the patch space! Sounds easy to you? Every level gets harder, every beat is faster and every second matters! Remember to keep your eyes on the patch space and hear every beat. Can you beat your own high score by listening to the beats? Let’s see!\n\n","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/HS445/thumbnail/small.png","url":"https://play.gamepix.com/catchthebeats/embed?sid=1","plays":40447,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"1IN3R","slug":"neon-guitar","title":"Neon Guitar","description":"“Neon Guitar” is an inspired musical game in the critically acclaimed “Guitar Hero”, developed for the enjoyment of all people. Hit as many notes as fall on the screen to accumulate points and beat your highscores. Great game to train your reflexes and have fun at the same time! The designs are Neon style, very colorful and beautiful! Have a good time!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/1IN3R/thumbnail/small.png","url":"https://play.gamepix.com/neon-guitar/embed?sid=1","plays":40447,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"6NI8R","slug":"parking","title":"Parking","description":"Jouez à l'un des jeux de stationnement les plus réalistes du marché. Conduisez différentes voitures, chacune avec un comportement unique. Découvrez de nombreuses missions variées dans un monde complètement simulé physiquement.","category":"Stratégie","tags":["strategy"],"thumbnail":"https://games.assets.gamepix.com/6NI8R/thumbnail/small.png","url":"https://play.gamepix.com/parking/embed?sid=1","plays":40447,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"6ALEA","slug":"slaky-ball-touch-ball-game","title":"Slaky Ball - Touch Ball Game","description":"$b","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/6ALEA/thumbnail/small.png","url":"https://play.gamepix.com/ball-fall-touch-ball-game/embed?sid=1","plays":40447,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"E16WR","slug":"where-is-multiplayer","title":"Where is - Multiplayer","description":"Where is is a multiplayer PvP game in which the first to reach 10 points wins. Whoever starts the game will be the one who will check the cups and decide the object to hide under them. The opponent will have to guess under which cup the object is hidden or which object is hidden.\nWhere has also a local mode that will allow you to play against an artificial intelligence.","category":"Arcade","tags":["arcade","board","classics"],"thumbnail":"https://games.assets.gamepix.com/E16WR/thumbnail/small.png","url":"https://play.gamepix.com/where-is/embed?sid=1","plays":40447,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"W9OOK","slug":"blockworld-parkour","title":"Blockworld Parkour","description":"Welcome to the world of blocks. Pass different maps and follow the track. Beware of the lava you might die in the falling block world. If you die, you start from scratch, don't die! \n\nHow to Play?\n*Use WASD keys to play!                      \n*Use mouse cursor to rotate 360 ​​degrees.                      \n*Press the \"p\" key to stop the game.                      \n","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/W9OOK/thumbnail/small.png","url":"https://play.gamepix.com/blockworld-parkour/embed?sid=1","plays":40446,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"I5IS4","slug":"multiplication-simulator","title":"Multiplication Simulator","description":"Which of the tasks will be more fun for primary school students? Of course, the multiplication table. And such an educational game as “Multiplication Simulator” is perfect for children to quickly learn the multiplication tables in a playful way.","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/I5IS4/thumbnail/small.png","url":"https://play.gamepix.com/multiplication-simulator/embed?sid=1","plays":40444,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40101","slug":"swipe-art-puzzle","title":"Swipe Art Puzzle","description":"Si vous aimez l'art - voici un jeu de puzzle pour vous. Déplacez les pièces pour recréer des peintures ultra célèbres faites par les plus anciens grands maîtres (qui ont été un peu \"améliorées\" avec notre humour étrange ;) Entraînez votre cerveau et faites le plein de beauté et d'humour en même temps!","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/40101/thumbnail/small.png","url":"https://play.gamepix.com/swipe-art-puzzle/embed?sid=1","plays":40443,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40154","slug":"mega-slots","title":"Mega Slots","description":"Mega slots est un simulateur de machines à sous diaboliquement excitant! Gagnez soit en horizontal soit en vertical en combinant 3 objets du même type. Tentez la roulette et booster encore plus vos gains. Le démon du jeu vous tient!","category":"Stratégie","tags":["board"],"thumbnail":"https://games.assets.gamepix.com/40154/thumbnail/small.png","url":"https://play.gamepix.com/mega-slots/embed?sid=1","plays":40443,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"A4F21","slug":"minigolf-master","title":"Minigolf Master","description":"Amusez-vous avec différents parcours de minigolf truffés d'obstacles et animé par la physique simulée. Atteignez le par ou obtenez un résultat encore meilleur pour déverrouiller d'autres niveaux, paramètres de difficulté et commandes. Chaque niveau de difficulté a ses propres commandes. Pouvez-vous terminer tout un parcours sous le par ?\n","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/A4F21/thumbnail/small.png","url":"https://play.gamepix.com/minigolf-master/embed?sid=1","plays":40442,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"13OT7","slug":"attack-robots","title":"Attack Robots","description":"Attack Robots is a 3D action game with 10 levels playable in 3 difficulty modes. The goal in each is to eliminate all enemies. The game offers 3 weapons and option to buy medical kit that increases health. Have fun.","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/13OT7/thumbnail/small.png","url":"https://play.gamepix.com/attack-robots/embed?sid=1","plays":40439,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"TP565","slug":"don-t-drop-the-sponge","title":"Don't Drop the Sponge","description":"Don' Drop the Sponge is a cool endless game, very easy and intuitive to play, but it will be hard to stop playing.\nHit with your finger the blowing up balloons on the screen and touch the Sponge to prevent it from falling down.\nEnjoy this cool game the more you can!\nYou can play with your kids.\n\nProduct feature bullets:\n• very very easy to play\n• nice 2D graphics\n• endless game play\n• very fun game for kids and babies\n• cool sound effects","category":"Arcade","tags":["arcade","junior"],"thumbnail":"https://games.assets.gamepix.com/TP565/thumbnail/small.png","url":"https://play.gamepix.com/dont-drop-the-sponge/embed?sid=1","plays":40439,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"62266","slug":"get10-plus","title":"Get10 Plus","description":"Vous aimez les maths ou les jeux de logique ? Grâce à cet amusant jeu de connexion de nombres, vous allez les adorer ! Associez les mêmes nombres voisins pour les transformer en un plus grand nombre. Associez davantage pour atteindre 10 et au-delà ! Un jeu facile à apprendre, mais difficile à maîtriser !\n","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/62266/thumbnail/small.png","url":"https://play.gamepix.com/get10-plus/embed?sid=1","plays":40439,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"N1M96","slug":"match-earth-online-game","title":"Match Earth Online Game","description":"Match Earth is an addictive match-3 puzzle game with relaxing gameplay and beautiful graphics. Match 3 or more of the same symbols in a row to clear the level.   \nPlay Match Earth online free. Destroy all the asteroids with your spaceship and don't crash into them.Match Earth is a fun and addicting match-3 game. Play on your phone or tablet for free.Match Earth is a free game where you can match the colors of the planets to their respective orbits.   \n","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/N1M96/thumbnail/small.png","url":"https://play.gamepix.com/match-earth-online-game/embed?sid=1","plays":40439,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"65305","slug":"memory","title":"Memory","description":"Play by heart and let's see what level you can get to","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/65305/thumbnail/small.png","url":"https://play.gamepix.com/memory/embed?sid=1","plays":40439,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"S6RMO","slug":"platform-shooter","title":"Platform Shooter","description":"\"Platform Shooter\" est un jeu de tir de plateforme, avec beaucoup d'armes et plusieurs niveaux difficiles et différents ennemis.","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/S6RMO/thumbnail/small.png","url":"https://play.gamepix.com/platform-shooter/embed?sid=1","plays":40439,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"S2155","slug":"princess-maid-academy","title":"Princess Maid Academy","description":"La princesse a besoin d'une nouvelle femme de chambre, car elle a tellement de choses à faire - réceptions, rencontres avec les ambassadeurs d'autres États, bals de charité. Et quelqu'un à ce moment-là doit maintenir l'ordre dans le palais et dans la garde-robe de la princesse. Où trouver la bonne personne? Bien sûr à la princess maid academy! Ce n'est qu'ici que les femmes de chambre de la plus haute classe sont formées, leurs tenues ne sont que légèrement inférieures en beauté aux robes des princesses, et leur coiffure et leur posture sont toujours impeccables. Le style strict des tenues en noir et blanc peut parfois être dilué avec des nuances de rose, de bleu et de lilas. Un tablier blanc est un must-have pour une femme de chambre diligente. Choisissez la femme de chambre la plus élégante et la plus impeccable pour votre princesse!","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/S2155/thumbnail/small.png","url":"https://play.gamepix.com/princess-maid-academy/embed?sid=1","plays":40439,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"6008Q","slug":"red-square-adventure","title":"Red Square Adventure","description":"Welcome to the adventurous life of a cute red square. The red square has to pass the levels one by one and it needs you. Pass the obstacles and get the red square to the end of the level!\n\nHow to Play?\nWASD + Mobile Touch Control \n*Double jump available","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/6008Q/thumbnail/small.png","url":"https://play.gamepix.com/red-square/embed?sid=1","plays":40439,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"O3161","slug":"sandro-s-world","title":"Sandro's World","description":"sandro's world is a platform game full of obstacles and enemies to avoid","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/O3161/thumbnail/small.png","url":"https://play.gamepix.com/sandro-s-world/embed?sid=1","plays":40439,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"AIMNW","slug":"sandwich-master","title":"Sandwich Master","description":"Plein de niveaux difficiles, ce jeu est conçu pour vous éviter l'ennui. Délicieux et très intéressant! À quelle hauteur pouvez-vous empiler votre sandwich?","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/AIMNW/thumbnail/small.png","url":"https://play.gamepix.com/sandwich-master/embed?sid=1","plays":40439,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"40070","slug":"scratch-fruit","title":"Scratch Fruit","description":"Scratch Fruit est un jeu de gain instantané. Grattez et découvrez si vous avez gagné un prix ! C'est tout, juste de la simplicité, de la chance et du fun!","category":"Stratégie","tags":["board"],"thumbnail":"https://games.assets.gamepix.com/40070/thumbnail/small.png","url":"https://play.gamepix.com/scratch-fruit/embed?sid=1","plays":40439,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"214N5","slug":"bomb-is-in-the-air","title":"Bomb is in the air","description":"How do you park a plane?\nA crazy aviator and his journey to discover the world. ","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/214N5/thumbnail/small.png","url":"https://play.gamepix.com/bomb-is-in-the-air/embed?sid=1","plays":40438,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"NEESI","slug":"the-simple-piano","title":"The Simple Piano","description":"Simple piano application to learn play the piano and with realistic sounds of instruments.   \nHow to Play Piano:   \nJust run your fingers over the real piano tiles, playing live music and feel like a real musician.   \nFeatures:   \n• It works with all screen resolutions   \n• Full piano keyboard   \n• Multi-Touch   \n• Easy for children","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/NEESI/thumbnail/small.png","url":"https://play.gamepix.com/the-simple-piano/embed?sid=1","plays":40436,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"UTA2U","slug":"fruit-smash-master","title":"Fruit Smash Master","description":"Fruit Smash Master Fruit Cutter is a fun and challenging fruit slicing game.    \nfruit smashing is an essential skill for cooking and eating. By slicing fruit, you can make it easier to get the most out of your fruits by making them more accessible and tasty. Fruit Smash Master offers a unique and challenging experience that will have you coming back for more! \n \nThe objective of the game is to cut as many pieces from a fruit as possible in the shortest time. The player can use different fruits, but care should be taken that they are not too heavy or too thin so that they do not break during cutting. The fruit slices can be set on different surfaces such as a desk, table, or floor and there are several levels of difficulty available for players to increase their chances of winning.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/UTA2U/thumbnail/small.png","url":"https://play.gamepix.com/fruit-smash-master/embed?sid=1","plays":40432,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"14L1B","slug":"8-ball-pool-multiplayer","title":"8 Ball Pool Multiplayer","description":"8 Ball Pool has introduced a new level system to keep you entertained. With this new system, you'll always face a challenge and get access to more exclusive match locations, where you play against only the best Pool players. You can also compete in tournaments and win rewards that improve your ranking.      \n","category":"Stratégie","tags":["board"],"thumbnail":"https://games.assets.gamepix.com/14L1B/thumbnail/small.png","url":"https://play.gamepix.com/8-ball-pool-multiplayer/embed?sid=1","plays":40431,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"533A0","slug":"aster-supreme","title":"Aster Supreme","description":"Build traps and fight enemies using your boomerang witch you can draw the path of and other weapons and traps.\n\nYou play as Aster in a dungeon crawler zelda like game\n\nPress Q to open the Quick selection menu and change your weapons and traps on the fly\n\nPress space to jump to avoid obstecles and enwmy attacks\n\nLeft shift to roll.\n\nMouse left click for the main attack right click for the boomerang to attack the nearest enemy\n\nE to place traps\n\nThis Game contains:\n\n3 uniqe weapons melee sword a boomerang and a cannon\n\n4 unique traps to synergiese\n\nTotal of 10 unique enemies in addition to some platforming in a top down zelda like game.\n\n2 unique boss fightes.\n\nYour objective is to defeat leviathan the Demon God in his differant incornation","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/533A0/thumbnail/small.png","url":"https://play.gamepix.com/aster-supreme/embed?sid=1","plays":40431,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"46EBO","slug":"balls-collect-bounce-build","title":"Balls Collect - Bounce & Build!","description":"Balls Collect is the first choice for casual puzzle games.\n\nYou just need to control the ball to double and double continuously. Feel the explosive growth of the ball!\n\nStart with 3 balls, use your wisdom, feel the super cool experience of increasing to thousands of balls.","category":"Arcade","tags":["classics"],"thumbnail":"https://games.assets.gamepix.com/46EBO/thumbnail/small.png","url":"https://play.gamepix.com/balls-collect-bounce-and-build/embed?sid=1","plays":40431,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"IP5SC","slug":"black-white-escape-cars","title":"Black & White Escape Cars","description":"Control two cars at the same time.\nClick to change the track car.\nRun away from the police and get the gas to keep the car always fueled.\nSee how many points you can score by taking as many gasolines as you can.","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/IP5SC/thumbnail/small.png","url":"https://play.gamepix.com/black-and-white-escape-cars/embed?sid=1","plays":40431,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"6U46Z","slug":"buzzy-bugs","title":"Buzzy Bugs","description":"Use your finger and flap your wings to fly be careful to try to avoid all dangerous trunks!\nHave Fun! Fly as long as you can without hitting the trunks and\nachieve high scores.","category":"Arcade","tags":["arcade","junior"],"thumbnail":"https://games.assets.gamepix.com/6U46Z/thumbnail/small.png","url":"https://play.gamepix.com/buzzy-bugs/embed?sid=1","plays":40431,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"A4T3E","slug":"cat-strapped","title":"Cat Strapped","description":"Cat Strapped is an off-the-wall word puzzler that will keep you coming back for more.      \nYou start the game with 8 lovable Cats strapped with C4!!! As you play the game you guess letters.      \nFor each letter, you guess wrong a poor little kitty will explode! With every correct puzzle, you will get 2 cats back.      \n      \nThe game is over when you run out of cats.","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/A4T3E/thumbnail/small.png","url":"https://play.gamepix.com/cat-strapped/embed?sid=1","plays":40431,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"HI71Z","slug":"dizzy-sushi","title":"Dizzy Sushi","description":"Dizzy Sushi a fun reflex game to match as many items as you can. this game is a mix of speed, memory, and skills!\nYou want to know how your memory skill! so use the memory test in this game!","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/HI71Z/thumbnail/small.png","url":"https://play.gamepix.com/dizzy-sushi/embed?sid=1","plays":40431,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"8EVLD","slug":"doodle-game","title":"Doodle Game","description":"On smartphone or i-Phone:\ndrag your finger left or right depending on where you want to go.\nOn pc:\ndrag your finger left or right depending on where you want to go or press right arrow and left arrow.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/8EVLD/thumbnail/small.png","url":"https://play.gamepix.com/doodle-game-ver-2-00/embed?sid=1","plays":40431,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"109CS","slug":"esther-the-penguin-return-to-antartica","title":"Esther the Penguin - Return to Antartica","description":"Esther has gone on vacation and has to go home to Antarctica. She doesn't remember how to come back and you have to help her. \nYou have to tap on the wooden objects so that Esther falls on the dock and Josè, her friend, can get her on the boat. \nEsther hasn't learned to swim yet, if she falls in the water it's a problem. Beware of pitfalls and sharks.","category":"Puzzle","tags":["puzzles","adventure"],"thumbnail":"https://games.assets.gamepix.com/109CS/thumbnail/small.png","url":"https://play.gamepix.com/esther-the-penguin-return-to-antarctica/embed?sid=1","plays":40431,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"OCI4I","slug":"immune-system-command","title":"Immune System Command","description":"This is a simplified and modern take on a retro classic game!!!\n\nThe one where you are the immune system command o protect your body from an endless hail of creepy Virus!\n\nSimple one tap game play.\n\nYou can never win this game, only survive as long as possible, because in war, all is lost in the end!","category":"Arcade","tags":["arcade","junior"],"thumbnail":"https://games.assets.gamepix.com/OCI4I/thumbnail/small.png","url":"https://play.gamepix.com/color-objects-for-kids/embed?sid=1","plays":40431,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"L117L","slug":"kill-birds","title":"Kill Birds","description":"Tap the birds out of the sky in this fast paced action strategy game from Mapi games.\nTry to finish all round in less time you can! have fun!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/L117L/thumbnail/small.png","url":"https://play.gamepix.com/kill-birds/embed?sid=1","plays":40431,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"7M718","slug":"match-2d","title":"Match 2D","description":"Get ready for a new, challenging and original matching pair game? You need to match 2D extra cute characters on the ground and pop them all! When you clear a level, you will find new match to pair.\nThis matching pairs cute match game is so easy that anyone can play it.","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/7M718/thumbnail/small.png","url":"https://play.gamepix.com/match-2d/embed?sid=1","plays":40431,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"L651E","slug":"mumble-jumble","title":"Mumble Jumble","description":"Your GOAL:   \nunscramble as many five-letter words as you can with out running out of time.   \nWith two game modality, you will be entertained for hours. In Endless mode, you get 20 seconds to unscramble each word.   \nIn Time mode, solve as many words as you can in 3 minutes.   \n   \nFeatures Bullets:   \n• Over 3.000 common 5-letter words   \n• 2 action-packed game modes   \n• Best score and word count tracker   \n• Next word indicator   \n• 3 word skips per game   \n• Awesome puzzle App for all family   \n• Amazing graphics effects   \n• Cool music sounds   \nHave Fun with this great word puzzle game!","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/L651E/thumbnail/small.png","url":"https://play.gamepix.com/mumble-jumble/embed?sid=1","plays":40431,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"A77G4","slug":"percentage-game","title":"Percentage Game","description":"Whoever says that math is boring has clearly never played Percentage, a fun and challenging fraction-based game.\nA percentage is a fraction based number game, the objective is to select the floating bubble of a fraction which is equal to the percentage displayed above, for every correct answer you score points and collect awesome Christmas themed baubles and trinkets to make sure that you’ve got the best Christmas decorations but make sure you don’t forget about the timer, This game is a must-try for everyone who wants to make math a little more fun and understandable.\n","category":"Puzzle","tags":["puzzles","junior"],"thumbnail":"https://games.assets.gamepix.com/A77G4/thumbnail/small.png","url":"https://play.gamepix.com/percentage-games/embed?sid=1","plays":40431,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"4S81A","slug":"pop-balloons","title":"PoP Balloons","description":"PoP Balloons is a cool action game very easy and intuitive to play, but it will be hard to stop playing.\n\nPop with your finger the color balloons on the screen, came on don’t let them vanish away!\nRed give more points than the others; don't touch the Black one!\n\nEnjoy popping balloons the more you can!       \n\nProduct feature bullets:\n • Ideal for all Kids and Children\n • Cool cartoon graphics\n • Easy to play\n • Very cool funny sound effects\n • Local scoreboard to sign your records\n • Easy to start hard to stop","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/4S81A/thumbnail/small.png","url":"https://play.gamepix.com/pop-balloons/embed?sid=1","plays":40431,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"8TIL1","slug":"poppy-it-playtime","title":"Poppy it Playtime","description":"Complete all Poppy pop it toys to Escape From The Factory! Try to do that as faster as you can! If you ever know about Poppy scary character, it's Playtime for you to get start in this game.! enjoy it!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/8TIL1/thumbnail/small.png","url":"https://play.gamepix.com/poppy-it-playtime/embed?sid=1","plays":40431,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"N6619","slug":"snail-run","title":"Snail Run","description":"The snail run game is an interactive way to get your blood sprinting through you. All it takes are two people, some space in which they can move around freely (the bigger the better), and this simple but fun activity! The person who starts off goes on their toes while holding onto one side of whatever object or surface will be used for balance like a pondside log; then behind them follows another player ready with hand spoons so both may share lightly tapping feet together as if dancing Lindy hop style without stepping too far forward nor backward - making sure only light taps adorn each step towards success until reaching finish line at center stage where victory awaits those able enough runners slow down enough before.","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/N6619/thumbnail/small.png","url":"https://play.gamepix.com/snail-run/embed?sid=1","plays":40431,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"U9TAG","slug":"squid-dentist-game","title":"Squid Dentist Game","description":"Take care of all the Squid patients in this great Dentist Office game!       \nNow let yourself be a great dentist and take care of your Squid\npatient.\nDon't be a crazy dentist!\n\nKey Features:\n- 6 Squid Character!\n- Great effects!\n- Totally awesome dentist tools!\n- All funny sound\n- Great graphics\n- It's a great Kids quite game ;)\nWhat are you waiting for?\n\nGet started playing Squid Dentist NOW!!!","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/U9TAG/thumbnail/small.png","url":"https://play.gamepix.com/squid-dentist-game/embed?sid=1","plays":40431,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"146AP","slug":"tap-ninja","title":"Tap Ninja","description":"Tap Ninja is a fun and addictive game to play on.\nWe all know about the reflexes have with ninja, so here you have to become one of them.\nSo tap repeatedly on the items which are falling and keep away from the dynamites and achieve high scores.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/146AP/thumbnail/small.png","url":"https://play.gamepix.com/tap-ninja/embed?sid=1","plays":40431,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"21GM7","slug":"trick-or-treat-halloween-games","title":"Trick or Treat Halloween Games","description":"Trick or Treat Halloween is a cute puzzle game with all funny and scary Halloween items.\nHere is the season of Halloween where you see lots of similar items like pumpkins, hats. eyeballs, skeletons, spiders, and more scary stuff.\nHere in this game select any scary item and try to solve the jigsaw puzzle by matching all the pieces.\nComplete all the scary items and win the game.","category":"Arcade","tags":["junior"],"thumbnail":"https://games.assets.gamepix.com/21GM7/thumbnail/small.png","url":"https://play.gamepix.com/trick-or-treat-halloween-games/embed?sid=1","plays":40431,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"T46UO","slug":"winter-house-quest","title":"Winter House Quest","description":"Very unique puzzle game.\nTry to solve how to get from this creepy house!","category":"Puzzle","tags":["adventure","puzzles"],"thumbnail":"https://games.assets.gamepix.com/T46UO/thumbnail/small.png","url":"https://play.gamepix.com/winter-house-quest/embed?sid=1","plays":40431,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"0DRBN","slug":"battalion-commander-1917","title":"Battalion Commander 1917","description":"TBD","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/0DRBN/thumbnail/small.png","url":"https://play.gamepix.com/battalion-commander-1917/embed?sid=1","plays":40430,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"69D53","slug":"bridge-race-stairs-run-build","title":"Bridge Race Stairs Run Build","description":"Pave the way by collecting bricks to see who is the fastest one. Don't let others steal your bridge! \n \nHave you ever wished to build a bridge? Try this collecting game! Enjoy a bridge-building race from rooftop to rooftop. Collect logs of your colour, choose a bridge, place them to build yours, and get to the finish line before others build the bridge and win the race!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/69D53/thumbnail/small.png","url":"https://play.gamepix.com/squid/embed?sid=1","plays":40430,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"A15T2","slug":"card-match","title":"Card Match","description":"Try this nice game of cards, you must find all pairs equally among all the cards using your memory, this game is designed for children, the sound effects are delightful and make you laughing all the children, the graphics are simple but very clean, beautiful and colorful! if he touches the animals that appear on the screen feel of funny lines that will make anyone laugh.\n\nThere are three different themes, animals, toys and objects.\n\nProduct feature bullets:\n• Best memory exercise for your kids.\n• Graphics in high definition.\n• Sound effects likeable.\n• Fun music and sound fx.  \n• Colorful graphics.\n• Gameplay immediate.\n• Three different subjects.\n• Different backgrounds.   \n• Hours of fun for your kid.\n\nMatch HD is simple to play but hard to stop ...especially suitable for small children at play.","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/A15T2/thumbnail/small.png","url":"https://play.gamepix.com/card-match/embed?sid=1","plays":40430,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"G6H21","slug":"fly-ghost","title":"Fly Ghost","description":"Fly Ghost - It's a fun game in a simple but challenging way, a ghost slowly flies by the man dodging pipes and without touching the ground.\n\nGameplay:\n\nYou need to constantly control the frequency of clicks on the screen to adjust the flight height and landing speed of the bird, so that the bird can smoothly pass through the tube space on the right side of the screen. If the ghost accidentally cleans and touches the tube, you lose.","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/G6H21/thumbnail/small.png","url":"https://play.gamepix.com/fly-ghost/embed?sid=1","plays":40430,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"45E5T","slug":"fruits-shooter-pop-master","title":"Fruits Shooter Pop Master","description":"Fruits Shooter Pop Master is a free online game. Shoot fruits and pop all the fruits in this fun puzzle game! \nIn this free online game, you are a fruit shooter. You must shoot all the fruits in order to win! The objective of the game is to pop as many fruits as possible in each level. There are five levels with different obstacles and challenges that you must overcome. Your goal is to pop all the fruits in each level before time runs out!","category":"Puzzle","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/45E5T/thumbnail/small.png","url":"https://play.gamepix.com/fruits-shooter-pop-master/embed?sid=1","plays":40430,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"3NKT4","slug":"kenny-the-cow","title":"Kenny the Cow","description":"Downhill skiing fun and mayhem in this great game!\nAvoid the obstacles, move up and down the hill, collect the stars, hit the ramp and perform tricks and stunts for more points\nALL WHILST SKIING AS A COW! Sounds crazy? It is!\n\nParallax scrolling at on an angle, watch trees and rocks whoosh past you as you whizz down the ski slopes; and just watch as Kenny our hero flays down the slopes!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/3NKT4/thumbnail/small.png","url":"https://play.gamepix.com/kenny-the-cow/embed?sid=1","plays":40430,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"2EAE9","slug":"maze-game-kids","title":"Maze Game Kids","description":"A fun maze game to exercise your mind. Try to go through the 15 mazes as fast as possible and compare the time with your friends.","category":"Arcade","tags":["puzzles"],"thumbnail":"https://games.assets.gamepix.com/2EAE9/thumbnail/small.png","url":"https://play.gamepix.com/maze-game-kids/embed?sid=1","plays":40430,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"0OT14","slug":"robot-ball","title":"Robot Ball","description":"robot ball is an html5 arcade game, touch the screen to control the player avoid the falling robot and get score from it ","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/0OT14/thumbnail/small.png","url":"https://play.gamepix.com/robot-chopter/embed?sid=1","plays":40430,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"R0O66","slug":"rocket-fly-forward","title":"Rocket Fly Forward","description":"Control one Fly Rocket and try to collect the more you can!   \nEnjoy it!","category":"Arcade","tags":["arcade"],"thumbnail":"https://games.assets.gamepix.com/R0O66/thumbnail/small.png","url":"https://play.gamepix.com/rocket-fly-forward/embed?sid=1","plays":40430,"rating":4.7,"featured":false,"source":"gamepix"},{"id":"O34V3","slug":"shadoworld-adventure","title":"Shadoworld Adventure","description":"“Shadoworld Adventure” is a very fun platform / retro game! The character, a brave creature of the shadows, must cross the dark valley and defeat the enemies. Jump on enemies to eliminate them and watch out for the angry obstacles that fall on your head. Dodge the spikes to avoid losing the game! Find the key to open the portal at the end of each level. The game has 50 levels! Have a good time!","category":"Aventure","tags":["adventure"],"thumbnail":"https://games.assets.gamepix.com/O34V3/thumbnail/small.png","url":"https://play.gamepix.com/shadoworld-adventure/embed?sid=1","plays":40430,"rating":4.7,"featured":false,"source":"gamepix"}],"categories":[{"name":"Arcade","count":235},{"name":"Puzzle","count":90},{"name":"Aventure","count":77},{"name":"Sport","count":55},{"name":"Stratégie","count":43}]}]}],["$","footer",null,{"className":"page_footer__F3MD0","children":["$","div",null,{"className":"page_footerInner__5TPTB","children":[["$","span",null,{"className":"page_footerLogo__LcRrq","children":"NovArcade."}],["$","p",null,{"children":"Des jeux gratuits pour tout le monde, partout, tout le temps."}],["$","p",null,{"className":"page_footerLinks__ZWbAq","children":[["$","a",null,{"href":"#","children":"Confidentialité"}]," · ",["$","a",null,{"href":"#","children":"Contact"}]," · ",["$","a",null,{"href":"#","children":"Ajouter un jeu"}]]}]]}]}]]],null],null]},[["$","html",null,{"lang":"fr","children":["$","body",null,{"children":["$","$Lc",null,{"parallelRouterKey":"children","segmentPath":["children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$Ld",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":[["$","title",null,{"children":"404: This page could not be found."}],["$","div",null,{"style":{"fontFamily":"system-ui,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif,\"Apple Color Emoji\",\"Segoe UI Emoji\"","height":"100vh","textAlign":"center","display":"flex","flexDirection":"column","alignItems":"center","justifyContent":"center"},"children":["$","div",null,{"children":[["$","style",null,{"dangerouslySetInnerHTML":{"__html":"body{color:#000;background:#fff;margin:0}.next-error-h1{border-right:1px solid rgba(0,0,0,.3)}@media (prefers-color-scheme:dark){body{color:#fff;background:#000}.next-error-h1{border-right:1px solid rgba(255,255,255,.3)}}"}}],["$","h1",null,{"className":"next-error-h1","style":{"display":"inline-block","margin":"0 20px 0 0","padding":"0 23px 0 0","fontSize":24,"fontWeight":500,"verticalAlign":"top","lineHeight":"49px"},"children":"404"}],["$","div",null,{"style":{"display":"inline-block"},"c